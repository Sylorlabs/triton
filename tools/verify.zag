    if (!run_suite("picking", "rm -f probe/picking_test.new && ../zag/zag-poc/znc probe/picking_test.zag -o probe/picking_test.new && mv -f probe/picking_test.new probe/picking_test && ./probe/picking_test")) { f = f + 1; }
