fn gates_2(f: i32) i32 {
    if (!run_suite("security-regression", "rm -f probe/security_regression_test.new /tmp/triton_command_injection && ../zag/zag-poc/znc probe/security_regression_test.zag -o probe/security_regression_test.new && mv -f probe/security_regression_test.new probe/security_regression_test && ./probe/security_regression_test && TRITON_CAPS=all ./zagpa --agent --once 'test engine;touch /tmp/triton_command_injection' | rg -q 'E_COMMAND unknown test' && test ! -e /tmp/triton_command_injection")) { f = f + 1; }
    if (!run_suite("parser-corpus", "rm -f probe/parser_corpus_test.new && ../zag/zag-poc/znc probe/parser_corpus_test.zag -o probe/parser_corpus_test.new && mv -f probe/parser_corpus_test.new probe/parser_corpus_test && ./probe/parser_corpus_test")) { f = f + 1; }
    if (!run_suite("protocol-parser", "rm -f probe/protocol_parser_test.new && ../zag/zag-poc/znc --no-analyze probe/protocol_parser_test.zag -o probe/protocol_parser_test.new && mv -f probe/protocol_parser_test.new probe/protocol_parser_test && ./probe/protocol_parser_test")) { f = f + 1; }
    if (!run_suite("masterplan-evidence", "rm -f probe/masterplan_evidence_test.new && ../zag/zag-poc/znc probe/masterplan_evidence_test.zag -o probe/masterplan_evidence_test.new && mv -f probe/masterplan_evidence_test.new probe/masterplan_evidence_test && ./probe/masterplan_evidence_test")) { f = f + 1; }
    if (!run_suite("headless-render", "./zagpa --smoke /tmp/triton_verify_smoke.bmp")) { f = f + 1; }
    if (!run_suite("frame-overlay", "rm -f probe/frame_overlay_test.new && ../zag/zag-poc/znc probe/frame_overlay_test.zag -o probe/frame_overlay_test.new && mv -f probe/frame_overlay_test.new probe/frame_overlay_test && ./probe/frame_overlay_test")) { f = f + 1; }
    if (!run_suite("frame-diff", "rm -f probe/frame_diff_test.new && ../zag/zag-poc/znc probe/frame_diff_test.zag -o probe/frame_diff_test.new && mv -f probe/frame_diff_test.new probe/frame_diff_test && ./probe/frame_diff_test")) { f = f + 1; }
    if (!run_suite("agent-protocol", "TRITON_CAPS=all ./zagpa --agent examples/agent_demo.tcmd")) { f = f + 1; }
    if (!run_suite("zagctl-envelope", "rm -f /tmp/triton_zagctl_gate.zpa* && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_zagctl_gate.zpa ./zagctl new | rg -q 'idempotency_key=zagctl-' && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_zagctl_gate.zpa TRITON_IDEMPOTENCY=zagctl-fixed ./zagctl place plate 0 0 0 | rg -q 'idempotency_key=zagctl-fixed' && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_zagctl_gate.zpa TRITON_IDEMPOTENCY=zagctl-fixed ./zagctl place plate 0 0 0 | rg -q 'replay idempotency_key=zagctl-fixed'")) { f = f + 1; }
    if (!run_suite("agent-negotiation", "TRITON_CAPS=read,inspect,simulate ./zagpa --agent --once capabilities | rg -q 'protocol triton-agent-1' && TRITON_CAPS=read,inspect,simulate ./zagpa --agent --once capabilities | rg -q 'capability_bits 7' && TRITON_CAPS=read,inspect,simulate ./zagpa --agent --once capabilities | rg -q 'max_request_bytes 4096'")) { f = f + 1; }
    if (!run_suite("agent-error-codes", "./zagpa --agent --once nonsense | rg -q 'ERR E_COMMAND unknown command' && ./zagpa --agent --once 'sim mode invalid' | rg -q 'ERR E_BAD_MODE expected functional or physical' && ./zagpa --agent --once 'request bad -1 new' | rg -q 'ERR E_REQUEST_ENVELOPE expected_revision'")) { f = f + 1; }
    if (!run_suite("mcp-protocol", "body='{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\"}' && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | ./zagpa --mcp | rg -q '\"protocolVersion\":\"2024-11-05\"' && body='{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"triton_command\",\"arguments\":{\"command\":\"capabilities\"}}}' && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | ./zagpa --mcp | rg -q 'protocol triton-agent-1' && printf 'Content-Length: 1048577\\r\\n\\r\\n' | ./zagpa --mcp >/dev/null")) { f = f + 1; }
    if (!run_suite("mcp-mutation-envelope", "rm -f /tmp/triton_mcp_gate.zpa* && TRITON_CAPS=all TRITON_IDEMPOTENCY=mcp-init TRITON_SESSION=/tmp/triton_mcp_gate.zpa ./zagpa --agent --once new >/dev/null && base=$(cat /tmp/triton_mcp_gate.zpa.rev) && body='{\"jsonrpc\":\"2.0\",\"id\":3,\"method\":\"tools/list\"}' && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_gate.zpa ./zagpa --mcp | rg -q triton_mutate && body=\"{\\\"jsonrpc\\\":\\\"2.0\\\",\\\"id\\\":4,\\\"method\\\":\\\"tools/call\\\",\\\"params\\\":{\\\"name\\\":\\\"triton_mutate\\\",\\\"arguments\\\":{\\\"command\\\":\\\"place plate 0 0 0\\\",\\\"idempotency_key\\\":\\\"mcp-a\\\",\\\"expected_revision\\\":$base}}}\" && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_gate.zpa ./zagpa --mcp | rg -q 'id=1' && committed=$(cat /tmp/triton_mcp_gate.zpa.rev) && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_gate.zpa ./zagpa --mcp | rg -q \"replay idempotency_key=mcp-a revision=$committed\"")) { f = f + 1; }
    if (!run_suite("mcp-specialized-mutations", "rm -f /tmp/triton_mcp_special.zpa* && TRITON_CAPS=all TRITON_IDEMPOTENCY=mcp-special-init TRITON_SESSION=/tmp/triton_mcp_special.zpa ./zagpa --agent --once new >/dev/null && base=$(cat /tmp/triton_mcp_special.zpa.rev) && body='{\"jsonrpc\":\"2.0\",\"id\":5,\"method\":\"tools/list\"}' && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_special.zpa ./zagpa --mcp | rg -q '\"name\":\"triton_place\".*\"idempotency_key\".*\"expected_revision\"' && body='{\"jsonrpc\":\"2.0\",\"id\":6,\"method\":\"tools/call\",\"params\":{\"name\":\"triton_place\",\"arguments\":{\"kind\":\"plate\",\"x\":0,\"y\":0,\"z\":0}}}' && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_special.zpa ./zagpa --mcp | rg -q E_REQUEST_ENVELOPE && body=\"{\\\"jsonrpc\\\":\\\"2.0\\\",\\\"id\\\":7,\\\"method\\\":\\\"tools/call\\\",\\\"params\\\":{\\\"name\\\":\\\"triton_place\\\",\\\"arguments\\\":{\\\"kind\\\":\\\"plate\\\",\\\"x\\\":0,\\\"y\\\":0,\\\"z\\\":0,\\\"idempotency_key\\\":\\\"mcp-place\\\",\\\"expected_revision\\\":$base}}}\" && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_special.zpa ./zagpa --mcp | rg -q 'id=1' && committed=$(cat /tmp/triton_mcp_special.zpa.rev) && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_special.zpa ./zagpa --mcp | rg -q \"replay idempotency_key=mcp-place revision=$committed\"")) { f = f + 1; }
    if (!run_suite("mcp-tool-coverage", "rm -f /tmp/triton_mcp_tools.zpa* /tmp/triton_mcp_tools_export.* /tmp/triton_mcp_tools.trace && TRITON_CAPS=all TRITON_IDEMPOTENCY=mcp-tools-init TRITON_SESSION=/tmp/triton_mcp_tools.zpa ./zagpa --agent --once new >/dev/null && base=$(cat /tmp/triton_mcp_tools.zpa.rev) && body='{\"jsonrpc\":\"2.0\",\"id\":8,\"method\":\"tools/list\"}' && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_tools.zpa ./zagpa --mcp | rg -q 'triton_delete.*triton_export.*triton_trace.*triton_flash_import.*triton_flash_verify' && body='{\"jsonrpc\":\"2.0\",\"id\":9,\"method\":\"tools/call\",\"params\":{\"name\":\"triton_can_place\",\"arguments\":{\"kind\":\"plate\",\"x\":0,\"y\":0,\"z\":0}}}' && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_tools.zpa ./zagpa --mcp | rg -q yes && body=\"{\\\"jsonrpc\\\":\\\"2.0\\\",\\\"id\\\":10,\\\"method\\\":\\\"tools/call\\\",\\\"params\\\":{\\\"name\\\":\\\"triton_place\\\",\\\"arguments\\\":{\\\"kind\\\":\\\"plate\\\",\\\"x\\\":0,\\\"y\\\":0,\\\"z\\\":0,\\\"idempotency_key\\\":\\\"mcp-tools-place\\\",\\\"expected_revision\\\":$base}}}\" && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_tools.zpa ./zagpa --mcp | rg -q 'id=1' && body='{\"jsonrpc\":\"2.0\",\"id\":11,\"method\":\"tools/call\",\"params\":{\"name\":\"triton_get\",\"arguments\":{\"component_id\":1}}}' && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_tools.zpa ./zagpa --mcp | rg -q 'kind=plate' && rev1=$(cat /tmp/triton_mcp_tools.zpa.rev) && body=\"{\\\"jsonrpc\\\":\\\"2.0\\\",\\\"id\\\":12,\\\"method\\\":\\\"tools/call\\\",\\\"params\\\":{\\\"name\\\":\\\"triton_delete\\\",\\\"arguments\\\":{\\\"component_id\\\":1,\\\"idempotency_key\\\":\\\"mcp-tools-delete\\\",\\\"expected_revision\\\":$rev1}}}\" && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_tools.zpa ./zagpa --mcp | rg -q deleted && body='{\"jsonrpc\":\"2.0\",\"id\":13,\"method\":\"tools/call\",\"params\":{\"name\":\"triton_export\",\"arguments\":{\"prefix\":\"/tmp/triton_mcp_tools_export\"}}}' && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_tools.zpa ./zagpa --mcp | rg -q exported && body='{\"jsonrpc\":\"2.0\",\"id\":14,\"method\":\"tools/call\",\"params\":{\"name\":\"triton_trace\",\"arguments\":{\"path\":\"/tmp/triton_mcp_tools.trace\",\"steps\":1}}}' && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_tools.zpa ./zagpa --mcp | rg -q 'trace exported' && rev2=$(cat /tmp/triton_mcp_tools.zpa.rev) && body=\"{\\\"jsonrpc\\\":\\\"2.0\\\",\\\"id\\\":15,\\\"method\\\":\\\"tools/call\\\",\\\"params\\\":{\\\"name\\\":\\\"triton_flash_import\\\",\\\"arguments\\\":{\\\"path\\\":\\\"../flash/examples/photonic_massive.fir\\\",\\\"idempotency_key\\\":\\\"mcp-tools-flash\\\",\\\"expected_revision\\\":$rev2}}}\" && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_tools.zpa ./zagpa --mcp | rg -q 'ops=64 components=384 verification_failures=0' && body='{\"jsonrpc\":\"2.0\",\"id\":16,\"method\":\"tools/call\",\"params\":{\"name\":\"triton_flash_verify\",\"arguments\":{}}}' && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_tools.zpa ./zagpa --mcp | rg -q 'Flash photonic execution verified'")) { f = f + 1; }
    if (!run_suite("mcp-invariant-enforcement", "rm -f /tmp/triton_mcp_invariant.zpa* /tmp/mcp-inv-* && TRITON_CAPS=all TRITON_IDEMPOTENCY=inv-init TRITON_SESSION=/tmp/triton_mcp_invariant.zpa ./zagpa --agent --once new >/dev/null && base=$(cat /tmp/triton_mcp_invariant.zpa.rev) && before=$(sha256sum /tmp/triton_mcp_invariant.zpa) && body=\"{\\\"jsonrpc\\\":\\\"2.0\\\",\\\"id\\\":21,\\\"method\\\":\\\"tools/call\\\",\\\"params\\\":{\\\"name\\\":\\\"triton_place\\\",\\\"arguments\\\":{\\\"kind\\\":\\\"detector\\\",\\\"x\\\":0,\\\"y\\\":1,\\\"z\\\":0,\\\"idempotency_key\\\":\\\"inv-bad-place\\\",\\\"expected_revision\\\":$base}}}\" && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_invariant.zpa ./zagpa --mcp | rg -q 'needs GeSn plate underneath' && after=$(sha256sum /tmp/triton_mcp_invariant.zpa) && test \"$before\" = \"$after\" && test \"$(cat /tmp/triton_mcp_invariant.zpa.rev)\" = \"$base\" && body=\"{\\\"jsonrpc\\\":\\\"2.0\\\",\\\"id\\\":22,\\\"method\\\":\\\"tools/call\\\",\\\"params\\\":{\\\"name\\\":\\\"triton_route\\\",\\\"arguments\\\":{\\\"from_comp\\\":99,\\\"from_port\\\":0,\\\"to_comp\\\":100,\\\"to_port\\\":0,\\\"idempotency_key\\\":\\\"inv-bad-route\\\",\\\"expected_revision\\\":$base}}}\" && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_invariant.zpa ./zagpa --mcp | rg -q 'unknown component in route' && final=$(sha256sum /tmp/triton_mcp_invariant.zpa) && test \"$before\" = \"$final\" && test \"$(cat /tmp/triton_mcp_invariant.zpa.rev)\" = \"$base\" && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_mcp_invariant.zpa ./zagpa --agent --once list | rg -q '^\\.$'")) { f = f + 1; }
    if (!run_suite("flash-photonic", "rm -rf /tmp/triton_flash_source && cp -a ../flash /tmp/triton_flash_source && rm -f /tmp/triton_flash_gate.zpa* /tmp/triton_flash_export.* && (cd /tmp/triton_flash_source && ./flashc examples/photonic_massive.flash --target ppu32 >/dev/null) && cmp /tmp/triton_flash_source/examples/photonic_massive.fir ../flash/examples/photonic_massive.fir && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_flash_gate.zpa ./zagpa --agent --once 'request flash-import current flash import /tmp/triton_flash_source/examples/photonic_massive.fir' | rg -q 'ops=64 components=384 verification_failures=0' && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_flash_gate.zpa ./zagpa --agent --once 'flash verify' | rg -q 'Flash photonic execution verified' && cmp /tmp/triton_flash_gate.zpa examples/flash_photonic_massive.zpa && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_flash_gate.zpa ./zagpa --agent --once 'export /tmp/triton_flash_export' | rg -q exported && cmp /tmp/triton_flash_export.bom.txt examples/flash_photonic_massive.bom.txt && cmp /tmp/triton_flash_export.netlist.txt examples/flash_photonic_massive.netlist.txt && cmp /tmp/triton_flash_export.models.txt examples/flash_photonic_massive.models.txt && cmp /tmp/triton_flash_export.report.txt examples/flash_photonic_massive.report.txt")) { f = f + 1; }
    return f;
}

fn gates_3(f: i32) i32 {
    if (!run_suite("agent-capability-denial", "rm -f /tmp/triton_cap_gate.zpa* && TRITON_CAPS=all TRITON_IDEMPOTENCY=cap-init TRITON_SESSION=/tmp/triton_cap_gate.zpa ./zagpa --agent --once new >/dev/null && before=$(sha256sum /tmp/triton_cap_gate.zpa) && out=$(TRITON_CAPS=read,inspect,simulate TRITON_SESSION=/tmp/triton_cap_gate.zpa ./zagpa --agent --once 'place plate 0 0 0') && after=$(sha256sum /tmp/triton_cap_gate.zpa) && test \"$before\" = \"$after\" && echo \"$out\" | rg -q E_CAP_DENIED")) { f = f + 1; }
    if (!run_suite("agent-user-rules", "rm -rf /tmp/triton-rule-root /tmp/triton-rule-outside.zpa && mkdir -p /tmp/triton-rule-root && TRITON_CAPS=all TRITON_SESSION=/tmp/triton-rule-root/live.zpa ./zagpa --agent --once new >/dev/null && base=$(cat /tmp/triton-rule-root/live.zpa.rev) && TRITON_CAPS=read,inspect,simulate TRITON_ALLOW_OPS=edit TRITON_SESSION=/tmp/triton-rule-root/live.zpa ./zagpa --agent --once \"request rule-place $base place plate 0 0 0\" | rg -q 'id=1' && before=$(sha256sum /tmp/triton-rule-root/live.zpa) && base=$(cat /tmp/triton-rule-root/live.zpa.rev) && TRITON_CAPS=all TRITON_DENY_OPS=edit TRITON_SESSION=/tmp/triton-rule-root/live.zpa ./zagpa --agent --once \"request rule-deny $base place plate 20 0 0\" | rg -q E_RULE_DENIED && after=$(sha256sum /tmp/triton-rule-root/live.zpa) && test \"$before\" = \"$after\" && base=$(cat /tmp/triton-rule-root/live.zpa.rev) && TRITON_CAPS=read,inspect,simulate TRITON_ALLOW_OPS=save TRITON_PROJECT_ROOT=/tmp/triton-rule-root TRITON_SESSION=/tmp/triton-rule-root/live.zpa ./zagpa --agent --once \"request rule-save $base save /tmp/triton-rule-outside.zpa\" | rg -q E_PATH_OUTSIDE_ROOT && test ! -e /tmp/triton-rule-outside.zpa")) { f = f + 1; }
    if (!run_suite("agent-scoped-grants", "rm -rf /tmp/triton-grant-root /tmp/triton-grant-other && mkdir -p /tmp/triton-grant-root/allowed /tmp/triton-grant-root/blocked /tmp/triton-grant-other && TRITON_CAPS=all TRITON_SESSION=/tmp/triton-grant-root/live.zpa ./zagpa --agent --once new >/dev/null && base=$(cat /tmp/triton-grant-root/live.zpa.rev) && grant='project=/tmp/triton-grant-root session=/tmp/triton-grant-root/live.zpa ops=save path=/tmp/triton-grant-root/allowed expires_after_ms=999999999999' && TRITON_CAPS=all TRITON_PROJECT_ROOT=/tmp/triton-grant-root TRITON_SESSION=/tmp/triton-grant-root/live.zpa TRITON_GRANT=\"$grant\" ./zagpa --agent --once \"request grant-save $base save /tmp/triton-grant-root/allowed/out.zpa\" | rg -q saved && TRITON_CAPS=all TRITON_PROJECT_ROOT=/tmp/triton-grant-root TRITON_SESSION=/tmp/triton-grant-root/live.zpa TRITON_GRANT=\"$grant\" ./zagpa --agent --once list | rg -q 'E_GRANT_SCOPE operation denied' && bad_session='project=/tmp/triton-grant-root session=/tmp/triton-grant-root/other.zpa ops=inspect expires_after_ms=999999999999' && TRITON_CAPS=all TRITON_PROJECT_ROOT=/tmp/triton-grant-root TRITON_SESSION=/tmp/triton-grant-root/live.zpa TRITON_GRANT=\"$bad_session\" ./zagpa --agent --once list | rg -q 'E_GRANT_SCOPE session mismatch' && bad_project='project=/tmp/triton-grant-other session=/tmp/triton-grant-root/live.zpa ops=inspect expires_after_ms=999999999999' && TRITON_CAPS=all TRITON_PROJECT_ROOT=/tmp/triton-grant-root TRITON_SESSION=/tmp/triton-grant-root/live.zpa TRITON_GRANT=\"$bad_project\" ./zagpa --agent --once list | rg -q 'E_GRANT_SCOPE project mismatch' && base=$(cat /tmp/triton-grant-root/live.zpa.rev) && TRITON_CAPS=all TRITON_PROJECT_ROOT=/tmp/triton-grant-root TRITON_SESSION=/tmp/triton-grant-root/live.zpa TRITON_GRANT=\"$grant\" ./zagpa --agent --once \"request grant-path $base save /tmp/triton-grant-root/blocked/out.zpa\" | rg -q 'E_GRANT_SCOPE path denied' && expired='project=/tmp/triton-grant-root session=/tmp/triton-grant-root/live.zpa ops=inspect expires_after_ms=1' && TRITON_CAPS=all TRITON_PROJECT_ROOT=/tmp/triton-grant-root TRITON_SESSION=/tmp/triton-grant-root/live.zpa TRITON_GRANT=\"$expired\" ./zagpa --agent --once list | rg -q 'E_GRANT_SCOPE expired' && test -e /tmp/triton-grant-root/allowed/out.zpa && test ! -e /tmp/triton-grant-root/blocked/out.zpa")) { f = f + 1; }
    if (!run_suite("agent-path-confinement", "rm -f /tmp/triton_path_gate.zpa /tmp/triton_outside.zpa /tmp/triton_path_render.bmp && TRITON_CAPS=all TRITON_PROJECT_ROOT=/tmp/triton-root TRITON_SESSION=/tmp/triton-root/live.zpa ./zagpa --agent --once 'request path-save current save /tmp/triton_outside.zpa' | rg -q E_PATH_OUTSIDE_ROOT && test ! -e /tmp/triton_outside.zpa && TRITON_CAPS=all TRITON_PROJECT_ROOT=/tmp/triton-root TRITON_SESSION=/tmp/triton-root/live.zpa ./zagpa --agent --once 'render /tmp/triton-root/../triton_path_render.bmp' | rg -q E_PATH_OUTSIDE_ROOT && test ! -e /tmp/triton_path_render.bmp")) { f = f + 1; }
    if (!run_suite("agent-revision-conflict", "rm -f /tmp/triton_rev_gate.zpa* && TRITON_CAPS=all TRITON_IDEMPOTENCY=rev-init TRITON_SESSION=/tmp/triton_rev_gate.zpa ./zagpa --agent --once new >/dev/null && base=$(cat /tmp/triton_rev_gate.zpa.rev) && TRITON_CAPS=all TRITON_IDEMPOTENCY=rev-a TRITON_SESSION=/tmp/triton_rev_gate.zpa TRITON_EXPECT_REV=$base ./zagpa --agent --once 'place plate 0 0 0' >/dev/null && next=$(cat /tmp/triton_rev_gate.zpa.rev) && test $next -gt $base && before=$(sha256sum /tmp/triton_rev_gate.zpa) && out=$(TRITON_CAPS=all TRITON_IDEMPOTENCY=rev-b TRITON_SESSION=/tmp/triton_rev_gate.zpa TRITON_EXPECT_REV=$base ./zagpa --agent --once 'place plate 20 0 0') && after=$(sha256sum /tmp/triton_rev_gate.zpa) && echo \"$out\" | rg -q 'E_REV_CONFLICT expected=' && test \"$before\" = \"$after\" && test \"$(cat /tmp/triton_rev_gate.zpa.rev)\" = \"$next\" && TRITON_CAPS=all TRITON_IDEMPOTENCY=rev-c TRITON_SESSION=/tmp/triton_rev_gate.zpa TRITON_EXPECT_REV=$next ./zagpa --agent --once 'place plate 20 0 0' | rg -q 'OK id='")) { f = f + 1; }
    if (!run_suite("agent-idempotency", "rm -f /tmp/triton_idem_gate.zpa* && TRITON_CAPS=all TRITON_IDEMPOTENCY=idem-init TRITON_SESSION=/tmp/triton_idem_gate.zpa ./zagpa --agent --once new >/dev/null && base=$(cat /tmp/triton_idem_gate.zpa.rev) && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_idem_gate.zpa TRITON_EXPECT_REV=$base TRITON_IDEMPOTENCY=place-a ./zagpa --agent --once 'place plate 0 0 0' | rg -q 'OK id=' && committed=$(cat /tmp/triton_idem_gate.zpa.rev) && before=$(sha256sum /tmp/triton_idem_gate.zpa) && out=$(TRITON_CAPS=all TRITON_SESSION=/tmp/triton_idem_gate.zpa TRITON_EXPECT_REV=$base TRITON_IDEMPOTENCY=place-a ./zagpa --agent --once 'place plate 0 0 0') && after=$(sha256sum /tmp/triton_idem_gate.zpa) && echo \"$out\" | rg -q 'OK replay idempotency_key=place-a revision=' && test \"$before\" = \"$after\" && test \"$(cat /tmp/triton_idem_gate.zpa.rev)\" = \"$committed\" && bad=$(TRITON_CAPS=all TRITON_SESSION=/tmp/triton_idem_gate.zpa TRITON_IDEMPOTENCY='bad/key' ./zagpa --agent --once 'place plate 20 0 0') && echo \"$bad\" | rg -q E_IDEMPOTENCY_KEY")) { f = f + 1; }
    if (!run_suite("agent-mutation-envelope", "rm -f /tmp/triton_envelope_gate.zpa* && TRITON_CAPS=all TRITON_IDEMPOTENCY=envelope-init TRITON_SESSION=/tmp/triton_envelope_gate.zpa ./zagpa --agent --once new >/dev/null && base=$(cat /tmp/triton_envelope_gate.zpa.rev) && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_envelope_gate.zpa ./zagpa --agent --once 'place plate 0 0 0' | rg -q E_IDEMPOTENCY_REQUIRED && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_envelope_gate.zpa ./zagpa --agent --once \"request envelope-a $base place plate 0 0 0\" | rg -q 'OK id=' && committed=$(cat /tmp/triton_envelope_gate.zpa.rev) && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_envelope_gate.zpa ./zagpa --agent --once \"request envelope-a $base place plate 0 0 0\" | rg -q \"OK replay idempotency_key=envelope-a revision=$committed\"")) { f = f + 1; }
    if (!run_suite("agent-audit-result", "rm -f /tmp/triton_audit_gate.zpa* /tmp/triton_audit_gate.log && TRITON_CAPS=all TRITON_IDEMPOTENCY=audit-init TRITON_SESSION=/tmp/triton_audit_gate.zpa TRITON_AUDIT=/tmp/triton_audit_gate.log TRITON_ACTOR=verify-agent ./zagpa --agent --once new >/dev/null && base=$(cat /tmp/triton_audit_gate.zpa.rev) && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_audit_gate.zpa TRITON_AUDIT=/tmp/triton_audit_gate.log TRITON_ACTOR=verify-agent ./zagpa --agent --once \"request audit-place $base place plate 0 0 0\" | rg -q 'idempotency_key=audit-place' && rg -q 'actor=verify-agent state=success required=8 request=place plate 0 0 0 result=id=1 .*revision=.*affected_id=1 undo_token=' /tmp/triton_audit_gate.log")) { f = f + 1; }
    if (!run_suite("audit-redaction", "rm -f /tmp/triton_redact_gate.zpa* /tmp/triton_redact_gate.log /tmp/triton_XAUTHORITY_cookie_password_hunter2.zpa /tmp/triton_private_project.zpa && printf 'zpa 1\\nc 1 0 0 0 0 0 1 0 1550000 0 |PRIVATE_SCENE_SENTINEL\\n' > /tmp/triton_private_project.zpa && TRITON_CAPS=all TRITON_IDEMPOTENCY=red-init TRITON_SESSION=/tmp/triton_redact_gate.zpa TRITON_AUDIT=/tmp/triton_redact_gate.log TRITON_ACTOR=token-secret-actor ./zagpa --agent --once new >/dev/null && base=$(cat /tmp/triton_redact_gate.zpa.rev) && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_redact_gate.zpa TRITON_AUDIT=/tmp/triton_redact_gate.log TRITON_ACTOR=token-secret-actor ./zagpa --agent --once \"request red-save $base save /tmp/triton_XAUTHORITY_cookie_password_hunter2.zpa\" | rg -q saved && base=$(cat /tmp/triton_redact_gate.zpa.rev) && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_redact_gate.zpa TRITON_AUDIT=/tmp/triton_redact_gate.log TRITON_ACTOR=token-secret-actor ./zagpa --agent --once \"request red-open $base open /tmp/triton_private_project.zpa\" | rg -q opened && test -e /tmp/triton_XAUTHORITY_cookie_password_hunter2.zpa && ! rg -q 'hunter2|token-secret|XAUTHORITY|cookie_password|PRIVATE_SCENE_SENTINEL' /tmp/triton_redact_gate.log && rg -q '\\[redacted\\]' /tmp/triton_redact_gate.log && rg -q 'undo_token=' /tmp/triton_redact_gate.log")) { f = f + 1; }
    if (!run_suite("diagnostics-privacy", "rm -f /tmp/triton_diag_private.zpa /tmp/triton_diag.txt /tmp/triton_diag_session.zpa* && printf 'zpa 1\\nc 1 0 0 0 0 0 1 0 1550000 0 |PRIVATE_DIAG_SENTINEL\\n' > /tmp/triton_diag_private.zpa && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_diag_session.zpa ./zagpa --agent --once new >/dev/null && base=$(cat /tmp/triton_diag_session.zpa.rev) && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_diag_session.zpa ./zagpa --agent --once \"request diag-open $base open /tmp/triton_diag_private.zpa\" | rg -q opened && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_diag_session.zpa ./zagpa --agent --once 'diagnostics /tmp/triton_diag.txt' | rg -q 'diagnostics written' && rg -q 'scene_contents=excluded_by_default' /tmp/triton_diag.txt && ! rg -q 'PRIVATE_DIAG_SENTINEL|GeSn|Plate|zpa 1|c 1' /tmp/triton_diag.txt")) { f = f + 1; }
