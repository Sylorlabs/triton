    if (!run_suite("unsupported-claim-audit", "! rg -n '110 GHz|9[.]09 ps|2100 MHz|40 CUs|renderD128|Radeon RX|Navi 10' README.md src probe tools --glob '!device_model.zag' --glob '!verify.zag' --glob '!gpu_query_test.zag'")) { f = f + 1; }
    if (!run_suite("stale-language-audit", "! rg -n -i 'world.?first|revolutionary|breakthrough|probe-era|demo only|toy|lab[- ]?validated|hardware[- ]?validated|silicon[- ]?proven|production[- ]?ready' README.md docs src probe tools examples --glob '!verify.zag'")) { f = f + 1; }
    if (!run_suite("pure-zag-tree", "test -z \"$(find src std tools probe -type f \\( -name '*.c' -o -name '*.h' -o -name '*.py' -o -name '*.zig' \\) -print -quit)\"")) { f = f + 1; }
    if (!run_suite("agent-ops", "rm -f /tmp/tao_gate.zpa* && S=/tmp/tao_gate.zpa && TRITON_CAPS=all TRITON_IDEMPOTENCY=n TRITON_SESSION=$S ./zagpa --agent --once new >/dev/null && TRITON_CAPS=all TRITON_SESSION=$S ./zagpa --agent --once \"request k1 $(cat $S.rev) place plate 0 0 0\" | rg -q 'OK id=1' && TRITON_CAPS=all TRITON_SESSION=$S ./zagpa --agent --once \"request k2 $(cat $S.rev) place emitter 1 1 2\" | rg -q 'OK id=2' && TRITON_CAPS=all TRITON_SESSION=$S ./zagpa --agent --once \"request k3 $(cat $S.rev) place chamber 4 1 3\" | rg -q 'OK id=3' && TRITON_CAPS=all TRITON_SESSION=$S ./zagpa --agent --once \"request k4 $(cat $S.rev) route 2 0 3 0\" | rg -q 'OK id=1' && TRITON_CAPS=all TRITON_SESSION=$S ./zagpa --agent --once \"request k5 $(cat $S.rev) move 2 1 0 0\" | rg -q 'OK moved' && TRITON_CAPS=all TRITON_SESSION=$S ./zagpa --agent --once \"request k6 $(cat $S.rev) rotate 3\" | rg -q 'OK rotated' && TRITON_CAPS=all TRITON_SESSION=$S ./zagpa --agent --once \"request k7 $(cat $S.rev) reroute 1\" | rg -q 'OK id=' && TRITON_CAPS=all TRITON_SESSION=$S ./zagpa --agent --once \"request k8 $(cat $S.rev) disconnect 2\" | rg -q 'OK disconnected' && TRITON_CAPS=all TRITON_SESSION=$S ./zagpa --agent --once \"request k9 $(cat $S.rev) undo\" | rg -q 'OK undo' && TRITON_CAPS=all TRITON_SESSION=$S ./zagpa --agent --once 'inspect' | rg -q 'schema=2 model_complete=yes' && TRITON_CAPS=all TRITON_SESSION=$S ./zagpa --agent --once \"request k10 $(cat $S.rev) close\" | rg -q 'OK closed'")) { f = f + 1; }
