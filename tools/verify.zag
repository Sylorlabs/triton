t /tmp/triton_undo_audit.zpa.rev) && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_undo_audit.zpa TRITON_AUDIT=/tmp/triton_undo_audit.log ./zagpa --agent --once \"request ua-delete $r delete 2\" | rg -q deleted && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_undo_audit.zpa ./zagpa --agent --once list > /tmp/ua-list4 && ! rg -q '^C 2 ' /tmp/ua-list4 && ! rg -q '^G 1 ' /tmp/ua-list4 && r=$(cat /tmp/triton_undo_audit.zpa.rev) && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_undo_audit.zpa TRITON_AUDIT=/tmp/triton_undo_audit.log ./zagpa --agent --once \"request ua-undo-delete $r undo\" | rg -q undo && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_undo_audit.zpa ./zagpa --agent --once list > /tmp/ua-list5 && rg -q '^C 2 ' /tmp/ua-list5 && rg -q 'state=success .*request=route 2 0 3 0 .*affected_id=1 undo_token=' /tmp/triton_undo_audit.log && rg -q 'state=success .*request=delete 2 .*affected_id=2 undo_token=' /tmp/triton_undo_audit.log && rg -q 'state=success .*request=undo .*undo_token=' /tmp/triton_undo_audit.log && rg -q 'state=success .*request=redo .*undo_token=' /tmp/triton_undo_audit.log")) { f = f + 1; }
    if (!run_suite("bounded-inputs", "long=$(head -c 5000 /dev/zero | tr '\\0' x) && ./zagpa --agent --once \"$long\" | rg -q E_REQUEST_LIMIT && rm -f /tmp/triton_oversize.zpa && { printf 'zpa 2\\n'; head -c 16777217 /dev/zero; } > /tmp/triton_oversize.zpa && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_flash_gate.zpa ./zagpa --agent --once 'request bounded-open current open /tmp/triton_oversize.zpa' | rg -q 'open failed' && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_flash_gate.zpa ./zagpa --agent --once 'trace /tmp/no.trace 100001' | rg -q E_TRACE_LIMIT && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_flash_gate.zpa ./zagpa --agent --once 'sim step 100001' | rg -q E_SIM_LIMIT && ./zagpa --x11-capture /tmp/no.bmp --width 4097 --height 4096 2>&1 | rg -q 'dimensions outside'")) { f = f + 1; }
