    if (!run_suite("render-golden", "rm -f probe/render_golden_test.new && ../zag/zag-poc/znc probe/render_golden_test.zag -o probe/render_golden_test.new && mv -f probe/render_golden_test.new probe/render_golden_test && ./probe/render_golden_test")) { f = f + 1; }
    if (!run_suite("bench", "rm -f tools/bench.bin && ../zag/zag-poc/znc tools/bench.zag -o tools/bench.bin && ./tools/bench.bin")) { f = f + 1; }
    if (!run_suite("agent-matrix", "sh tools/agent_matrix.sh")) { f = f + 1; }
    if (!run_suite("crash-recovery", "rm -f /tmp/triton_crash_* && ../zag/zag-poc/znc probe/crash_recovery_test.zag -o probe/crash_recovery_test.new && mv -f probe/crash_recovery_test.new probe/crash_recovery_test && ./probe/crash_recovery_test")) { f = f + 1; }
    if (!run_suite("sim-semantics", "rm -f probe/sim_semantics_test.new && ../zag/zag-poc/znc probe/sim_semantics_test.zag -o probe/sim_semantics_test.new && mv -f probe/sim_semantics_test.new probe/sim_semantics_test && ./probe/sim_semantics_test")) { f = f + 1; }
    if (!run_suite("feedback", "rm -f probe/feedback_test.new && ../zag/zag-poc/znc probe/feedback_test.zag -o probe/feedback_test.new && mv -f probe/feedback_test.new probe/feedback_test && ./probe/feedback_test")) { f = f + 1; }
    if (!run_suite("optimizer-verify", "rm -f probe/opt_verify_test.new && ../zag/zag-poc/znc probe/opt_verify_test.zag -o probe/opt_verify_test.new && mv -f probe/opt_verify_test.new probe/opt_verify_test && ./probe/opt_verify_test")) { f = f + 1; }
    if (!run_suite("optimizer-schedule", "rm -f probe/opt_schedule_test.new && ../zag/zag-poc/znc probe/opt_schedule_test.zag -o probe/opt_schedule_test.new && mv -f probe/opt_schedule_test.new probe/opt_schedule_test && ./probe/opt_schedule_test")) { f = f + 1; }
    if (!run_suite("provenance-units", "rm -f probe/provenance_units_test.new && ../zag/zag-poc/znc probe/provenance_units_test.zag -o probe/provenance_units_test.new && mv -f probe/provenance_units_test.new probe/provenance_units_test && ./probe/provenance_units_test")) { f = f + 1; }
    if (!run_suite("model-schema-migration", "rm -f /tmp/prism_model_migrated.zpa probe/model_schema_test.new && ../zag/zag-poc/znc probe/model_schema_test.zag -o probe/model_schema_test.new && mv -f probe/model_schema_test.new probe/model_schema_test && ./probe/model_schema_test")) { f = f + 1; }
    if (!run_suite("ui-agent-access", "rm -f /tmp/prism_ui_agent_session.zpa* /tmp/prism_ui_agent_access.bmp probe/ui_agent_access_test.new && ../zag/zag-poc/znc probe/ui_agent_access_test.zag -o probe/ui_agent_access_test.new && mv -f probe/ui_agent_access_test.new probe/ui_agent_access_test && TRITON_SESSION=/tmp/prism_ui_agent_session.zpa TRITON_CAPS=all ./probe/ui_agent_access_test")) { f = f + 1; }
    if (!run_suite("mcp-ui-model-schema", "body='{\"jsonrpc\":\"2.0\",\"id\":41,\"method\":\"tools/list\"}' && out=$({ printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/prism_mcp_ui.zpa ./zagpa --mcp) && echo \"$out\" | rg -q 'triton_ui_list.*triton_ui_screenshot.*triton_ui_activate.*triton_model_status.*triton_model_migrate' && echo \"$out\" | rg -q 'triton_ui_activate.*idempotency_key.*expected_revision' && body='{\"jsonrpc\":\"2.0\",\"id\":42,\"method\":\"tools/call\",\"params\":{\"name\":\"triton_ui_list\",\"arguments\":{}}}' && { printf 'Content-Length: %s\\r\\n\\r\\n' ${#body}; printf %s \"$body\"; } | TRITON_CAPS=all TRITON_SESSION=/tmp/prism_mcp_ui.zpa ./zagpa --mcp | rg -q 'ui_schema 1'")) { f = f + 1; }
