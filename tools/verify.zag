    if (!run_suite("session-conflict", "rm -f /tmp/triton_session_conflict.zpa* && ../zag/zag-poc/znc probe/session_conflict_test.zag -o probe/session_conflict_test.new && mv -f probe/session_conflict_test.new probe/session_conflict_test && ./probe/session_conflict_test")) { f = f + 1; }
    if (!run_suite("optimizer-report", "rm -f probe/opt_report_test.new && ../zag/zag-poc/znc probe/opt_report_test.zag -o probe/opt_report_test.new && mv -f probe/opt_report_test.new probe/opt_report_test && ./probe/opt_report_test")) { f = f + 1; }
    if (!run_suite("timing", "rm -f probe/timing_test.new && ../zag/zag-poc/znc probe/timing_test.zag -o probe/timing_test.new && mv -f probe/timing_test.new probe/timing_test && ./probe/timing_test")) { f = f + 1; }
    if (!run_suite("limits", "rm -f probe/limits_test.new && ../zag/zag-poc/znc probe/limits_test.zag -o probe/limits_test.new && mv -f probe/limits_test.new probe/limits_test && TRITON_LIMITS_TEST=777 ./probe/limits_test")) { f = f + 1; }
    if (!run_suite("doc-perf-claim-audit", "! rg -n -i '[0-9]+ ?ms/frame|[0-9]+ ?fps|frame.?time.{0,20}[0-9]|[0-9]{4,} ?(components|comps|parts)' README.md docs")) { f = f + 1; }
    if (!run_suite("gpu-query", "rm -f probe/gpu_query_test.new && ../zag/zag-poc/znc probe/gpu_query_test.zag -o probe/gpu_query_test.new && mv -f probe/gpu_query_test.new probe/gpu_query_test && ./probe/gpu_query_test")) { f = f + 1; }
    if (!run_suite("probe-manifest-audit", "sh tools/probe_manifest_audit.sh")) { f = f + 1; }
    if (!run_suite("inventory-audit", "sh tools/inventory_audit.sh")) { f = f + 1; }
    return f;
}

fn main() i32 {
    let mode: []u8 = "safe";
    if (_zag_argc() > 1) { mode = _zag_arg(1); }
    let fails: i32 = 0;
    fails = gates_0(fails);
    fails = gates_1(fails);
    fails = gates_2(fails);
    fails = gates_3(fails);

    if (_zag_getenv("DISPLAY").len > 0) {
        if (!run_suite("x11-live", "./zagpa --x11-selftest")) { fails = fails + 1; }
        if (!run_suite("x11-captures", "./zagpa --x11-capture /tmp/triton_x11_1024.bmp --width 1024 --height 640 && ./zagpa --x11-capture /tmp/triton_x11_1440.bmp --width 1440 --height 900 && test -s /tmp/triton_x11_1024.bmp && test -s /tmp/triton_x11_1440.bmp")) { fails = fails + 1; }
    } else {
        json_result("x11-live", "not-run", 0);
        json_result("x11-captures", "not-run", 0);
        if (_zag_strcmp(mode, "release") == 1) { fails = fails + 1; }
    }

    if (_zag_strcmp(mode, "gpu-memory") == 1 || _zag_strcmp(mode, "gpu-dispatch") == 1) {
        if (!run_suite("gpu-memory", "rm -f probe/gpu_test.new && ../zag/zag-poc/znc probe/gpu_test.zag -o probe/gpu_test.new && mv -f probe/gpu_test.new probe/gpu_test && ./probe/gpu_test")) { fails = fails + 1; }
    } else {
        json_result("gpu-memory", "not-run", 0);
    }
    if (_zag_strcmp(mode, "gpu-dispatch") == 1) {
        if (!run_suite("gpu-submit", "rm -f probe/gpu_submit_test.new && ../zag/zag-poc/znc probe/gpu_submit_test.zag -o probe/gpu_submit_test.new && mv -f probe/gpu_submit_test.new probe/gpu_submit_test && ./probe/gpu_submit_test")) { fails = fails + 1; }
        if (!run_suite("gpu-compute", "rm -f probe/gpu_compute_test.new && ../zag/zag-poc/znc probe/gpu_compute_test.zag -o probe/gpu_compute_test.new && mv -f probe/gpu_compute_test.new probe/gpu_compute_test && ./probe/gpu_compute_test")) { fails = fails + 1; }
    } else {
        json_result("gpu-submit", "not-run", 0);
        json_result("gpu-compute", "not-run", 0);
    }

    if (fails == 0) { _zag_println("{\"summary\":\"pass\",\"failures\":0}"); return 0; }
    _zag_print("{\"summary\":\"fail\",\"failures\":");
    _zag_print(_zag_i64_to_str(fails as i64));
    _zag_println("}");
    return 1;
}
