// verify.zag — the single machine-readable Triton test entry point.
// This orchestrator is compiled and run by the supported self-hosted znc.

@import("../std/rt.zag")

fn json_result(name_: []u8, state: []u8, rc: i32) void {
    let a: []u8 = _zag_str_concat("{\"suite\":\"", name_);
    let b: []u8 = _zag_str_concat(a, "\",\"state\":\"");
    let c: []u8 = _zag_str_concat(b, state);
    let d: []u8 = _zag_str_concat(c, "\",\"exit_code\":");
    let e: []u8 = _zag_str_concat(d, _zag_i64_to_str(rc as i64));
    _zag_println(_zag_str_concat(e, "}"));
}

fn run_suite(name_: []u8, cmd: []u8) bool {
    _zag_print("== "); _zag_print(name_); _zag_println(" ==");
    let rc: i32 = _zag_exec_cmd(cmd);
    if (rc == 0) { json_result(name_, "pass", rc); return true; }
    json_result(name_, "fail", rc);
    return false;
}

fn gates_0(f: i32) i32 {
    if (!run_suite("build-production", "rm -f zagpa.new && ../zag/zag-poc/znc src/main.zag -o zagpa.new && mv -f zagpa.new zagpa")) { f = f + 1; }
    if (!run_suite("engine", "rm -f probe/engine_test.new && ../zag/zag-poc/znc probe/engine_test.zag -o probe/engine_test.new && mv -f probe/engine_test.new probe/engine_test && ./probe/engine_test")) { f = f + 1; }
    if (!run_suite("device-model-version", "rm -f /tmp/triton_model_gate.zpa* /tmp/triton_bad_model.zpa && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_model_gate.zpa ./zagpa --agent --once new >/dev/null && sed 's/^m 2 /m 99 /' /tmp/triton_model_gate.zpa > /tmp/triton_bad_model.zpa && base=$(cat /tmp/triton_model_gate.zpa.rev) && TRITON_CAPS=all TRITON_SESSION=/tmp/triton_model_gate.zpa ./zagpa --agent --once \"request bad-model $base open /tmp/triton_bad_model.zpa\" | rg -q 'E_MODEL_VERSION unsupported device model schema 99 supported 1..2'")) { f = f + 1; }
    if (!run_suite("x11-pixel-pack", "rm -f probe/x11_pixel_pack_test.new && ../zag/zag-poc/znc probe/x11_pixel_pack_test.zag -o probe/x11_pixel_pack_test.new && mv -f probe/x11_pixel_pack_test.new probe/x11_pixel_pack_test && ./probe/x11_pixel_pack_test")) { f = f + 1; }
    if (!run_suite("fb-bounds", "rm -f probe/fb_bounds_test.new && ../zag/zag-poc/znc probe/fb_bounds_test.zag -o probe/fb_bounds_test.new && mv -f probe/fb_bounds_test.new probe/fb_bounds_test && ./probe/fb_bounds_test")) { f = f + 1; }
    if (!run_suite("ui-preferences", "rm -f /tmp/triton_layout_test.cfg probe/ui_prefs_test.new && ../zag/zag-poc/znc probe/ui_prefs_test.zag -o probe/ui_prefs_test.new && mv -f probe/ui_prefs_test.new probe/ui_prefs_test && TRITON_LAYOUT=/tmp/triton_layout_test.cfg ./probe/ui_prefs_test")) { f = f + 1; }
    if (!run_suite("ui-tokens", "rm -f probe/ui_tokens_test.new && ../zag/zag-poc/znc probe/ui_tokens_test.zag -o probe/ui_tokens_test.new && mv -f probe/ui_tokens_test.new probe/ui_tokens_test && ./probe/ui_tokens_test")) { f = f + 1; }
    if (!run_suite("ui-accessibility", "rm -f probe/ui_accessibility_test.new && ../zag/zag-poc/znc probe/ui_accessibility_test.zag -o probe/ui_accessibility_test.new && mv -f probe/ui_accessibility_test.new probe/ui_accessibility_test && ./probe/ui_accessibility_test")) { f = f + 1; }
    if (!run_suite("ui-states", "rm -f probe/ui_states_test.new && ../zag/zag-poc/znc probe/ui_states_test.zag -o probe/ui_states_test.new && mv -f probe/ui_states_test.new probe/ui_states_test && ./probe/ui_states_test")) { f = f + 1; }
    if (!run_suite("simulation-properties", "rm -f probe/simulation_property_test.new && ../zag/zag-poc/znc probe/simulation_property_test.zag -o probe/simulation_property_test.new && mv -f probe/simulation_property_test.new probe/simulation_property_test && ./probe/simulation_property_test")) { f = f + 1; }
    if (!run_suite("optimizer", "rm -f probe/optimizer_test.new && ../zag/zag-poc/znc probe/optimizer_test.zag -o probe/optimizer_test.new && mv -f probe/optimizer_test.new probe/optimizer_test && ./probe/optimizer_test")) { f = f + 1; }
    if (!run_suite("optimizer-ui", "rm -f probe/opt_ui_test.new /tmp/triton_opt_audit.log && ../zag/zag-poc/znc probe/opt_ui_test.zag -o probe/opt_ui_test.new && mv -f probe/opt_ui_test.new probe/opt_ui_test && TRITON_AUDIT=/tmp/triton_opt_audit.log ./probe/opt_ui_test")) { f = f + 1; }
    if (!run_suite("palette", "rm -f probe/palette_test.new && ../zag/zag-poc/znc probe/palette_test.zag -o probe/palette_test.new && mv -f probe/palette_test.new probe/palette_test && ./probe/palette_test")) { f = f + 1; }
    if (!run_suite("shortcuts", "rm -f probe/shortcuts_test.new && ../zag/zag-poc/znc probe/shortcuts_test.zag -o probe/shortcuts_test.new && mv -f probe/shortcuts_test.new probe/shortcuts_test && ./probe/shortcuts_test")) { f = f + 1; }
    if (!run_suite("boxselect", "rm -f probe/boxselect_test.new && ../zag/zag-poc/znc probe/boxselect_test.zag -o probe/boxselect_test.new && mv -f probe/boxselect_test.new probe/boxselect_test && ./probe/boxselect_test")) { f = f + 1; }
