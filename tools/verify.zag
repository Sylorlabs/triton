    if (!run_suite("gpu-kernel-manifest", "rm -f probe/gpu_kernel_test.new && ../zag/zag-poc/znc probe/gpu_kernel_test.zag -o probe/gpu_kernel_test.new && mv -f probe/gpu_kernel_test.new probe/gpu_kernel_test && ./probe/gpu_kernel_test")) { f = f + 1; }
