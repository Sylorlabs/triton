// workspace.zag — panel rendering + per-frame orchestration.
// Menu bar, toolbar, outliner, signal debugger, viewport composition,
// status bar, and the modal dialogs (Open / Save As / Shortcuts).

@import("../std/list.zag") as list
@import("app.zag")
@import("sim_region.zag")
@import("demo.zag")
@import("capability.zag")

fn fmt_i(v: i64) []u8 {
    return _zag_i64_to_str(v);
}

// One-decimal float formatter for provenance/inspector readouts.
fn fmt_f1(v: f64) []u8 {
    let neg: bool = v < 0.0;
    let av: f64 = v;
    if (neg) { av = 0.0 - av; }
    let ip: i64 = av as i64;
    let dp: i64 = ((av - (ip as f64)) * 10.0 + 0.5) as i64;
    if (dp >= 10) { ip = ip + 1; dp = 0; }
    let s: []u8 = _zag_str_concat(_zag_str_concat(_zag_i64_to_str(ip), "."), _zag_i64_to_str(dp));
    if (neg) { s = _zag_str_concat("-", s); }
    return s;
}

// Draw a physical parameter's full provenance (value/units, class + uncertainty,
// source + date). Returns the next y. Unknown params render as such, never faked.
fn draw_provenance(f: *FB, x: i32, y: i32, label: []u8, p: PhysicalParam) i32 {
    if (!p.known) {
        draw_text(f, x, y, _zag_str_concat(label, " Unknown / Not characterized"), th_warning());
        return y + 14;
    }
    let v: []u8 = _zag_str_concat(_zag_str_concat(_zag_str_concat(label, " "), fmt_f1(p.value)),
                                  _zag_str_concat(" ", p.units));
    draw_text(f, x, y, v, th_text());
    let cls: []u8 = _zag_str_concat("[", _zag_str_concat(evidence_class_name(p.confidence), "]"));
    if (p.uncertainty > 0.0) {
        cls = _zag_str_concat(_zag_str_concat("±", _zag_str_concat(fmt_f1(p.uncertainty), " ")), cls);
    }
    draw_text(f, x, y + 12, cls, th_text_dim());
    let sd: []u8 = p.source;
    if (p.date_.len > 0) { sd = _zag_str_concat(_zag_str_concat(p.source, " · "), p.date_); }
    draw_text(f, x, y + 24, sd, th_text_dim());
    return y + 38;
}

// ── command dispatch (menus + shortcuts route here) ───────────────────────────
// 1 new / 2 open / 3 save / 4 save-as / 5 quit
// 10 undo / 11 redo / 12 duplicate / 13 delete / 14 deselect
// 20 frame-sel / 21 frame-all / 22 top / 23 front / 24 right / 25 perspective
// 30 shortcuts / 31 demo design / 32 canonical Flash reference PCU

fn app_action(a: *App, code: i32) void {
    a.*.menu = 0 - 1;
    if (code == 1) { app_new_design(a); }
    if (code == 2) { app_show_open(a); }
    if (code == 3) { app_save(a); }
    if (code == 4) { app_show_saveas(a); }
    if (code == 5) { a.*.quit = true; }
    if (code == 10) { app_undo(a); }
    if (code == 11) { app_redo(a); }
    if (code == 12) { app_duplicate(a); }
    if (code == 13) { app_delete_selection(a); }
    if (code == 14) { sel_clear(a); }
    if (code == 15) { app_copy(a); }
    if (code == 16) { app_paste(a); }
    if (code == 17) { app_group_selection(a); }
    if (code == 18) { app_ungroup_selection(a); }
    if (code == 19) { app_begin_rename(a, sel_primary(a)); }
    if (code == 20) { app_frame_selected(a); }
    if (code == 21) { app_frame_all(a); }
    if (code == 22) {
        a.*.cam.yaw = 0.0 - 1.5707963;
        a.*.cam.pitch = 1.51;
    }
    if (code == 23) {
        a.*.cam.yaw = 0.0 - 1.5707963;
        a.*.cam.pitch = 0.06;
    }
    if (code == 24) {
        a.*.cam.yaw = 0.0;
        a.*.cam.pitch = 0.06;
    }
    if (code == 25) {
        a.*.cam.yaw = 0.9;
        a.*.cam.pitch = 0.62;
    }
    if (code == 26) {
        a.*.cam.ortho = !a.*.cam.ortho;
        scene_mark_render(a.*.scene);   // projection change invalidates the tile cache
    }
    if (code == 27) { a.*.ui_scale = (a.*.ui_scale % 3) + 1; }   // cycle 1x/2x/3x
    if (code == 28) { app_reset_view(a); }
    if (code == 29) {
        a.*.sect_on = !a.*.sect_on;
        scene_mark_render(a.*.scene);
        if (a.*.sect_on) { app_log(a, "section view on ([ / ] adjust level)"); }
    }
    if (code == 30) { a.*.modal = modal_keys(); }
    if (code == 31) { app_action_demo(a); }
    if (code == 49) { a.*.model_open = true; }
    // This is deliberately a first-class visible command rather than an
    // undocumented file path: the canonical Flash PCU is the reproducible
    // reference design users can inspect, run, modify, save, and reopen.
    if (code == 32) { app_open_file(a, "examples/flash_photonic_massive.zpa"); }
    if (code == 34) { app_show_recovery(a); }
    if (code == 40) { a.*.tool = tool_select(); }
    if (code == 41) { a.*.tool = tool_route(); a.*.route_c = 0 - 1; }
    if (code == 42) { a.*.sim.*.playing = !a.*.sim.*.playing; }
    if (code == 43) { a.*.opt_open = true; a.*.settings_open = false; a.*.opt_previewed = false; a.*.opt_details = false; }
    if (code == 44) { a.*.settings_open = true; a.*.opt_open = false; }
    if (code == 45) { a.*.palette_open = true; a.*.palette_text.len = 0; a.*.palette_sel = 0; }
    if (code == 46) { a.*.tool = tool_measure(); a.*.measure_n = 0; }
    if (code == 47) { a.*.inp.reduced_motion = !a.*.inp.reduced_motion; }
    if (code == 48) { a.*.snap_obj = !a.*.snap_obj; }
    if (code == 49) { a.*.flash_open = true; a.*.settings_open = false; a.*.opt_open = false; }
    if (code >= 50 && code < 50 + kind_count()) { a.*.tool = tool_place_base() + (code - 50); }
    // jump to object (Section 3.6): palette codes 1000+idx select and frame
    if (code >= 1000 && code - 1000 < a.*.scene.*.comps.len) {
        sel_set(a, a.*.scene.*.comps.data[code - 1000].id);
        app_frame_selected(a);
    }
}

// Begin inline rename of `id` (F2, menu, context menu, outliner double-slow-click).
fn app_begin_rename(a: *App, id: i32) void {
    if (id < 0) { return; }
    let ci: i32 = scene_comp_index(a.*.scene, id);
    if (ci < 0) { return; }
    a.*.rename_id = id;
    textedit_set(&a.*.rename_edit, a.*.scene.*.comps.data[ci].name_);
    a.*.rename_edit.focus = true;
}

// ── command palette (Section 3.6) ─────────────────────────────────────────────
struct PCmd {
    label: []u8,
    hint: []u8,
    code: i32,
}

fn palette_commands(out: *list.ArrayList[PCmd]) void {
    out.*.len = 0;
    list.push[PCmd](out, PCmd{ .label = "New Project", .hint = "Ctrl+N", .code = 1 });
    list.push[PCmd](out, PCmd{ .label = "Open Project...", .hint = "Ctrl+O", .code = 2 });
    list.push[PCmd](out, PCmd{ .label = "Save", .hint = "Ctrl+S", .code = 3 });
    list.push[PCmd](out, PCmd{ .label = "Save As...", .hint = "Ctrl+Shift+S", .code = 4 });
    list.push[PCmd](out, PCmd{ .label = "Undo", .hint = "Ctrl+Z", .code = 10 });
    list.push[PCmd](out, PCmd{ .label = "Redo", .hint = "Ctrl+Y", .code = 11 });
    list.push[PCmd](out, PCmd{ .label = "Duplicate Selection", .hint = "Shift+D", .code = 12 });
    list.push[PCmd](out, PCmd{ .label = "Copy", .hint = "Ctrl+C", .code = 15 });
    list.push[PCmd](out, PCmd{ .label = "Paste", .hint = "Ctrl+V", .code = 16 });
    list.push[PCmd](out, PCmd{ .label = "Delete Selection", .hint = "X", .code = 13 });
    list.push[PCmd](out, PCmd{ .label = "Deselect All", .hint = "Esc", .code = 14 });
    list.push[PCmd](out, PCmd{ .label = "Frame Selected", .hint = "F", .code = 20 });
    list.push[PCmd](out, PCmd{ .label = "Frame All", .hint = "Home", .code = 21 });
    list.push[PCmd](out, PCmd{ .label = "View: Top", .hint = "", .code = 22 });
    list.push[PCmd](out, PCmd{ .label = "View: Front", .hint = "", .code = 23 });
    list.push[PCmd](out, PCmd{ .label = "View: Right", .hint = "", .code = 24 });
    list.push[PCmd](out, PCmd{ .label = "View: Perspective", .hint = "", .code = 25 });
    list.push[PCmd](out, PCmd{ .label = "View: Toggle Orthographic", .hint = "", .code = 26 });
    list.push[PCmd](out, PCmd{ .label = "View: Reset", .hint = "", .code = 28 });
    list.push[PCmd](out, PCmd{ .label = "View: Toggle Section View", .hint = "", .code = 29 });
    list.push[PCmd](out, PCmd{ .label = "Cycle HiDPI Scale", .hint = "", .code = 27 });
    list.push[PCmd](out, PCmd{ .label = "Tool: Select", .hint = "Q", .code = 40 });
    list.push[PCmd](out, PCmd{ .label = "Tool: Route Waveguide", .hint = "E", .code = 41 });
    list.push[PCmd](out, PCmd{ .label = "Tool: Measure", .hint = "M", .code = 46 });
    list.push[PCmd](out, PCmd{ .label = "Group Selection", .hint = "Ctrl+G", .code = 17 });
    list.push[PCmd](out, PCmd{ .label = "Ungroup Selection", .hint = "Ctrl+Shift+G", .code = 18 });
    list.push[PCmd](out, PCmd{ .label = "Rename Selection", .hint = "F2", .code = 19 });
    list.push[PCmd](out, PCmd{ .label = "Toggle Reduced Motion", .hint = "", .code = 47 });
    list.push[PCmd](out, PCmd{ .label = "Toggle Object Snapping", .hint = "", .code = 48 });
    list.push[PCmd](out, PCmd{ .label = "Toggle Simulation", .hint = "Space", .code = 42 });
    list.push[PCmd](out, PCmd{ .label = "Open Optimizer", .hint = "Alt+O", .code = 43 });
    list.push[PCmd](out, PCmd{ .label = "Open Settings", .hint = "Alt+S", .code = 44 });
    list.push[PCmd](out, PCmd{ .label = "Flash FIR Workspace", .hint = "", .code = 49 });
    let ki: i32 = 0;
    while (ki < kind_count()) {
        list.push[PCmd](out, PCmd{ .label = _zag_str_concat("Place: ", kind_name(kind_at(ki))),
                                   .hint = "", .code = 50 + ki });
        ki = ki + 1;
    }
    list.push[PCmd](out, PCmd{ .label = "Load Demo Design", .hint = "F1", .code = 31 });
    list.push[PCmd](out, PCmd{ .label = "Open Reference Flash PCU", .hint = "", .code = 32 });
    list.push[PCmd](out, PCmd{ .label = "Keyboard Shortcuts", .hint = "", .code = 30 });
}

fn ascii_lower(c: u8) u8 {
    if (c >= 65 && c <= 90) { return c + 32; }
    return c;
}

// Case-insensitive substring match; an empty query matches everything.
fn pcmd_match(label: []u8, q: []u8) bool {
    if (q.len == 0) { return true; }
    let i: i32 = 0;
    while (i + q.len <= label.len) {
        let ok: bool = true;
        let j: i32 = 0;
        while (j < q.len) {
            if (ascii_lower(label[i + j]) != ascii_lower(q[j])) { ok = false; }
            j = j + 1;
        }
        if (ok) { return true; }
        i = i + 1;
    }
    return false;
}

fn palette_filtered(a: *App, out: *list.ArrayList[PCmd]) void {
    let all: list.ArrayList[PCmd] = list.make[PCmd](40);
    palette_commands(&all);
    // jump to object (Section 3.6): one dynamic entry per placed part
    let jc: i32 = 0;
    while (jc < a.*.scene.*.comps.len) {
        list.push[PCmd](&all, PCmd{
            .label = _zag_str_concat("Go to: ", a.*.scene.*.comps.data[jc].name_),
            .hint = "", .code = 1000 + jc });
        jc = jc + 1;
    }
    out.*.len = 0;
    let q: []u8 = a.*.palette_text.data[0..a.*.palette_text.len];
    let i: i32 = 0;
    while (i < all.len) {
        if (pcmd_match(all.data[i].label, q)) { list.push[PCmd](out, all.data[i]); }
        i = i + 1;
    }
    list.free[PCmd](&all);
}

// Execute the highlighted command in the current filtered list.
fn app_palette_exec(a: *App) void {
    let filt: list.ArrayList[PCmd] = list.make[PCmd](40);
    palette_filtered(a, &filt);
    if (filt.len > 0) {
        let sel: i32 = a.*.palette_sel;
        if (sel < 0) { sel = 0; }
        if (sel >= filt.len) { sel = filt.len - 1; }
        let code: i32 = filt.data[sel].code;
        a.*.palette_open = false;
        app_action(a, code);
    }
    list.free[PCmd](&filt);
}

// Palette key handling (owns the keyboard while open).
fn app_palette_keys(a: *App) void {
    let inp: *Input = &a.*.inp;
    let i: i32 = 0;
    while (i < inp.*.keys.len) {
        let k: i32 = list.get[i32](inp.*.keys, i);
        if (k == key_esc()) { a.*.palette_open = false; return; }
        else if (k == key_enter()) { app_palette_exec(a); return; }
        else if (k == 17) { if (a.*.palette_sel > 0) { a.*.palette_sel = a.*.palette_sel - 1; } }
        else if (k == 18) { a.*.palette_sel = a.*.palette_sel + 1; }
        else if (k == key_backspace()) {
            if (a.*.palette_text.len > 0) { a.*.palette_text.len = a.*.palette_text.len - 1; }
            a.*.palette_sel = 0;
        } else if (k >= 32 && k < 127 && a.*.palette_text.len < 40) {
            list.push[u8](&a.*.palette_text, k as u8);
            a.*.palette_sel = 0;
        }
        i = i + 1;
    }
}

fn draw_palette(a: *App) void {
    if (!a.*.palette_open) { return; }
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let cap: i32 = inp.*.capture;
    inp.*.capture = 0;

    let pw: i32 = 440;
    let px: i32 = (a.*.inp.w - pw) / 2;
    if (px < 8) { px = 8; }
    let py: i32 = 84;

    let filt: list.ArrayList[PCmd] = list.make[PCmd](40);
    palette_filtered(a, &filt);
    if (a.*.palette_sel >= filt.len) { a.*.palette_sel = filt.len - 1; }
    if (a.*.palette_sel < 0) { a.*.palette_sel = 0; }
    let shown: i32 = filt.len;
    if (shown > 9) { shown = 9; }
    let row_h: i32 = 20;
    let ph: i32 = 30 + shown * row_h + 6;

    draw_shadow(f, px, py, pw, ph, radius_panel());
    fill_round_rect(f, px, py, pw, ph, radius_panel(), th_panel());
    round_rect_outline(f, px, py, pw, ph, radius_panel(), th_outline());
    // input row
    draw_text(f, px + 12, py + 9, ">", th_accent());
    if (a.*.palette_text.len > 0) {
        draw_text(f, px + 24, py + 9, a.*.palette_text.data[0..a.*.palette_text.len], th_text());
    } else {
        draw_text(f, px + 24, py + 9, "Type a command...", th_text_dim());
    }
    hline(f, px + 8, py + 27, pw - 16, th_outline_soft());

    let y: i32 = py + 30;
    let idx: i32 = 0;
    while (idx < shown) {
        let c: PCmd = filt.data[idx];
        let row: Rect = rect(px + 6, y, pw - 12, row_h);
        let hov: bool = rect_has(row, inp.*.mx, inp.*.my);
        let _eid: i64 = ui_register(inp, "menuitem", c.label, c.label, row, true,
                                    idx == a.*.palette_sel, false);
        if (idx == a.*.palette_sel || hov) { fill_round_rect(f, row.x, row.y, row.w, row.h, radius_control(), th_accent()); }
        draw_text(f, row.x + 8, y + 6, c.label, th_text());
        if (c.hint.len > 0) {
            draw_text(f, row.x + row.w - text_w(c.hint) - 8, y + 6, c.hint, th_text_dim());
        }
        if (hov && btn_released(inp, 0)) {
            a.*.palette_sel = idx;
            app_palette_exec(a);
        }
        y = y + row_h;
        idx = idx + 1;
    }
    list.free[PCmd](&filt);

    if (btn_pressed(inp, 0)) {
        let box: Rect = rect(px, py, pw, ph);
        if (!rect_has(box, inp.*.mx, inp.*.my)) { a.*.palette_open = false; }
    }
    inp.*.capture = cap;
}

// small demo design (also used by --smoke); placed through the normal APIs
fn app_action_demo(a: *App) void {
    demo_load(a);
    app_log(a, "demo design loaded");
}

// ── menu bar ──────────────────────────────────────────────────────────────────

struct MenuItem {
    label: []u8,
    hint: []u8,
    code: i32,     // 0 = separator
}

fn menu_title(m: i32) []u8 {
    if (m == 0) { return "File"; }
    if (m == 1) { return "Edit"; }
    if (m == 2) { return "View"; }
    return "Help";
}

fn menu_items(m: i32, out: *list.ArrayList[MenuItem]) void {
    out.*.len = 0;
    if (m == 0) {
        list.push[MenuItem](out, MenuItem{ .label = "New", .hint = "Ctrl+N", .code = 1 });
        list.push[MenuItem](out, MenuItem{ .label = "Open...", .hint = "Ctrl+O", .code = 2 });
        list.push[MenuItem](out, MenuItem{ .label = "", .hint = "", .code = 0 });
        list.push[MenuItem](out, MenuItem{ .label = "Save", .hint = "Ctrl+S", .code = 3 });
        list.push[MenuItem](out, MenuItem{ .label = "Save As...", .hint = "Ctrl+Shift+S", .code = 4 });
        list.push[MenuItem](out, MenuItem{ .label = "Recover Autosave...", .hint = "", .code = 34 });
        list.push[MenuItem](out, MenuItem{ .label = "", .hint = "", .code = 0 });
        list.push[MenuItem](out, MenuItem{ .label = "Quit", .hint = "Ctrl+Q", .code = 5 });
    }
    if (m == 1) {
        list.push[MenuItem](out, MenuItem{ .label = "Undo", .hint = "Ctrl+Z", .code = 10 });
        list.push[MenuItem](out, MenuItem{ .label = "Redo", .hint = "Ctrl+Y", .code = 11 });
        list.push[MenuItem](out, MenuItem{ .label = "", .hint = "", .code = 0 });
        list.push[MenuItem](out, MenuItem{ .label = "Duplicate", .hint = "Shift+D", .code = 12 });
        list.push[MenuItem](out, MenuItem{ .label = "Copy", .hint = "Ctrl+C", .code = 15 });
        list.push[MenuItem](out, MenuItem{ .label = "Paste", .hint = "Ctrl+V", .code = 16 });
        list.push[MenuItem](out, MenuItem{ .label = "Delete", .hint = "X", .code = 13 });
        list.push[MenuItem](out, MenuItem{ .label = "Deselect", .hint = "Esc", .code = 14 });
        list.push[MenuItem](out, MenuItem{ .label = "", .hint = "", .code = 0 });
        list.push[MenuItem](out, MenuItem{ .label = "Group", .hint = "Ctrl+G", .code = 17 });
        list.push[MenuItem](out, MenuItem{ .label = "Ungroup", .hint = "Ctrl+Shift+G", .code = 18 });
        list.push[MenuItem](out, MenuItem{ .label = "Rename", .hint = "F2", .code = 19 });
        list.push[MenuItem](out, MenuItem{ .label = "", .hint = "", .code = 0 });
        list.push[MenuItem](out, MenuItem{ .label = "Command Palette", .hint = "Ctrl+K", .code = 45 });
    }
    if (m == 2) {
        list.push[MenuItem](out, MenuItem{ .label = "Frame Selected", .hint = "F", .code = 20 });
        list.push[MenuItem](out, MenuItem{ .label = "Frame All", .hint = "Home", .code = 21 });
        list.push[MenuItem](out, MenuItem{ .label = "Reset View", .hint = "", .code = 28 });
        list.push[MenuItem](out, MenuItem{ .label = "", .hint = "", .code = 0 });
        list.push[MenuItem](out, MenuItem{ .label = "Top", .hint = "", .code = 22 });
        list.push[MenuItem](out, MenuItem{ .label = "Front", .hint = "", .code = 23 });
        list.push[MenuItem](out, MenuItem{ .label = "Right", .hint = "", .code = 24 });
        list.push[MenuItem](out, MenuItem{ .label = "Perspective", .hint = "", .code = 25 });
        list.push[MenuItem](out, MenuItem{ .label = "Toggle Orthographic", .hint = "", .code = 26 });
        list.push[MenuItem](out, MenuItem{ .label = "", .hint = "", .code = 0 });
        list.push[MenuItem](out, MenuItem{ .label = "Section View", .hint = "", .code = 29 });
        list.push[MenuItem](out, MenuItem{ .label = "Measure Tool", .hint = "M", .code = 46 });
        list.push[MenuItem](out, MenuItem{ .label = "Object Snapping", .hint = "", .code = 48 });
    }
    if (m == 3) {
        list.push[MenuItem](out, MenuItem{ .label = "Shortcuts", .hint = "", .code = 30 });
        list.push[MenuItem](out, MenuItem{ .label = "Load Demo Design", .hint = "F1", .code = 31 });
        list.push[MenuItem](out, MenuItem{ .label = "Physical Model & Provenance...", .hint = "", .code = 49 });
    }
}

fn draw_menubar(a: *App) void {
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let r: Rect = zone_menu(a);
    fill_rect(f, r.x, r.y, r.w, r.h, th_header());
    hline(f, r.x, r.y + r.h - 1, r.w, th_outline());

    let x: i32 = 6;
    let m: i32 = 0;
    while (m < 4) {
        let t: []u8 = menu_title(m);
        let bw: i32 = text_w(t) + 18;
        let br: Rect = rect(x, r.y + 3, bw, r.h - 5);
        let hov: bool = rect_has(br, inp.*.mx, inp.*.my);
        let _eid: i64 = ui_register(inp, "menubaritem", t, t, br,
                                    a.*.modal == modal_none(), a.*.menu == m, false);
        if (a.*.menu == m) {
            fill_round_rect(f, br.x, br.y, br.w, br.h, radius_control(), th_accent());
        } else if (hov && a.*.modal == modal_none()) {
            fill_round_rect(f, br.x, br.y, br.w, br.h, radius_control(), th_panel_alt());
        }
        draw_text(f, x + 9, r.y + 7, t, th_text());
        if (a.*.modal == modal_none()) {
            if (hov && btn_pressed(inp, 0)) {
                if (a.*.menu == m) { a.*.menu = 0 - 1; } else { a.*.menu = m; }
            } else if (hov && a.*.menu >= 0) {
                a.*.menu = m;   // slide between menus while one is open
            }
        }
        x = x + bw;
        m = m + 1;
    }

    // right side: Optimizer button (quiet, count-only badge) + Settings gear.
    let ob: Rect = zone_opt_btn(a);
    let oh: bool = rect_has(ob, inp.*.mx, inp.*.my) && a.*.modal == modal_none();
    let obr: Rect = rect(ob.x, ob.y + 3, ob.w, ob.h - 5);
    let _oeid: i64 = ui_register(inp, "button", "optimizer", "Optimizer", obr,
                                 a.*.modal == modal_none(), a.*.opt_open, false);
    if (a.*.opt_open) { fill_round_rect(f, obr.x, obr.y, obr.w, obr.h, radius_control(), th_accent()); }
    else if (oh) { fill_round_rect(f, obr.x, obr.y, obr.w, obr.h, radius_control(), th_panel_alt()); }
    draw_text(f, ob.x + 9, r.y + 7, "opt", th_text());
    if (opt_engine_badge(a.*.opt) > 0) {
        let bx: i32 = ob.x + 9 + text_w("opt ");
        let _bw: i32 = draw_int(f, bx, r.y + 7, opt_engine_badge(a.*.opt) as i64, th_accent_hot());
    }
    if (oh && btn_pressed(inp, 0)) {
        a.*.opt_open = !a.*.opt_open;
        a.*.settings_open = false;
        a.*.opt_previewed = false;
        a.*.opt_details = false;
    }

    let gr: Rect = zone_settings_gear(a);
    let gh: bool = rect_has(gr, inp.*.mx, inp.*.my) && a.*.modal == modal_none();
    let grr: Rect = rect(gr.x, gr.y + 3, gr.w, gr.h - 5);
    let _geid: i64 = ui_register(inp, "button", "settings", "Settings", grr,
                                 a.*.modal == modal_none(), a.*.settings_open, false);
    if (a.*.settings_open) { fill_round_rect(f, grr.x, grr.y, grr.w, grr.h, radius_control(), th_accent()); }
    else if (gh) { fill_round_rect(f, grr.x, grr.y, grr.w, grr.h, radius_control(), th_panel_alt()); }
    draw_gear(f, gr.x + gr.w / 2, gr.y + gr.h / 2, th_text());
    if (gh && btn_pressed(inp, 0)) {
        a.*.settings_open = !a.*.settings_open;
        a.*.opt_open = false;
    }

    // document name, left of the buttons
    let title: []u8 = a.*.file_;
    if (a.*.dirty) { title = _zag_str_concat(a.*.file_, " *"); }
    draw_text(f, ob.x - text_w(title) - 12, r.y + 7, title, th_text_dim());
}

// A small cog icon composed from framebuffer rects (no glyph font dependency).
fn draw_gear(f: *FB, cx: i32, cy: i32, c: i64) void {
    fill_rect(f, cx - 4, cy - 4, 9, 9, c);          // body
    fill_rect(f, cx - 1, cy - 6, 3, 2, c);          // N tooth
    fill_rect(f, cx - 1, cy + 5, 3, 2, c);          // S tooth
    fill_rect(f, cx - 6, cy - 1, 2, 3, c);          // W tooth
    fill_rect(f, cx + 5, cy - 1, 2, 3, c);          // E tooth
    fill_rect(f, cx - 5, cy - 5, 2, 2, c);          // NW
    fill_rect(f, cx + 4, cy - 5, 2, 2, c);          // NE
    fill_rect(f, cx - 5, cy + 4, 2, 2, c);          // SW
    fill_rect(f, cx + 4, cy + 4, 2, 2, c);          // SE
    fill_rect(f, cx - 1, cy - 1, 3, 3, th_panel()); // hub hole
}

// draw + interact with the open dropdown; called last so it overlays panels
fn draw_menu_dropdown(a: *App) void {
    if (a.*.menu < 0) { return; }
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;

    // anchor under the menu title
    let x0: i32 = 6;
    let m: i32 = 0;
    while (m < a.*.menu) {
        x0 = x0 + text_w(menu_title(m)) + 18;
        m = m + 1;
    }

    let items: list.ArrayList[MenuItem] = list.make[MenuItem](12);
    menu_items(a.*.menu, &items);
    let iw: i32 = 208;
    let ih: i32 = 21;
    let sep: i32 = 7;
    let total: i32 = 0;
    let i: i32 = 0;
    while (i < items.len) {
        if (items.data[i].code == 0) { total = total + sep; } else { total = total + ih; }
        i = i + 1;
    }
    let dr: Rect = rect(x0, menu_h(), iw, total + 8);
    draw_shadow(f, dr.x, dr.y, dr.w, dr.h, radius_panel());
    fill_round_rect(f, dr.x, dr.y, dr.w, dr.h, radius_panel(), th_panel());
    round_rect_outline(f, dr.x, dr.y, dr.w, dr.h, radius_panel(), th_outline());

    let y: i32 = dr.y + 4;
    let clicked_any: bool = false;
    i = 0;
    while (i < items.len) {
        let it: MenuItem = items.data[i];
        if (it.code == 0) {
            hline(f, dr.x + 8, y + 3, dr.w - 16, th_outline_soft());
            y = y + sep;
        } else {
            let row: Rect = rect(dr.x + 4, y, dr.w - 8, ih);
            let hov: bool = rect_has(row, inp.*.mx, inp.*.my);
            let _eid: i64 = ui_register(inp, "menuitem", it.label, it.label, row, true, false, false);
            if (hov) { fill_round_rect(f, row.x, row.y, row.w, row.h, radius_control(), th_accent()); }
            draw_text(f, row.x + 8, y + 6, it.label, th_text());
            if (it.hint.len > 0) {
                draw_text(f, row.x + row.w - text_w(it.hint) - 8, y + 6, it.hint, th_text_dim());
            }
            if (hov && btn_released(inp, 0)) {
                app_action(a, it.code);
                clicked_any = true;
            }
            y = y + ih;
        }
        i = i + 1;
    }
    // click outside (below the bar) closes
    if (!clicked_any && btn_pressed(inp, 0)) {
        if (!rect_has(dr, inp.*.mx, inp.*.my) && inp.*.my > menu_h()) {
            a.*.menu = 0 - 1;
        }
    }
    list.free[MenuItem](&items);
}

// ── status bar ────────────────────────────────────────────────────────────────

fn tool_name(a: *App) []u8 {
    if (a.*.moving) { return "move"; }
    if (a.*.tool == tool_route()) { return "route"; }
    if (a.*.tool >= tool_place_base()) {
        return _zag_str_concat("place ", kind_short(app_current_kind(a)));
    }
    return "select";
}

fn draw_statusbar(a: *App) void {
    let f: *FB = &a.*.f;
    let r: Rect = zone_status(a);
    fill_rect(f, r.x, r.y, r.w, r.h, th_header());
    hline(f, r.x, r.y, r.w, th_outline());
    let ty: i32 = r.y + 7;

    // left: document
    draw_text(f, 8, ty, a.*.file_, th_text());
    let doc_w: i32 = text_w(a.*.file_);
    if (a.*.dirty) {
        draw_text(f, 8 + doc_w, ty, " *", th_text());
        doc_w = doc_w + text_w(" *");
    }

    // cursor lattice cell (250 nm pitch)
    let x: i32 = 8 + doc_w + 24;
    if (a.*.hover_ok) {
        let col: i64 = th_accent_hot();
        draw_text(f, x, ty, "cell ", col);
        let cx: i32 = x + text_w("cell ");
        cx = cx + draw_int(f, cx, ty, a.*.hover_cell.x as i64, col);
        draw_text(f, cx, ty, ", ", col);
        cx = cx + text_w(", ");
        cx = cx + draw_int(f, cx, ty, a.*.hover_cell.y as i64, col);
        draw_text(f, cx, ty, ", ", col);
        cx = cx + text_w(", ");
        cx = cx + draw_int(f, cx, ty, a.*.hover_cell.z as i64, col);
        x = cx + 24;
    }

    // tool
    if (a.*.moving) {
        draw_text(f, x, ty, "move", th_text_dim());
        x = x + text_w("move") + 24;
    } else if (a.*.tool == tool_route()) {
        draw_text(f, x, ty, "route", th_text_dim());
        x = x + text_w("route") + 24;
    } else if (a.*.tool == tool_measure()) {
        draw_text(f, x, ty, "measure", th_text_dim());
        x = x + text_w("measure") + 24;
    } else if (a.*.tool >= tool_place_base()) {
        draw_text(f, x, ty, "place ", th_text_dim());
        let kx: i32 = x + text_w("place ");
        let ks: []u8 = kind_short(app_current_kind(a));
        draw_text(f, kx, ty, ks, th_text_dim());
        x = kx + text_w(ks) + 24;
    } else {
        draw_text(f, x, ty, "select", th_text_dim());
        x = x + text_w("select") + 24;
    }
    if (a.*.sel.len > 0) {
        x = x + draw_int(f, x, ty, a.*.sel.len as i64, th_text_dim());
        draw_text(f, x, ty, " selected", th_text_dim());
        x = x + text_w(" selected") + 24;
    }

    // camera + snap + section state (Section 3.2: a working status bar)
    let camm: []u8 = "persp";
    if (a.*.cam.ortho) { camm = "ortho"; }
    draw_text(f, x, ty, camm, th_text_dim());
    x = x + text_w(camm) + 16;
    if (a.*.snap_obj) {
        draw_text(f, x, ty, "snap", th_accent_hot());
        x = x + text_w("snap") + 16;
    }
    if (a.*.sect_on) {
        draw_text(f, x, ty, "section", th_warning());
        x = x + text_w("section") + 16;
    }

    // design warnings count: click to list them (Section 3.4)
    if (a.*.warn_ids.len > 0) {
        let wr: Rect = rect(x - 4, r.y + 2, text_w("00 warnings") + 8, r.h - 4);
        let whov: bool = rect_has(wr, a.*.inp.mx, a.*.inp.my);
        if (whov || a.*.warn_open) { fill_rect(f, wr.x, wr.y, wr.w, wr.h, th_header()); }
        let wtx: i32 = x;
        wtx = wtx + draw_int(f, wtx, ty, a.*.warn_ids.len as i64, th_warning());
        draw_text(f, wtx, ty, " warnings", th_warning());
        if (whov && btn_released(&a.*.inp, 0)) { a.*.warn_open = !a.*.warn_open; }
        x = x + text_w("00 warnings") + 16;
    } else { a.*.warn_open = false; }

    // Optimizer badge: quiet, count-only (Section 20.4). Nothing shows at zero.
    if (opt_engine_badge(a.*.opt) > 0) {
        let ocol: i64 = th_accent_hot();
        draw_text(f, x, ty, "opt ", ocol);
        x = x + text_w("opt ");
        x = x + draw_int(f, x, ty, opt_engine_badge(a.*.opt) as i64, ocol);
    }

    // right: counts + timing + sim state
    let run: []u8 = "paused";
    if (a.*.sim.*.playing) { run = "running"; }
    let rw: i32 = text_w(" parts  ") + text_w(" guides  ") + text_w(" ms  sim ") + text_w(run);
    rw = rw + text_w(fmt_i(a.*.scene.*.comps.len as i64));
    rw = rw + text_w(fmt_i(a.*.scene.*.guides.len as i64));
    rw = rw + text_w(fmt_i(a.*.frame_ms));
    let sx: i32 = r.w - rw - 8;
    let rx: i32 = sx;
    rx = rx + draw_int(f, rx, ty, a.*.scene.*.comps.len as i64, th_text_dim());
    draw_text(f, rx, ty, " parts  ", th_text_dim());
    rx = rx + text_w(" parts  ");
    rx = rx + draw_int(f, rx, ty, a.*.scene.*.guides.len as i64, th_text_dim());
    draw_text(f, rx, ty, " guides  ", th_text_dim());
    rx = rx + text_w(" guides  ");
    rx = rx + draw_int(f, rx, ty, a.*.frame_ms, th_text_dim());
    draw_text(f, rx, ty, " ms  sim ", th_text_dim());
    rx = rx + text_w(" ms  sim ");
    draw_text(f, rx, ty, run, th_text_dim());
}

// Clickable warning list (Section 3.4): every design warning selects and
// frames its component on click, so no warning is a dead end.
fn draw_warnings_popup(a: *App) void {
    if (!a.*.warn_open) { return; }
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let cap: i32 = inp.*.capture;
    inp.*.capture = 0;
    let n: i32 = a.*.warn_ids.len;
    if (n > 12) { n = 12; }
    let ph: i32 = n * 18 + 30;
    let pw: i32 = 300;
    let pr: Rect = rect(8, a.*.inp.h - status_h() - ph - 4, pw, ph);
    draw_shadow(f, pr.x, pr.y, pr.w, pr.h, radius_panel());
    fill_round_rect(f, pr.x, pr.y, pr.w, pr.h, radius_panel(), th_panel());
    round_rect_outline(f, pr.x, pr.y, pr.w, pr.h, radius_panel(), th_outline());
    draw_text(f, pr.x + pad_panel(), pr.y + 7, "DESIGN WARNINGS", th_warning());
    let y: i32 = pr.y + 24;
    let i: i32 = 0;
    while (i < n) {
        let id: i32 = list.get[i32](a.*.warn_ids, i);
        let code: i32 = list.get[i32](a.*.warn_codes, i);
        let row: Rect = rect(pr.x + 4, y, pr.w - 8, 17);
        let hov: bool = rect_has(row, inp.*.mx, inp.*.my);
        if (hov) { fill_round_rect(f, row.x, row.y, row.w, row.h, radius_control(), th_accent()); }
        let ci: i32 = scene_comp_index(a.*.scene, id);
        let nm: []u8 = "?";
        if (ci >= 0) { nm = a.*.scene.*.comps.data[ci].name_; }
        draw_text(f, row.x + 6, y + 4, nm, th_text());
        draw_text(f, row.x + 6 + text_w(nm) + 8, y + 4, warn_text(code), th_warning());
        if (hov && btn_released(inp, 0)) {
            sel_set(a, id);
            app_frame_selected(a);
            a.*.warn_open = false;
        }
        y = y + 18;
        i = i + 1;
    }
    if (btn_pressed(inp, 0) && !rect_has(pr, inp.*.mx, inp.*.my)) { a.*.warn_open = false; }
    inp.*.capture = cap;
}

// ── left: library + inspector ─────────────────────────────────────────────────

// Library category tabs (Section 3.7). A category is a lens, not a partition:
// a part may appear under several tabs.
fn library_tab_count() i32 { return 8; }

fn library_tab_name(t: i32) []u8 {
    if (t == 0) { return "All"; }
    if (t == 1) { return "Base"; }
    if (t == 2) { return "Emit"; }
    if (t == 3) { return "Sens"; }
    if (t == 4) { return "Chmb"; }
    if (t == 5) { return "Logic"; }
    if (t == 6) { return "Route"; }
    return "Debug";
}

fn library_tab_has(t: i32, ki: i32) bool {
    if (t == 0) { return true; }
    if (t == 1) { return ki == 0; }            // Base: GeSn plate
    if (t == 2) { return ki == 3; }            // Emitters
    if (t == 3) { return ki == 4; }            // Sensors
    if (t == 4) { return ki == 1 || ki == 2; } // Chambers + memory tiles
    if (t == 5) { return ki == 1; }            // Logic: interference chamber
    return false;                              // Route/Debug hold tool cards
}

// Beam compatibility line for a component card.
fn kind_compat(k: Kind) []u8 {
    if (k == Kind.Emitter) { return "C-band 1530-1565 nm"; }
    if (k == Kind.Chamber) { return "any WDM channel"; }
    if (k == Kind.Detector) { return "any channel"; }
    return "no beam port";
}

// Small pseudo-3D component icon: consistent style for every kind.
fn draw_kind_icon(f: *FB, x: i32, y: i32, k: Kind) void {
    let tint: i64 = kind_tint(k);
    // soft rounded chip: top face (lighter), front face (tint), side (darker)
    fill_round_rect(f, x + 3, y, 18, 6, 2, shade(tint, 320));
    fill_round_rect(f, x, y + 4, 18, 14, 3, tint);
    fill_rect(f, x + 16, y + 4, 3, 14, shade(tint, 150));
    round_rect_outline(f, x, y + 4, 18, 14, 3, shade(tint, 60));
    if (k == Kind.Emitter) { hline(f, x + 18, y + 10, 8, rgb(255, 220, 120)); }
    if (k == Kind.Detector) { fill_round_rect(f, x + 6, y + 8, 6, 6, 2, rgb(24, 25, 32)); }
}

// One component card: icon, name, description, port count, beam compatibility.
// Click arms the place tool; dragging the card into the viewport places with
// the live ghost (Section 3.7). Returns the next y.
fn draw_lib_card(a: *App, x: i32, y: i32, w: i32, ki: i32) i32 {
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let k: Kind = kind_at(ki);
    let card: Rect = rect(x, y, w, 46);
    let armed: bool = a.*.tool == tool_place_base() + ki || a.*.lib_drag == ki;
    let hov: bool = hover(inp, card);
    let _eid: i64 = ui_register(inp, "option", kind_name(k), kind_name(k), card, true, armed, false);
    let hot: i32 = input_hot(inp, ui_key(card), hov);
    let bgc: i64 = th_panel_alt();
    if (armed) { bgc = th_accent(); }
    else if (hot > 0) { bgc = mix(th_header(), th_panel_alt(), hot); }
    fill_round_rect(f, card.x, card.y, card.w, card.h, radius_panel(), bgc);
    let cbord: i64 = th_outline();
    if (armed) { cbord = th_accent_hot(); }
    round_rect_outline(f, card.x, card.y, card.w, card.h, radius_panel(), cbord);
    draw_kind_icon(f, card.x + pad_panel(), card.y + 12, k);
    let tx: i32 = card.x + 36;
    // Reserve the shortcut index before measuring copy. Every card line uses
    // the same safe text column, so descriptive copy never crosses the border
    // or collides with the index on narrow workspaces.
    let idx: []u8 = fmt_i((ki + 1) as i64);
    let tmax: i32 = card.x + card.w - tx - pad_panel() - text_w(idx) - 4;
    let tcol: i64 = th_text();
    if (armed) { tcol = rgb(240, 244, 250); }
    draw_text_max(f, tx, card.y + 5, kind_short(k), tcol, tmax);
    draw_text_max(f, tx, card.y + 18, kind_blurb(k), th_text_dim(), tmax);
    let ports: []u8 = _zag_str_concat(fmt_i(kind_port_count(k) as i64), " ports  ");
    draw_text_max(f, tx, card.y + 31, _zag_str_concat(ports, kind_compat(k)), th_text_dim(), tmax);
    draw_text(f, card.x + card.w - text_w(idx) - pad_text(), card.y + 5, idx, th_text_dim());
    ui_tip(inp, card, kind_name(k));
    if (hov && btn_pressed(inp, 0)) {
        a.*.tool = tool_place_base() + ki;
        a.*.lib_drag = ki;    // becomes a drag if the pointer leaves with LMB held
    }
    if (a.*.lib_drag == ki && !btn_down(inp, 0) && hov) {
        a.*.lib_drag = 0 - 1; // released in place: plain click, tool stays armed
    }
    return y + 50;
}

fn draw_toolbar(a: *App) void {
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let content: Rect = ui_panel(f, zone_left(a), "LIBRARY");
    fb_clip(f, content.x, content.y, content.x + content.w, content.y + content.h);
    let x: i32 = content.x + pad_panel();
    let w: i32 = content.w - pad_panel() * 2;
    let y: i32 = content.y + pad_panel();

    // tool row
    let third: i32 = (w - pad_text() * 2) / 3;
    if (ui_button(f, inp, rect(x, y, third, control_h()), "Select",
                  a.*.tool == tool_select() && !a.*.moving)) {
        a.*.tool = tool_select();
    }
    if (ui_button(f, inp, rect(x + third + pad_text(), y, third, control_h()), "Route",
                  a.*.tool == tool_route())) {
        a.*.tool = tool_route();
        a.*.route_c = 0 - 1;
    }
    if (ui_button(f, inp, rect(x + (third + pad_text()) * 2, y, third, control_h()), "Measure",
                  a.*.tool == tool_measure())) {
        a.*.tool = tool_measure();
        a.*.measure_n = 0;
    }
    ui_tip(inp, rect(x, y, third, control_h()), "Select and move parts (Q)");
    ui_tip(inp, rect(x + third + pad_text(), y, third, control_h()), "Route a waveguide between ports (E)");
    ui_tip(inp, rect(x + (third + pad_text()) * 2, y, third, control_h()), "Measure distance and angle (M)");
    y = y + control_h() + pad_text();

    // search bar (Section 3.7)
    let _sch: bool = ui_textfield(f, inp, rect(x, y, w, control_h()), &a.*.lib_search, "Search parts...");
    y = y + control_h() + pad_text();

    // category tabs: two rows of four
    let tw: i32 = (w - pad_text() * 3) / 4;
    let trow: i32 = 0;
    while (trow < 2) {
        let tcol_i: i32 = 0;
        while (tcol_i < 4) {
            let t: i32 = trow * 4 + tcol_i;
            let tr: Rect = rect(x + tcol_i * (tw + pad_text()), y + trow * (row_h() + 2), tw, row_h());
            let th_: bool = hover(inp, tr);
            let active: bool = a.*.lib_tab == t;
            let tn: []u8 = library_tab_name(t);
            let _eid: i64 = ui_register(inp, "tab", tn, tn, tr, true, active, false);
            let tbg: i64 = th_panel_alt();
            if (active) { tbg = th_accent(); }
            else if (th_) { tbg = th_header(); }
            fill_round_rect(f, tr.x, tr.y, tr.w, tr.h, radius_control(), tbg);
            if (active) { round_rect_outline(f, tr.x, tr.y, tr.w, tr.h, radius_control(), th_accent_hot()); }
            let tncol: i64 = th_text_dim();
            if (active) { tncol = rgb(245, 247, 252); }
            else if (th_) { tncol = th_text(); }
            let tnmax: i32 = tr.w - pad_text() * 2;
            let tnx: i32 = tr.x + (tr.w - imin(text_w(tn), tnmax)) / 2;
            draw_text_max(f, tnx, tr.y + 4, tn, tncol, tnmax);
            if (th_ && btn_released(inp, 0)) { a.*.lib_tab = t; }
            tcol_i = tcol_i + 1;
        }
        trow = trow + 1;
    }
    y = y + (row_h() + 2) * 2 + pad_text();

    // component cards, filtered by tab + search
    let q: []u8 = textedit_text(&a.*.lib_search);
    let shown: i32 = 0;
    let ki: i32 = 0;
    while (ki < kind_count()) {
        if (library_tab_has(a.*.lib_tab, ki)) {
            let k: Kind = kind_at(ki);
            if (pcmd_match(kind_name(k), q) || pcmd_match(kind_short(k), q)) {
                y = draw_lib_card(a, x, y, w, ki);
                shown = shown + 1;
            }
        }
        ki = ki + 1;
    }
    // tool cards for the Route / Debug categories
    if (a.*.lib_tab == 6 && pcmd_match("route waveguide", q)) {
        if (ui_button(f, inp, rect(x, y, w, control_h()), "Route Waveguide (E)", a.*.tool == tool_route())) {
            a.*.tool = tool_route();
            a.*.route_c = 0 - 1;
        }
        y = y + control_h() + pad_text();
        shown = shown + 1;
    }
    if (a.*.lib_tab == 7) {
        if (pcmd_match("measure", q)) {
            if (ui_button(f, inp, rect(x, y, w, control_h()), "Measure Tool (M)", a.*.tool == tool_measure())) {
                a.*.tool = tool_measure();
                a.*.measure_n = 0;
            }
            y = y + control_h() + pad_text();
            shown = shown + 1;
        }
        if (pcmd_match("demo design", q)) {
            if (ui_button(f, inp, rect(x, y, w, control_h()), "Load Demo Design", false)) {
                app_action_demo(a);
            }
            y = y + control_h() + pad_text();
            shown = shown + 1;
        }
        if (pcmd_match("reference flash pcu", q)) {
            if (ui_button(f, inp, rect(x, y, w, control_h()), "Open Reference Flash PCU", false)) {
                app_action(a, 32);
            }
            y = y + control_h() + pad_text();
            shown = shown + 1;
        }
        if (pcmd_match("flash fir workspace", q)) {
            if (ui_button(f, inp, rect(x, y, w, control_h()), "Flash FIR Workspace", false)) {
                app_action(a, 49);
            }
            y = y + control_h() + pad_text();
            shown = shown + 1;
        }
    }
    if (shown == 0) {
        // clean empty state instead of a dead area (Section 3.2)
        ui_empty_state(f, rect(content.x, y, content.w, 84), "no parts match", "clear the search or switch tabs");
        y = y + 88;
    }
    y = y + pad_text();

    // ── inspector (Section 3.8) ──
    hline(f, content.x, y, content.w, th_outline());
    y = y + pad_text() + 2;
    draw_text(f, x, y, "INSPECTOR", th_text_dim());
    y = y + row_h();

    let pid: i32 = sel_primary(a);
    if (pid >= 0) {
        let ci: i32 = scene_comp_index(a.*.scene, pid);
        if (ci >= 0) { y = draw_inspector_comp(a, content, x, y, w, ci); }
    } else if (a.*.sel_guide >= 0) {
        let gi: i32 = scene_guide_index(a.*.scene, a.*.sel_guide);
        if (gi >= 0) { y = draw_inspector_guide(a, x, y, w, gi); }
    } else {
        ui_empty_state(f, rect(content.x, y, content.w, imax(90, content.y + content.h - y - 4)),
                       "nothing selected", "click a part; shift+click adds");
    }
    fb_clip_reset(f);
}

// One labeled numeric row: label left, stepped field right. Returns +1/-1 on a
// step click, 2 when a typed value was committed (in out_val), 0 otherwise.
// Clicking the value opens precise typing through a.insp_edit (Section 3.8).
fn insp_field(a: *App, x: i32, y: i32, w: i32, label: []u8, val: []u8, unit: []u8,
              fid: i32, out_val: *i64) i32 {
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    draw_text(f, x, y + 6, label, th_text_dim());
    let fw: i32 = w - 58;
    if (fw < 76) { fw = 76; }
    let fr: Rect = rect(x + w - fw, y, fw, control_h());
    if (a.*.insp_edit_field == fid) {
        let _ch: bool = ui_textfield(f, inp, fr, &a.*.insp_edit, "");
        if (a.*.insp_edit.committed) {
            a.*.insp_edit_field = 0 - 1;
            out_val.* = _zag_str_to_i64(textedit_text(&a.*.insp_edit));
            return 2;
        }
        if (!a.*.insp_edit.focus) { a.*.insp_edit_field = 0 - 1; }
        return 0;
    }
    let step: i32 = ui_numfield(f, inp, fr, val, unit, ui_key(fr) + (fid as i64) * 31337);
    if (step != 0) { return step; }
    // click the value area (between the steppers) to type an exact number
    let mid: Rect = rect(fr.x + 14, fr.y, fr.w - 28, fr.h);
    if (hover(inp, mid) && btn_released(inp, 0)) {
        a.*.insp_edit_field = fid;
        textedit_set(&a.*.insp_edit, val);
        a.*.insp_edit.focus = true;
    }
    return 0;
}

// Apply a single-axis move to the primary selection through the journaled path.
fn insp_apply_move(a: *App, id: i32, d: Vox) void {
    if (d.x == 0 && d.y == 0 && d.z == 0) { return; }
    if (app_is_locked(a, id)) {
        a.*.insp_err = "part is locked";
        a.*.insp_err_frame = a.*.frame;
        return;
    }
    let one: list.ArrayList[i32] = list.make[i32](1);
    list.push[i32](&one, id);
    if (group_can_move(a.*.scene, &one, d) == 0) {
        op_move(&a.*.jrn, a.*.scene, id, d);
        group_move(a.*.scene, &one, d);
        app_mark_dirty(a);
        a.*.insp_err = "";
        input_flash(&a.*.inp, 424242 + (id as i64));
    } else {
        a.*.insp_err = "blocked: destination fails placement rules";
        a.*.insp_err_frame = a.*.frame;
        a.*.invalid_frame = a.*.frame;
    }
    list.free[i32](&one);
}

fn draw_inspector_comp(a: *App, content: Rect, x: i32, y0: i32, w: i32, ci: i32) i32 {
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let y: i32 = y0;
    let c: Comp = a.*.scene.*.comps.data[ci];
    let id: i32 = c.id;

    // identity: name (select color), kind, lock state — full size, never tiny
    draw_text(f, x, y, c.name_, th_select());
    if (app_is_locked(a, id)) {
        draw_text(f, x + text_w(c.name_) + pad_panel(), y, "locked", th_warning());
    }
    y = y + row_h();
    draw_text(f, x, y, kind_name(c.kind), th_text());
    y = y + row_h();

    // inline validation error (Section 3.8), clears after ~3 s
    if (a.*.insp_err.len > 0 && a.*.frame - a.*.insp_err_frame < 180) {
        draw_text(f, x, y, a.*.insp_err, th_danger());
        y = y + row_h();
    }
    // component warning from the design-warning pass (Section 3.4)
    let wcode: i32 = app_comp_warning(a, id);
    if (wcode != 0) {
        draw_text(f, x, y, warn_text(wcode), th_warning());
        y = y + row_h();
    }

    // ── transform (numeric fields with steppers, typing, units) ──
    if (ui_section(f, inp, x, y, w, "Transform", &a.*.insp_open_t, 0 - 1)) {
        y = y + row_h() + 2;
        let tv: i64 = 0;
        let sx: i32 = insp_field(a, x, y, w, "cell x", fmt_i(c.origin.x as i64), "cell", 0, &tv);
        if (sx == 1 || sx == 0 - 1) { insp_apply_move(a, id, vox(sx, 0, 0)); }
        if (sx == 2) { insp_apply_move(a, id, vox((tv as i32) - c.origin.x, 0, 0)); }
        y = y + control_h() + 2;
        let sy: i32 = insp_field(a, x, y, w, "cell y", fmt_i(c.origin.y as i64), "cell", 1, &tv);
        if (sy == 1 || sy == 0 - 1) { insp_apply_move(a, id, vox(0, sy, 0)); }
        if (sy == 2) { insp_apply_move(a, id, vox(0, (tv as i32) - c.origin.y, 0)); }
        y = y + control_h() + 2;
        let sz: i32 = insp_field(a, x, y, w, "cell z", fmt_i(c.origin.z as i64), "cell", 2, &tv);
        if (sz == 1 || sz == 0 - 1) { insp_apply_move(a, id, vox(0, 0, sz)); }
        if (sz == 2) { insp_apply_move(a, id, vox(0, 0, (tv as i32) - c.origin.z)); }
        y = y + control_h() + 2;
        let sr: i32 = insp_field(a, x, y, w, "rot", fmt_i((c.rot * 90) as i64), "deg", 3, &tv);
        if (sr != 0) {
            let newrot: i32 = (c.rot + 1) % 4;
            if (sr == 0 - 1) { newrot = (c.rot + 3) % 4; }
            if (sr == 2) {
                let q: i64 = (tv / 90) % 4;
                if (q < 0) { q = q + 4; }
                newrot = q as i32;
            }
            if (app_is_locked(a, id)) {
                a.*.insp_err = "part is locked";
                a.*.insp_err_frame = a.*.frame;
            } else {
                let rv: i32 = op_rotate(&a.*.jrn, a.*.scene, id, newrot);
                if (rv == 0) { app_mark_dirty(a); a.*.insp_err = ""; }
                else {
                    a.*.insp_err = _zag_str_concat("cannot rotate: ", place_err_text(rv));
                    a.*.insp_err_frame = a.*.frame;
                }
            }
        }
        y = y + control_h() + 2;
        // exact dimensions; resizable kinds get live width/depth fields
        if (kind_resizable(c.kind)) {
            let sw: i32 = insp_field(a, x, y, w, "size w", fmt_i(c.size.x as i64), "vox", 4, &tv);
            if (sw != 0) {
                let ns: Vox = c.size;
                if (sw == 2) { ns.x = tv as i32; } else { ns.x = ns.x + sw; }
                let rv2: i32 = op_resize(&a.*.jrn, a.*.scene, id, clamp_size(c.kind, ns));
                if (rv2 == 0) { app_mark_dirty(a); a.*.insp_err = ""; }
                else {
                    a.*.insp_err = _zag_str_concat("cannot resize: ", place_err_text(rv2));
                    a.*.insp_err_frame = a.*.frame;
                }
            }
            y = y + control_h() + 2;
            let sd: i32 = insp_field(a, x, y, w, "size d", fmt_i(c.size.z as i64), "vox", 6, &tv);
            if (sd != 0) {
                let ns2: Vox = c.size;
                if (sd == 2) { ns2.z = tv as i32; } else { ns2.z = ns2.z + sd; }
                let rv3: i32 = op_resize(&a.*.jrn, a.*.scene, id, clamp_size(c.kind, ns2));
                if (rv3 == 0) { app_mark_dirty(a); a.*.insp_err = ""; }
                else {
                    a.*.insp_err = _zag_str_concat("cannot resize: ", place_err_text(rv3));
                    a.*.insp_err_frame = a.*.frame;
                }
            }
            y = y + control_h() + 2;
        } else {
            let ext: Vox = comp_ext(c);
            let dim: []u8 = _zag_str_concat("size ", fmt_i(ext.x as i64));
            dim = _zag_str_concat(_zag_str_concat(dim, "x"), fmt_i(ext.y as i64));
            dim = _zag_str_concat(_zag_str_concat(dim, "x"), fmt_i(ext.z as i64));
            draw_text(f, x, y + 3, _zag_str_concat(dim, " vox"), th_text_dim());
            y = y + row_h();
        }
    } else { y = y + row_h() + 2; }

    // ── engine state: beam output, port states, simulation status ──
    if (ui_section(f, inp, x, y, w, "Engine", &a.*.insp_open_e, 0 - 1)) {
        y = y + row_h() + 2;
        if (c.kind == Kind.Emitter || c.kind == Kind.Chamber || c.kind == Kind.Detector) {
            let ot: i32 = sim_history(a.*.sim, id, 0);
            draw_text(f, x, y + 2, "output", th_text_dim());
            fill_rect(f, x + 46, y, 12, 12, trit_color(ot));
            rect_outline(f, x + 46, y, 12, 12, trit_rim(ot));
            draw_text(f, x + 64, y + 2, trit_glyph(ot), th_text());
            y = y + row_h() + 2;
        }
        // port states (Section 3.8): direction, connection, live carrier trit
        let np: i32 = kind_port_count(c.kind);
        if (np > 0 && ui_section(f, inp, x, y, w, "Ports", &a.*.insp_open_p, np)) {
            y = y + row_h() + 2;
            let pi2: i32 = 0;
            while (pi2 < np) {
                let p: Port = kind_port(c.kind, pi2);
                let dirs: []u8 = "in ";
                if (p.is_output) { dirs = "out"; }
                draw_text(f, x + pad_text(), y + 2, p.label, th_text());
                draw_text(f, x + 46, y + 2, dirs, th_text_dim());
                // find the guide attached to this port for its live trit
                let gt: i32 = signal_unknown();
                let attached: bool = false;
                let gg: i32 = 0;
                while (gg < a.*.scene.*.guides.len) {
                    let g2: Guide = a.*.scene.*.guides.data[gg];
                    if ((g2.from_c == id && g2.from_p == pi2) || (g2.to_c == id && g2.to_p == pi2)) {
                        gt = g2.live;
                        attached = true;
                    }
                    gg = gg + 1;
                }
                if (attached) {
                    fill_rect(f, x + 72, y + 1, 10, 10, trit_color(gt));
                    rect_outline(f, x + 72, y + 1, 10, 10, trit_rim(gt));
                    draw_text(f, x + 88, y + 2, trit_glyph(gt), th_text());
                } else {
                    draw_text(f, x + 72, y + 2, "open", th_warning());
                }
                y = y + row_h();
                pi2 = pi2 + 1;
            }
        } else if (np > 0) { y = y + row_h() + 2; }
        // simulation status (Section 3.8): mode, run state, model completeness
        let sst: []u8 = "Functional (symbolic)";
        if (a.*.sim.*.mode == SimMode.Physical) { sst = "Physical"; }
        let run2: []u8 = "  paused";
        if (a.*.sim.*.playing) { run2 = "  running"; }
        draw_text(f, x, y + 2, _zag_str_concat(_zag_str_concat("sim ", sst), run2), th_text_dim());
        y = y + row_h();
        if (a.*.sim.*.mode == SimMode.Physical && !model_complete(a.*.scene.*.model)) {
            draw_text(f, x, y + 2, "model incomplete: unverified", th_warning());
            y = y + row_h();
        }
        if (c.kind == Kind.Chamber) {
            let soh: []u8 = _zag_str_concat("memory tiles ", fmt_i(scene_soh_adjacent(a.*.scene, id) as i64));
            draw_text(f, x, y + 2, soh, th_text());
            y = y + row_h();
        }
    } else { y = y + row_h() + 2; }

    // ── model provenance + emitter physics fields ──
    if (ui_section(f, inp, x, y, w, "Model", &a.*.insp_open_m, 0 - 1)) {
        y = y + row_h() + 2;
        y = draw_provenance(f, x, y, "model", kind_model_param(a.*.scene.*.model, c.kind));
        if (c.kind == Kind.Emitter) {
            let tv2: i64 = 0;
            let swl: i32 = insp_field(a, x, y, w, "wl", fmt_i(c.wl_nm as i64), "nm", 7, &tv2);
            if (swl != 0) {
                let nwl: i32 = (c.wl_nm as i32) + swl;
                if (swl == 2) { nwl = tv2 as i32; }
                if (nwl < 1530) { nwl = 1530; }
                if (nwl > 1565) { nwl = 1565; }
                op_set_prop(&a.*.jrn, a.*.scene, id, prop_wl(), nwl);
                app_mark_dirty(a);
            }
            fill_rect(f, x + w - 24, y - row_h() + 2, 20, 9, wavelength_color(c.wl_nm));
            y = y + control_h() + 2;
            draw_text(f, x, y, "pattern (T to cycle):", th_text_dim());
            y = y + 13;
            let pat: []u8 = preset_pattern(c.preset);
            let pi3: i32 = 0;
            while (pi3 < pat.len) {
                let t2: i32 = 0;
                if ((pat[pi3] as i32) == '+') { t2 = 1; }
                if ((pat[pi3] as i32) == '-') { t2 = 0 - 1; }
                fill_rect(f, x + pi3 * 11, y, 9, 9, trit_color(t2));
                rect_outline(f, x + pi3 * 11, y, 9, 9, trit_rim(t2));
                pi3 = pi3 + 1;
            }
            y = y + row_h();
        }
    } else { y = y + row_h() + 2; }

    y = y + pad_text();
    // never place live controls beyond the visible panel (they would collide
    // with the panel underneath in hit-testing)
    if (y + control_h() <= content.y + content.h - pad_text()) {
        let half2: i32 = (w - pad_text()) / 2;
        if (ui_button(f, inp, rect(x, y, half2, control_h()), "Move (G)", a.*.moving)) {
            app_start_move(a);
        }
        if (ui_button(f, inp, rect(x + half2 + pad_text(), y, half2, control_h()), "Delete (X)", false)) {
            app_delete_selection(a);
        }
    }
    return y + control_h() + pad_text();
}

fn draw_inspector_guide(a: *App, x: i32, y0: i32, w: i32, gi: i32) i32 {
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let y: i32 = y0;
    let g: Guide = a.*.scene.*.guides.data[gi];
    draw_text(f, x, y, "Waveguide", th_select());
    y = y + row_h();
    // connection kind is stated explicitly (Section 3.4): this is a physically
    // routed lattice path, simulated by the engine
    draw_text(f, x, y, "physical: routed lattice path", th_text());
    y = y + row_h();
    if (a.*.sim.*.mode == SimMode.Physical && !model_complete(a.*.scene.*.model)) {
        draw_text(f, x, y, "unverified: model incomplete", th_warning());
    } else {
        draw_text(f, x, y, "simulated: deterministic engine", th_text_dim());
    }
    y = y + row_h();
    let ln: []u8 = _zag_str_concat("length ", fmt_i(g.length_nm as i64));
    draw_text(f, x, y, _zag_str_concat(ln, " nm"), th_text());
    y = y + row_h();
    let fs: []u8 = _zag_str_concat("delay ", fmt_i(guide_delay_fs_for(a.*.scene, g.length_nm) as i64));
    fs = _zag_str_concat(fs, " fs / ");
    fs = _zag_str_concat(fs,
        fmt_i(guide_delay_symbols_for_model(a.*.scene, a.*.sim.*.clock_ghz, g.length_nm) as i64));
    fs = _zag_str_concat(fs, " symbols");
    draw_text(f, x, y, fs, th_text_dim());
    y = y + row_h();
    draw_text(f, x, y + 2, "state", th_text_dim());
    fill_rect(f, x + 38, y, 12, 12, trit_color(g.live));
    rect_outline(f, x + 38, y, 12, 12, trit_rim(g.live));
    draw_text(f, x + 56, y + 2, trit_glyph(g.live), th_text());
    y = y + row_h() + 2;
    y = draw_provenance(f, x, y, "n_g", a.*.scene.*.model.group_index);
    if (ui_button(f, inp, rect(x, y, w, control_h()), "Delete (X)", false)) {
        app_delete_selection(a);
    }
    return y + control_h() + pad_text();
}

// ── right: outliner ───────────────────────────────────────────────────────────

fn outliner_group_row(a: *App, x: i32, y: i32, w: i32, gi: i32, label: []u8, count: i32) bool {
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let r: Rect = rect(x, y, w, 16);
    let hov: bool = hover(inp, r);
    let open: bool = list.get[i32](a.*.expand, gi) == 1;
    let _eid: i64 = ui_register(inp, "disclosure", label, label, r, true, open, false);
    if (hov) { fill_round_rect(f, r.x, r.y, r.w, r.h, radius_control(), th_header()); }
    let arrow: []u8 = ">";
    if (open) { arrow = "v"; }
    draw_text(f, x + 4, y + 4, arrow, th_text_dim());
    let cnt: []u8 = fmt_i(count as i64);
    let label_max: i32 = w - 16 - text_w(cnt) - 12;
    draw_text_max(f, x + 16, y + 4, label, th_text(), label_max);
    draw_text(f, x + w - text_w(cnt) - 6, y + 4, cnt, th_text_dim());
    if (hov && btn_released(inp, 0)) {
        let nv: i32 = 1;
        if (open) { nv = 0; }
        list.set[i32](&a.*.expand, gi, nv);
    }
    return open;
}

// One outliner component row (Section 3.9): type icon, name (inline-renamable),
// warning badge, live-signal badge, lock and visibility toggles. Handles click
// select, shift multi-select, double-click frame, right-click menu, and
// drag-onto-row grouping. Returns true when the row consumed the pointer.
fn outliner_comp_row(a: *App, row: Rect, j: i32) void {
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let c: Comp = a.*.scene.*.comps.data[j];
    let k: Kind = c.kind;
    let selr: bool = sel_has(a, c.id);
    let hov: bool = hover(inp, row);
    let _eid: i64 = ui_register(inp, "treeitem", fmt_i(c.id as i64), c.name_,
                                row, true, selr, false);
    if (selr) { fill_round_rect(f, row.x, row.y, row.w, row.h, radius_control(), th_accent()); }
    else if (hov) { fill_round_rect(f, row.x, row.y, row.w, row.h, radius_control(), th_header()); }

    // icon by object type
    fill_rect(f, row.x + 3, row.y + 4, 7, 7, kind_tint(k));
    rect_outline(f, row.x + 3, row.y + 4, 7, 7, th_outline());

    // inline rename (Section 3.6): the row becomes a text field
    if (a.*.rename_id == c.id) {
        let fr: Rect = rect(row.x + 14, row.y, row.w - 52, row.h);
        let _ch2: bool = ui_textfield(f, inp, fr, &a.*.rename_edit, "");
        if (a.*.rename_edit.committed) {
            op_rename(&a.*.jrn, a.*.scene, c.id, textedit_text(&a.*.rename_edit));
            app_mark_dirty(a);
            a.*.rename_id = 0 - 1;
        } else if (!a.*.rename_edit.focus) {
            a.*.rename_id = 0 - 1;   // Esc or click-away cancels
        }
        return;
    }

    let tcol: i64 = th_text();
    if (!c.visible) { tcol = th_text_dim(); }
    let nmax: i32 = row.w - 15 - 60;
    draw_text_max(f, row.x + 15, row.y + 3, c.name_, tcol, nmax);
    let bx: i32 = row.x + 15 + imin(text_w(c.name_), nmax) + 5;

    // group marker
    if (app_group_of(a, c.id) >= 0) {
        draw_text(f, bx, row.y + 3, "g", th_accent_hot());
        bx = bx + 8;
    }
    // warning badge (clickable meaning: selecting the row selects the part)
    if (app_comp_warning(a, c.id) != 0) {
        draw_text(f, bx, row.y + 3, "!", th_warning());
        bx = bx + 8;
    }
    // live signal badge for active parts
    if (k == Kind.Emitter || k == Kind.Chamber || k == Kind.Detector) {
        let lt: i32 = sim_history(a.*.sim, c.id, 0);
        fill_rect(f, bx, row.y + 4, 7, 7, trit_color(lt));
        rect_outline(f, bx, row.y + 4, 7, 7, trit_rim(lt));
    }

    // right side: lock toggle then visibility toggle
    let lk: []u8 = "-";
    let lcol: i64 = th_disabled();
    if (app_is_locked(a, c.id)) { lk = "#"; lcol = th_warning(); }
    if (ui_mini(f, inp, rect(row.x + row.w - 32, row.y, 14, row.h), lk, lcol)) {
        app_toggle_lock(a, c.id);
        return;
    }
    let eye: []u8 = "o";
    if (!c.visible) { eye = "-"; }
    if (ui_mini(f, inp, rect(row.x + row.w - 16, row.y, 14, row.h), eye, th_text_dim())) {
        a.*.scene.*.comps.data[j].visible = !c.visible;
        scene_mark_render(a.*.scene);
        return;
    }

    if (hov && inp.*.mx < row.x + row.w - 34) {
        // right-click context menu on the row
        if (btn_released(inp, 2)) {
            if (!sel_has(a, c.id)) { sel_set(a, c.id); }
            a.*.ctx_open = true;
            a.*.ctx_comp = c.id;
            a.*.ctx_x = inp.*.mx;
            a.*.ctx_y = inp.*.my;
            return;
        }
        if (btn_pressed(inp, 0)) {
            a.*.out_drag_id = c.id;   // may become a drag-to-group
            let dbl: bool = app_dblclick(a);
            if (shift_down(inp)) { sel_toggle(a, c.id); }
            else {
                sel_set(a, c.id);
                let gid: i32 = app_group_of(a, c.id);
                if (gid >= 0) { sel_add_group(a, gid); }
            }
            if (dbl) { app_frame_selected(a); }   // double-click frames
        }
        // drop of a dragged row onto this row: group the two (Section 3.9)
        if (btn_released(inp, 0) && a.*.out_drag_id >= 0 && a.*.out_drag_id != c.id) {
            let dragged: i32 = a.*.out_drag_id;
            let tgid: i32 = app_group_of(a, c.id);
            if (tgid < 0) {
                tgid = a.*.group_next;
                a.*.group_next = a.*.group_next + 1;
                list.push[i32](&a.*.groups, c.id);
                list.push[i32](&a.*.groups, tgid);
            }
            app_group_drop(a, dragged);
            list.push[i32](&a.*.groups, dragged);
            list.push[i32](&a.*.groups, tgid);
            app_log(a, "grouped by drag");
            a.*.out_drag_id = 0 - 1;
        }
    }
}

fn draw_outliner(a: *App) void {
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let panel_r: Rect = zone_right(a);
    let content: Rect = ui_panel(f, panel_r, "OUTLINER");
    fb_clip(f, content.x, content.y, content.x + content.w, content.y + content.h);

    if (hover(inp, content) && inp.*.wheel != 0) {
        a.*.out_scroll = a.*.out_scroll - inp.*.wheel * 32;
        if (a.*.out_scroll < 0) { a.*.out_scroll = 0; }
    }

    let x: i32 = content.x + pad_text();
    let w: i32 = content.w - pad_text() * 2;

    // search/filter (Section 3.9) — pinned above the scrolling tree
    let _os: bool = ui_textfield(f, inp, rect(x, content.y + pad_text(), w, control_h()),
                                 &a.*.out_search, "Filter objects...");
    let list_top: i32 = content.y + pad_text() + control_h() + pad_text();
    fb_clip(f, content.x, list_top, content.x + content.w, content.y + content.h);
    let y: i32 = list_top - a.*.out_scroll;
    let q: []u8 = textedit_text(&a.*.out_search);

    // empty state: a fresh design has nothing to navigate yet
    if (a.*.scene.*.comps.len == 0 && a.*.scene.*.guides.len == 0) {
        fb_clip_reset(f);
        ui_empty_state(f, rect(content.x, list_top, content.w, content.h - (list_top - content.y)),
                       "empty design", "place parts from the Library");
        return;
    }

    // per-kind counts in ONE pass over the scene (was one pass per group)
    let counts: list.ArrayList[i32] = list.make[i32](kind_count());
    let ki0: i32 = 0;
    while (ki0 < kind_count()) { list.push[i32](&counts, 0); ki0 = ki0 + 1; }
    let ci0: i32 = 0;
    while (ci0 < a.*.scene.*.comps.len) {
        let kx: i32 = kind_index(a.*.scene.*.comps.data[ci0].kind);
        list.set[i32](&counts, kx, list.get[i32](counts, kx) + 1);
        ci0 = ci0 + 1;
    }

    // rows scrolled out of the panel advance y but draw nothing — a 100k-part
    // outliner costs what its visible slice costs
    let y_lo: i32 = list_top - 16;
    let y_hi: i32 = content.y + content.h;

    let gi: i32 = 0;
    while (gi < kind_count()) {
        let k: Kind = kind_at(gi);
        let count: i32 = list.get[i32](counts, gi);
        let open: bool = outliner_group_row(a, x, y, w, gi, kind_name(k), count);
        y = y + 17;
        if (open) {
            let j: i32 = 0;
            while (j < a.*.scene.*.comps.len) {
                let c: Comp = a.*.scene.*.comps.data[j];
                if (c.kind == k && pcmd_match(c.name_, q)) {
                    if (y > y_lo && y < y_hi) {
                        outliner_comp_row(a, rect(x + 10, y, w - 10, 15), j);
                    }
                    y = y + 16;
                }
                j = j + 1;
            }
        }
        gi = gi + 1;
    }
    list.free[i32](&counts);
    // a released drag with no drop target just cancels
    if (!btn_down(inp, 0) && a.*.out_drag_id >= 0) { a.*.out_drag_id = 0 - 1; }

    let open_g: bool = outliner_group_row(a, x, y, w, 5, "Waveguides", a.*.scene.*.guides.len);
    y = y + 17;
    if (open_g) {
        let j2: i32 = 0;
        while (j2 < a.*.scene.*.guides.len) {
            if (y > y_lo && y < y_hi) {
                let g: Guide = a.*.scene.*.guides.data[j2];
                let row: Rect = rect(x + 10, y, w - 10, 15);
                let selr: bool = a.*.sel_guide == g.id;
                let hov: bool = hover(inp, row);
                let _eid: i64 = ui_register(inp, "treeitem", fmt_i(g.id as i64), "Waveguide",
                                            row, true, selr, false);
                if (selr) { fill_round_rect(f, row.x, row.y, row.w, row.h, radius_control(), th_accent()); }
                else if (hov) { fill_round_rect(f, row.x, row.y, row.w, row.h, radius_control(), th_header()); }
                fill_rect(f, row.x + 3, row.y + 4, 7, 7, trit_color(g.live));
                rect_outline(f, row.x + 3, row.y + 4, 7, 7, trit_rim(g.live));
                let sci: i32 = scene_comp_index(a.*.scene, g.from_c);
                let dci: i32 = scene_comp_index(a.*.scene, g.to_c);
                if (sci >= 0 && dci >= 0) {
                    let t1: []u8 = _zag_str_concat(a.*.scene.*.comps.data[sci].name_, " > ");
                    let t2: []u8 = _zag_str_concat(t1, a.*.scene.*.comps.data[dci].name_);
                    draw_text_max(f, row.x + 15, row.y + 3, t2, th_text(), row.w - 34);
                    _zag_str_free(t1);
                    _zag_str_free(t2);
                }
                if (ui_mini(f, inp, rect(row.x + row.w - 16, row.y, 14, 15), "x", th_danger())) {
                    op_del_guide(&a.*.jrn, a.*.scene, g.id);
                    scene_remove_guide(a.*.scene, g.id);
                    app_mark_dirty(a);
                    if (a.*.sel_guide == g.id) { a.*.sel_guide = 0 - 1; }
                } else if (hov && btn_released(inp, 0) && inp.*.mx < row.x + row.w - 18) {
                    a.*.sel_guide = g.id;
                    a.*.sel.len = 0;
                }
            }
            y = y + 16;
            j2 = j2 + 1;
        }
    }
    fb_clip_reset(f);
}

// ── bottom: signal debugger ───────────────────────────────────────────────────

fn scope_visible(a: *App) bool {
    let pid: i32 = sel_primary(a);
    if (pid < 0) { return false; }
    let ci: i32 = scene_comp_index(a.*.scene, pid);
    if (ci < 0) { return false; }
    return a.*.scene.*.comps.data[ci].kind == Kind.Chamber;
}

// ── signal timeline (Section 3.10) ────────────────────────────────────────────

fn tl_in(lst: *list.ArrayList[i32], id: i32) bool {
    let i: i32 = 0;
    while (i < lst.*.len) {
        if (list.get[i32](lst.*, i) == id) { return true; }
        i = i + 1;
    }
    return false;
}

fn tl_toggle(lst: *list.ArrayList[i32], id: i32) void {
    let i: i32 = 0;
    while (i < lst.*.len) {
        if (list.get[i32](lst.*, i) == id) {
            let k: i32 = i;
            while (k + 1 < lst.*.len) {
                lst.*.data[k] = lst.*.data[k + 1];
                k = k + 1;
            }
            lst.*.len = lst.*.len - 1;
            return;
        }
        i = i + 1;
    }
    list.push[i32](lst, id);
}

// Vertical level for a trit inside an 14px row: +1 top, 0 mid, -1 bottom.
fn tl_level_y(y: i32, t: i32) i32 {
    if (t > 0) { return y + 1; }
    if (t < 0) { return y + 11; }
    return y + 6;
}

// One waveform row: pin + hide toggles, name with propagation delay, then a
// smooth step-waveform over the visible history window. Hover inspects the
// exact tick, click on the label highlights the beam path in 3D.
fn draw_signal_row(a: *App, x: i32, y: i32, w: i32, comp_id: i32, label: []u8, tint: i64, hidden: bool) void {
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;

    // pin / hide toggles
    let pinned: bool = tl_in(&a.*.tl_pin, comp_id);
    let pcol: i64 = th_disabled();
    if (pinned) { pcol = th_accent_hot(); }
    if (ui_mini(f, inp, rect(x, y, 12, 14), "^", pcol)) { tl_toggle(&a.*.tl_pin, comp_id); }
    if (ui_mini(f, inp, rect(x + 13, y, 12, 14), "x", th_disabled())) { tl_toggle(&a.*.tl_hide, comp_id); }

    fill_rect(f, x + 28, y + 3, 8, 8, tint);

    // cross-highlight (Section 3.10): the row whose beam path is selected in 3D
    let hl: bool = false;
    if (a.*.sel_guide >= 0) {
        let hgi: i32 = scene_guide_index(a.*.scene, a.*.sel_guide);
        if (hgi >= 0 && a.*.scene.*.guides.data[hgi].from_c == comp_id) { hl = true; }
    }
    let lrect: Rect = rect(x + 40, y, 96, 14);
    let lcol: i64 = th_text();
    if (hidden) { lcol = th_text_dim(); }
    if (hl) { fill_rect(f, lrect.x - 2, y, 100, 14, th_accent()); }
    else if (sel_has(a, comp_id)) { fill_rect(f, lrect.x - 2, y, 100, 14, th_header()); }
    let label_max: i32 = 78;
    draw_text_max(f, lrect.x, y + 3, label, lcol, label_max);
    // propagation delay of the incoming guide, in symbols (Section 3.10)
    let din: i32 = 0 - 1;
    let gg2: i32 = 0;
    while (gg2 < a.*.scene.*.guides.len) {
        if (a.*.scene.*.guides.data[gg2].to_c == comp_id) {
            din = guide_delay_symbols_for_model(a.*.scene, a.*.sim.*.clock_ghz,
                                                a.*.scene.*.guides.data[gg2].length_nm);
        }
        gg2 = gg2 + 1;
    }
    if (din >= 0) {
        let ds: []u8 = _zag_str_concat("+", fmt_i(din as i64));
        draw_text(f, lrect.x + imin(text_w(label), label_max) + 4, y + 3, ds, th_accent_hot());
    }
    // clicking the label selects the part and lights its beam path in 3D
    let _eid: i64 = ui_register(inp, "timelineitem", fmt_i(comp_id as i64), label,
                                lrect, true, sel_has(a, comp_id), false);
    if (hover(inp, lrect) && btn_released(inp, 0)) {
        sel_set(a, comp_id);
        let found_g: i32 = 0 - 1;
        let gg3: i32 = 0;
        while (gg3 < a.*.scene.*.guides.len) {
            if (a.*.scene.*.guides.data[gg3].from_c == comp_id) {
                found_g = a.*.scene.*.guides.data[gg3].id;
            }
            gg3 = gg3 + 1;
        }
        if (found_g >= 0) { a.*.sel_guide = found_g; }   // after sel_set: both stay lit
    }

    // waveform area
    let wx: i32 = x + 140;
    let ww: i32 = w - 148;
    let cells: i32 = ww / a.*.tl_zoom;
    if (cells > hist_len() - 1) { cells = hist_len() - 1; }
    if (cells < 2) { return; }
    fill_rect(f, wx, y, cells * a.*.tl_zoom, 14, rgb(14, 14, 18));
    // symbol ruler ticks every 10 symbols
    let live_sym: i64 = a.*.sim.*.symbol - 1 - (a.*.tl_scrub as i64);
    let i: i32 = 0;
    let prev_y: i32 = 0 - 1;
    while (i < cells) {
        let back: i32 = a.*.tl_scrub + (cells - 1 - i);
        let t: i32 = sim_history(a.*.sim, comp_id, back);
        let cxp: i32 = wx + i * a.*.tl_zoom;
        let sym_i: i64 = a.*.sim.*.symbol - 1 - (back as i64);
        if (sym_i >= 0 && sym_i % 10 == 0) {
            vline(f, cxp, y, 14, rgb(30, 30, 36));
        }
        if (!signal_is_trit(t)) {
            // invalid/conflicting state: unmistakable amber block (Section 3.10)
            fill_rect(f, cxp, y + 2, a.*.tl_zoom, 10, trit_color(t));
        } else {
            let ly: i32 = tl_level_y(y, t);
            let segc: i64 = trit_rim(t);
            if (hidden) { segc = th_disabled(); }
            hline(f, cxp, ly, a.*.tl_zoom, segc);
            if (t != 0) { hline(f, cxp, ly + 1, a.*.tl_zoom, trit_color(t)); }
            if (prev_y >= 0 && prev_y != ly) {
                vline(f, cxp, imin(prev_y, ly), iabs(prev_y - ly) + 1, segc);
            }
            prev_y = ly;
        }
        i = i + 1;
    }
    rect_outline(f, wx - 1, y - 1, cells * a.*.tl_zoom + 2, 16, th_outline());

    // hover inspect: exact tick / time / state under the cursor (Section 3.10)
    let wrect: Rect = rect(wx, y, cells * a.*.tl_zoom, 14);
    if (rect_has(wrect, inp.*.mx, inp.*.my) && inp.*.capture == 0) {
        let hi: i32 = (inp.*.mx - wx) / a.*.tl_zoom;
        let hback: i32 = a.*.tl_scrub + (cells - 1 - hi);
        let ht: i32 = sim_history(a.*.sim, comp_id, hback);
        let hsym: i64 = a.*.sim.*.symbol - 1 - (hback as i64);
        if (hsym >= 0) {
            vline(f, wx + hi * a.*.tl_zoom, y - 1, 16, th_focus());
            let hps: i64 = ((hsym as f64) * sim_period_ps(a.*.sim)) as i64;
            let hs: []u8 = _zag_str_concat("sym ", fmt_i(hsym));
            hs = _zag_str_concat(hs, "  t ");
            hs = _zag_str_concat(hs, fmt_i(hps));
            hs = _zag_str_concat(hs, " ps  state ");
            hs = _zag_str_concat(hs, trit_glyph(ht));
            let hw: i32 = text_w(hs) + 10;
            let hxp: i32 = inp.*.mx + 12;
            if (hxp + hw > wx + ww) { hxp = inp.*.mx - hw - 8; }
            blend_rect(f, hxp, y - 4, hw, 15, rgb(6, 8, 12), 220);
            rect_outline(f, hxp, y - 4, hw, 15, th_outline());
            draw_text(f, hxp + 5, y, hs, th_text());
        }
    }
}

fn draw_debugger(a: *App) void {
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let content: Rect = ui_panel(f, zone_bottom(a), "SIGNALS");
    fb_clip(f, content.x, content.y, content.x + content.w, content.y + content.h);
    let x: i32 = content.x + 8;
    let y: i32 = content.y + 6;

    let playing: bool = a.*.sim.*.playing;
    let plabel: []u8 = "Run";
    if (playing) { plabel = "Pause"; }
    if (ui_button(f, inp, rect(x, y, 58, 18), plabel, playing)) {
        a.*.sim.*.playing = !playing;
    }
    if (ui_button(f, inp, rect(x + 62, y, 50, 18), "Step", false)) {
        sim_step(a.*.sim, a.*.scene);
    }
    if (ui_button(f, inp, rect(x + 116, y, 54, 18), "Reset", false)) {
        sim_reset(a.*.sim, a.*.scene);
    }
    draw_text(f, x + 180, y + 5, "rate", th_text_dim());
    a.*.sim.*.speed = ui_slider(f, inp, rect(x + 210, y + 3, 110, 12), a.*.sim.*.speed, 1.0, 120.0, &a.*.speed_drag);

    // clock readout — the derived fabric clock (min EO bandwidth of the
    // placed parts), not an asserted constant
    let ps: f64 = (a.*.sim.*.symbol as f64) * sim_period_ps(a.*.sim);
    let cx: i32 = x + 332;
    let tcol: i64 = th_text_dim();
    let mode_label: []u8 = "Functional  ";
    if (a.*.sim.*.mode == SimMode.Physical) { mode_label = "Physical  "; }
    draw_text(f, cx, y + 5, mode_label, tcol);
    cx = cx + text_w(mode_label);
    draw_text(f, cx, y + 5, "symbol ", tcol);
    cx = cx + text_w("symbol ");
    cx = cx + draw_int(f, cx, y + 5, a.*.sim.*.symbol, tcol);
    draw_text(f, cx, y + 5, "   t ", tcol);
    cx = cx + text_w("   t ");
    cx = cx + draw_int(f, cx, y + 5, ps as i64, tcol);
    draw_text(f, cx, y + 5, " ps   clock ", tcol);
    cx = cx + text_w(" ps   clock ");
    if (a.*.sim.*.mode == SimMode.Physical && !model_complete(a.*.scene.*.model)) {
        draw_text(f, cx, y + 5, "Unknown (model incomplete)", th_warning());
    } else if (a.*.sim.*.mode == SimMode.Functional) {
        draw_text(f, cx, y + 5, "N/A (symbolic)", tcol);
    } else if (a.*.sim.*.clock_ghz > 0.0) {
        cx = cx + draw_int(f, cx, y + 5, a.*.sim.*.clock_ghz as i64, tcol);
        let evidence: []u8 = evidence_class_name(a.*.scene.*.model.emitter_rate_ghz.confidence);
        draw_text(f, cx, y + 5, _zag_str_concat(" GHz  ", evidence), tcol);
    } else {
        draw_text(f, cx, y + 5, "-- (no active parts)", tcol);
    }

    // timeline zoom controls + scrub state (Section 3.10)
    let zx: i32 = content.x + content.w - 190;
    draw_text(f, zx, y + 5, "zoom", th_text_dim());
    if (ui_mini(f, inp, rect(zx + 30, y + 2, 14, 14), "-", th_text())) {
        if (a.*.tl_zoom > 2) { a.*.tl_zoom = a.*.tl_zoom - 1; }
    }
    if (ui_mini(f, inp, rect(zx + 46, y + 2, 14, 14), "+", th_text())) {
        if (a.*.tl_zoom < 14) { a.*.tl_zoom = a.*.tl_zoom + 1; }
    }
    if (a.*.tl_scrub > 0) {
        let vs: []u8 = _zag_str_concat("-", fmt_i(a.*.tl_scrub as i64));
        draw_text(f, zx + 66, y + 5, vs, th_warning());
        if (ui_button(f, inp, rect(zx + 106, y, 50, 18), "Live", true)) { a.*.tl_scrub = 0; }
    } else if (a.*.tl_hide.len > 0) {
        let hl2: []u8 = "hidden";
        if (ui_button(f, inp, rect(zx + 106, y, 60, 18), hl2, a.*.tl_show_hidden)) {
            a.*.tl_show_hidden = !a.*.tl_show_hidden;
        }
    }

    y = y + 26;

    // lanes use the full panel unless the interference scope is showing
    let has_scope: bool = scope_visible(a) && content.w >= 700;
    let lanes_w: i32 = content.w - 16;
    if (has_scope) { lanes_w = content.w - 332; }
    let lanes_top: i32 = y;

    // scrub + zoom input over the whole lanes region (drag left = back in time)
    let lanes_h: i32 = content.h - (y - content.y) - 14 * a.*.log.len - 8;
    let lanes_rect: Rect = rect(x + 154, lanes_top, lanes_w - 154, lanes_h);
    if (rect_has(lanes_rect, inp.*.mx, inp.*.my) && inp.*.capture == 0) {
        if (inp.*.wheel != 0 && ctrl_down(inp)) {
            a.*.tl_zoom = clampi(a.*.tl_zoom + inp.*.wheel, 2, 14);
        } else if (inp.*.wheel != 0) {
            a.*.tl_scroll = imax(0, a.*.tl_scroll - inp.*.wheel);
        }
        if (btn_pressed(inp, 0) && shift_down(inp)) {
            a.*.tl_drag = 1;
            inp.*.capture = 3;
        }
    }
    if (a.*.tl_drag == 1) {
        inp.*.capture = 3;
        if (!btn_down(inp, 0)) {
            a.*.tl_drag = 0;
            inp.*.capture = 0;
        } else {
            // dragging scrubs: cursor distance from the right edge is symbols back
            let backpx: i32 = (lanes_rect.x + lanes_rect.w) - inp.*.mx;
            let ns: i32 = backpx / a.*.tl_zoom;
            a.*.tl_scrub = clampi(ns, 0, hist_len() - 2);
        }
    }

    // row order: pinned first, then the rest; hidden rows skipped unless shown
    let order: list.ArrayList[i32] = list.make[i32](16);
    let pass: i32 = 0;
    while (pass < 2) {
        let i0: i32 = 0;
        while (i0 < a.*.scene.*.comps.len) {
            let c0: Comp = a.*.scene.*.comps.data[i0];
            let is_sig0: bool = c0.kind == Kind.Emitter || c0.kind == Kind.Chamber || c0.kind == Kind.Detector;
            if (is_sig0) {
                let pinned0: bool = tl_in(&a.*.tl_pin, c0.id);
                let hidden0: bool = tl_in(&a.*.tl_hide, c0.id);
                let want: bool = false;
                if (pass == 0 && pinned0) { want = true; }
                if (pass == 1 && !pinned0) { want = true; }
                if (want && (!hidden0 || a.*.tl_show_hidden)) { list.push[i32](&order, i0); }
            }
            i0 = i0 + 1;
        }
        pass = pass + 1;
    }

    let shown: i32 = 0;
    let max_lanes: i32 = (content.h - 60 - 14 * a.*.log.len) / 17;
    if (a.*.tl_scroll > imax(0, order.len - max_lanes)) {
        a.*.tl_scroll = imax(0, order.len - max_lanes);
    }
    let oi: i32 = a.*.tl_scroll;
    while (oi < order.len && shown < max_lanes) {
        let ci4: i32 = list.get[i32](order, oi);
        let c: Comp = a.*.scene.*.comps.data[ci4];
        let tint: i64 = kind_tint(c.kind);
        if (c.kind == Kind.Emitter) { tint = wavelength_color(c.wl_nm); }
        draw_signal_row(a, x + 6, y, lanes_w, c.id, c.name_, tint, tl_in(&a.*.tl_hide, c.id));
        y = y + 17;
        shown = shown + 1;
        oi = oi + 1;
    }
    list.free[i32](&order);
    if (shown == 0) {
        ui_empty_state(f, rect(content.x, y, lanes_w, imax(70, lanes_h)),
                       "no signal lanes", "place emitters, chambers and sensors");
        y = y + 15;
    }

    // console log
    let ly: i32 = content.y + content.h - 14 * a.*.log.len - 4;
    hline(f, content.x, ly - 3, content.w, th_outline());
    let li: i32 = 0;
    while (li < a.*.log.len) {
        draw_text(f, x, ly + li * 14, list.get[[]u8](a.*.log, li), th_text_dim());
        li = li + 1;
    }

    if (has_scope) { draw_scope(a, content); }
    fb_clip_reset(f);
}

fn draw_scope(a: *App, content: Rect) void {
    if (!scope_visible(a)) { return; }
    let f: *FB = &a.*.f;
    let sw: i32 = 300;
    let sh: i32 = content.h - 40 - 14 * a.*.log.len;
    if (sh > 108) { sh = 108; }
    if (sh < 50) { return; }
    let sx: i32 = content.x + content.w - sw - 8;
    let sy: i32 = content.y + 28;

    fill_rect(f, sx, sy, sw, sh, rgb(14, 14, 18));
    rect_outline(f, sx, sy, sw, sh, th_outline());

    let ci: i32 = scene_comp_index(a.*.scene, sel_primary(a));
    if (ci < 0) { return; }
    draw_text(f, sx + 6, sy + 4, "interference", th_accent_hot());
    draw_text(f, sx + 6, sy + 16, a.*.scene.*.comps.data[ci].name_, th_text_dim());

    let mid: i32 = sy + sh / 2 + 8;
    let amp_px: f64 = ((sh / 2) - 15) as f64;
    hline(f, sx + 2, mid, sw - 4, rgb(40, 42, 50));

    let cid: i32 = a.*.scene.*.comps.data[ci].id;
    // collect the selected chamber's incident guides ONCE (<= 3 inputs), not
    // per scope pixel — the old loop was O(pixels x all guides)
    let inc: list.ArrayList[i32] = list.make[i32](4);
    let gscan: i32 = 0;
    while (gscan < a.*.scene.*.guides.len) {
        if (a.*.scene.*.guides.data[gscan].to_c == cid) { list.push[i32](&inc, gscan); }
        gscan = gscan + 1;
    }
    let phase_anim: f64 = (a.*.frame as f64) * 0.12;
    let px_prev_sum: i32 = mid;
    let x2: i32 = 0;
    while (x2 < sw - 8) {
        let t: f64 = (x2 as f64) * 0.062831853 + phase_anim;
        let field: f64 = 0.0;
        let ii: i32 = 0;
        while (ii < inc.len) {
            let g: Guide = a.*.scene.*.guides.data[list.get[i32](inc, ii)];
            let tr: i32 = g.live;
            let s0: f64 = sin(t + trit_phase_pi(tr) * 3.14159265);
            let w0: f64 = trit_amp(tr);
            field = field + s0 * w0;
            let cy0: i32 = mid - ((s0 * w0 * amp_px * 0.35) as i32);
            px_set(f, sx + 4 + x2, cy0, trit_rim(tr));
            ii = ii + 1;
        }
        if (field > 3.0) { field = 3.0; }
        if (field < 0.0 - 3.0) { field = 0.0 - 3.0; }
        let cy: i32 = mid - ((field * amp_px / 3.0) as i32);
        line2d(f, sx + 3 + x2, px_prev_sum, sx + 4 + x2, cy, rgb(235, 240, 248));
        px_prev_sum = cy;
        x2 = x2 + 2;
    }
    list.free[i32](&inc);
    let out_t: i32 = sim_history(a.*.sim, cid, 0);
    draw_text(f, sx + sw - 62, sy + 4, "out", th_text_dim());
    fill_rect(f, sx + sw - 38, sy + 3, 10, 10, trit_color(out_t));
    rect_outline(f, sx + sw - 38, sy + 3, 10, 10, trit_rim(out_t));
    draw_text(f, sx + sw - 22, sy + 4, trit_glyph(out_t), th_text());
}

// ── measure tool (Section 3.4) ────────────────────────────────────────────────

// Degree arctangent on [0,1] (max error ~0.3 deg) and full-quadrant atan2.
fn atan_deg01(t: f64) f64 {
    return t * (45.0 + 15.6 * (1.0 - t));
}

fn atan2_deg(y: f64, x: f64) f64 {
    let ax: f64 = fabs(x);
    let ay: f64 = fabs(y);
    if (ax == 0.0 && ay == 0.0) { return 0.0; }
    let ang: f64 = 0.0;
    if (ax >= ay) { ang = atan_deg01(ay / ax); }
    else { ang = 90.0 - atan_deg01(ax / ay); }
    if (x < 0.0) { ang = 180.0 - ang; }
    if (y < 0.0) { ang = 0.0 - ang; }
    return ang;
}

fn draw_measure_marker(a: *App, vp: Rect, p: Vox, col: i64) void {
    let f: *FB = &a.*.f;
    let c: Vec3 = vox_center(p);
    line3z(f, a.*.cam, vp, v3(c.x - 0.4, c.y, c.z), v3(c.x + 0.4, c.y, c.z), col, false, true);
    line3z(f, a.*.cam, vp, v3(c.x, c.y, c.z - 0.4), v3(c.x, c.y, c.z + 0.4), col, false, true);
    line3z(f, a.*.cam, vp, v3(c.x, c.y - 0.4, c.z), v3(c.x, c.y + 0.4, c.z), col, false, true);
}

// Exact deltas, straight-line distance (cells and nm from the lattice pitch),
// layer height, and in-plane angle between the two picked points.
fn draw_measure(a: *App, vp: Rect) void {
    let f: *FB = &a.*.f;
    if (a.*.measure_n == 0) {
        draw_text(f, vp.x + pad_panel(), vp.y + vp.h - 30,
                  "measure: click the first point", th_accent_hot());
        return;
    }
    let pa: Vox = a.*.measure_a;
    let pb: Vox = a.*.hover_cell;
    if (a.*.measure_n == 2) { pb = a.*.measure_b; }
    else if (!a.*.hover_ok) { pb = pa; }
    draw_measure_marker(a, vp, pa, th_accent_hot());
    draw_measure_marker(a, vp, pb, th_ok());
    line3z(f, a.*.cam, vp, vox_center(pa), vox_center(pb), rgb(235, 240, 248), false, true);

    let dx: i32 = pb.x - pa.x;
    let dy: i32 = pb.y - pa.y;
    let dz: i32 = pb.z - pa.z;
    let dist_cells: f64 = sqrt((dx * dx + dy * dy + dz * dz) as f64);
    let dist_nm: i64 = (dist_cells * pitch_nm()) as i64;
    let s1: []u8 = _zag_str_concat("d ", fmt_i(dx as i64));
    s1 = _zag_str_concat(s1, ", ");
    s1 = _zag_str_concat(s1, fmt_i(dy as i64));
    s1 = _zag_str_concat(s1, ", ");
    s1 = _zag_str_concat(s1, fmt_i(dz as i64));
    s1 = _zag_str_concat(s1, " cells   ");
    s1 = _zag_str_concat(s1, fmt_f1(dist_cells));
    s1 = _zag_str_concat(s1, " cells = ");
    s1 = _zag_str_concat(s1, fmt_i(dist_nm));
    s1 = _zag_str_concat(s1, " nm");
    let s2: []u8 = _zag_str_concat("layer dy ", fmt_i(dy as i64));
    s2 = _zag_str_concat(s2, "   angle ");
    s2 = _zag_str_concat(s2, fmt_f1(atan2_deg(dz as f64, dx as f64)));
    s2 = _zag_str_concat(s2, " deg (plane)");
    let bw: i32 = imax(text_w(s1), text_w(s2)) + pad_panel() * 2;
    let bx: i32 = vp.x + pad_panel();
    let by: i32 = vp.y + vp.h - 52;
    blend_rect(f, bx, by, bw, 36, rgb(6, 8, 12), 200);
    rect_outline(f, bx, by, bw, 36, th_outline());
    draw_text(f, bx + pad_panel(), by + 7, s1, th_text());
    draw_text(f, bx + pad_panel(), by + 21, s2, th_text_dim());
}

// ── right-click context menu (Section 3.6) ────────────────────────────────────

fn ctx_items(a: *App, out: *list.ArrayList[MenuItem]) void {
    out.*.len = 0;
    if (a.*.ctx_comp >= 0) {
        let ci: i32 = scene_comp_index(a.*.scene, a.*.ctx_comp);
        let vis_label: []u8 = "Hide";
        if (ci >= 0 && !a.*.scene.*.comps.data[ci].visible) { vis_label = "Show"; }
        let lock_label: []u8 = "Lock";
        if (app_is_locked(a, a.*.ctx_comp)) { lock_label = "Unlock"; }
        list.push[MenuItem](out, MenuItem{ .label = "Rename", .hint = "F2", .code = 19 });
        list.push[MenuItem](out, MenuItem{ .label = "Duplicate", .hint = "Shift+D", .code = 12 });
        list.push[MenuItem](out, MenuItem{ .label = "Copy", .hint = "Ctrl+C", .code = 15 });
        list.push[MenuItem](out, MenuItem{ .label = "", .hint = "", .code = 0 });
        list.push[MenuItem](out, MenuItem{ .label = "Frame", .hint = "F", .code = 20 });
        list.push[MenuItem](out, MenuItem{ .label = vis_label, .hint = "", .code = 70 });
        list.push[MenuItem](out, MenuItem{ .label = lock_label, .hint = "", .code = 71 });
        list.push[MenuItem](out, MenuItem{ .label = "", .hint = "", .code = 0 });
        list.push[MenuItem](out, MenuItem{ .label = "Group", .hint = "Ctrl+G", .code = 17 });
        list.push[MenuItem](out, MenuItem{ .label = "Ungroup", .hint = "", .code = 18 });
        list.push[MenuItem](out, MenuItem{ .label = "", .hint = "", .code = 0 });
        list.push[MenuItem](out, MenuItem{ .label = "Delete", .hint = "X", .code = 13 });
    } else {
        list.push[MenuItem](out, MenuItem{ .label = "Paste", .hint = "Ctrl+V", .code = 16 });
        list.push[MenuItem](out, MenuItem{ .label = "", .hint = "", .code = 0 });
        list.push[MenuItem](out, MenuItem{ .label = "Frame All", .hint = "Home", .code = 21 });
        list.push[MenuItem](out, MenuItem{ .label = "Reset View", .hint = "", .code = 28 });
    }
}

fn ctx_exec(a: *App, code: i32) void {
    if (code == 70) {
        let ci: i32 = scene_comp_index(a.*.scene, a.*.ctx_comp);
        if (ci >= 0) {
            a.*.scene.*.comps.data[ci].visible = !a.*.scene.*.comps.data[ci].visible;
            scene_mark_render(a.*.scene);
        }
        return;
    }
    if (code == 71) {
        app_toggle_lock(a, a.*.ctx_comp);
        return;
    }
    app_action(a, code);
}

fn draw_ctx_menu(a: *App) void {
    if (!a.*.ctx_open) { return; }
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let cap: i32 = inp.*.capture;
    inp.*.capture = 0;

    let items: list.ArrayList[MenuItem] = list.make[MenuItem](14);
    ctx_items(a, &items);
    let iw: i32 = 180;
    let ih: i32 = 21;
    let sep: i32 = 7;
    let total: i32 = 0;
    let i: i32 = 0;
    while (i < items.len) {
        if (items.data[i].code == 0) { total = total + sep; } else { total = total + ih; }
        i = i + 1;
    }
    let mx0: i32 = a.*.ctx_x;
    let my0: i32 = a.*.ctx_y;
    if (mx0 + iw > inp.*.w - 4) { mx0 = inp.*.w - 4 - iw; }
    if (my0 + total + 8 > inp.*.h - 4) { my0 = inp.*.h - 4 - total - 8; }
    let dr: Rect = rect(mx0, my0, iw, total + 8);
    draw_shadow(f, dr.x, dr.y, dr.w, dr.h, radius_panel());
    fill_round_rect(f, dr.x, dr.y, dr.w, dr.h, radius_panel(), th_panel());
    round_rect_outline(f, dr.x, dr.y, dr.w, dr.h, radius_panel(), th_outline());

    let y: i32 = dr.y + 4;
    let clicked: bool = false;
    i = 0;
    while (i < items.len) {
        let it: MenuItem = items.data[i];
        if (it.code == 0) {
            hline(f, dr.x + 8, y + 3, dr.w - 16, th_outline_soft());
            y = y + sep;
        } else {
            let row: Rect = rect(dr.x + 4, y, dr.w - 8, ih);
            let hov: bool = rect_has(row, inp.*.mx, inp.*.my);
            let _eid: i64 = ui_register(inp, "menuitem", it.label, it.label, row, true, false, false);
            if (hov) { fill_round_rect(f, row.x, row.y, row.w, row.h, radius_control(), th_accent()); }
            draw_text(f, row.x + pad_panel(), y + 6, it.label, th_text());
            if (it.hint.len > 0) {
                draw_text(f, row.x + row.w - text_w(it.hint) - pad_panel(), y + 6, it.hint, th_text_dim());
            }
            if (hov && btn_released(inp, 0)) {
                a.*.ctx_open = false;
                ctx_exec(a, it.code);
                clicked = true;
            }
            y = y + ih;
        }
        i = i + 1;
    }
    if (!clicked && (btn_pressed(inp, 0) || btn_pressed(inp, 2)) &&
        !rect_has(dr, inp.*.mx, inp.*.my)) {
        a.*.ctx_open = false;
    }
    list.free[MenuItem](&items);
    inp.*.capture = cap;
}

// ── center: 3D viewport composition ───────────────────────────────────────────

fn draw_viewport(a: *App) void {
    let f: *FB = &a.*.f;
    let vp: Rect = zone_center(a);
    fb_clip(f, vp.x, vp.y, vp.x + vp.w, vp.y + vp.h);

    // ── static layer via the tile cache ──────────────────────────────────────
    // The expensive rasterization (grid, components, guide bodies) reruns only
    // when the camera moves or the design changes; otherwise the cached
    // pixel+depth slabs blit back in one pass and the frame costs ~nothing.
    let s: *Scene = a.*.scene;
    let cache: *TileCache = &a.*.tile_cache;
    tiles_marks_from_cam(cache, a.*.cam, vp);
    tiles_marks_from_rev(cache, s.*.render_rev);
    if (tiles_cache_ready(cache)) {
        tiles_blit(f, vp, cache);
    } else {
        vp_draw_static(f, a.*.cam, vp, s, a.*.sim, a.*.sect_on, a.*.sect_y);
        // Storing the slabs is only worth it if the camera will hold still and
        // reuse them. During an active orbit/pan every frame re-rasterizes
        // anyway, so skip the copy — the overlay still z-tests the fresh depth
        // in the framebuffer — and cache once when motion stops.
        if (!a.*.cam_drag) { tiles_store_from_fb(f, vp, cache); }
    }

    // ── dynamic overlay (every frame, z-tested against the cached depth) ─────
    vp_draw_live(f, a.*.cam, vp, s, a.*.sim, a.*.sel_guide, a.*.sect_on, a.*.sect_y);

    // simulation tick pulses active beams for a few frames (Section 3.11):
    // a brief brightness lift on the carrier centerline, color only, and off
    // entirely in reduced motion
    let page: i64 = a.*.frame - a.*.pulse_frame;
    if (!a.*.inp.reduced_motion && page >= 0 && page < 5) {
        let pt: f64 = 1.0 - (page as f64) / 5.0;
        let pg: i32 = 0;
        while (pg < s.*.guides.len) {
            let pgd: Guide = s.*.guides.data[pg];
            if (pgd.live != 0 && !sect_hides_guide(a.*.sect_on, a.*.sect_y, pgd)) {
                let pcol: i64 = lerp_color(trit_rim(pgd.live), rgb(255, 255, 255), pt * 0.5);
                let pi4: i32 = 1;
                while (pi4 < pgd.path.len) {
                    line3(f, a.*.cam, vp, vox_center(list.get[Vox](pgd.path, pi4 - 1)),
                          vox_center(list.get[Vox](pgd.path, pi4)), pcol, false);
                    pi4 = pi4 + 1;
                }
            }
            pg = pg + 1;
        }
    }

    // place ghost (armed tool or library card drag)
    if (a.*.ghost_ok >= 0 && !a.*.moving) {
        let k: Kind = kind_at(0);
        if (a.*.lib_drag >= 0) { k = kind_at(a.*.lib_drag); }
        else { k = app_current_kind(a); }
        let e: Vox = rot_ext(kind_fp(k), a.*.ghost_rot);
        let mn: Vec3 = v3(a.*.ghost_origin.x as f64, a.*.ghost_origin.y as f64, a.*.ghost_origin.z as f64);
        let mx: Vec3 = v3(mn.x + (e.x as f64), mn.y + (e.y as f64), mn.z + (e.z as f64));
        let gcol: i64 = th_ok();
        if (a.*.ghost_ok != 0) { gcol = th_danger(); }
        vp_box(f, a.*.cam, vp, mn, mx, gcol, 80, false);
        vp_box_wire(f, a.*.cam, vp, mn, mx, gcol);
        let gcx: f64 = (mn.x + mx.x) * 0.5;
        let gcz: f64 = (mn.z + mx.z) * 0.5;
        // depth cue: drop line from the ghost base to the ground grid
        if (mn.y > 0.0) {
            line3z(f, a.*.cam, vp, v3(gcx, mn.y, gcz), v3(gcx, 0.0, gcz), th_text_dim(), false, true);
        }
        // snap targets shown BEFORE placement (Section 3.4): the snapped lattice
        // cell outline plus alignment guides that gently pulse (Section 3.11)
        let pulse: i64 = th_ok();
        if (!a.*.inp.reduced_motion) {
            let ph: f64 = sin((a.*.frame as f64) * 0.25) * 0.5 + 0.5;
            pulse = lerp_color(th_ok(), rgb(180, 255, 205), ph);
        }
        if (a.*.snap_ax != 0 - 1000000) {
            line3z(f, a.*.cam, vp, v3(mn.x, mn.y, gcz - 14.0), v3(mn.x, mn.y, gcz + 14.0), pulse, false, false);
        }
        if (a.*.snap_az != 0 - 1000000) {
            line3z(f, a.*.cam, vp, v3(gcx - 14.0, mn.y, mn.z), v3(gcx + 14.0, mn.y, mn.z), pulse, false, false);
        }
        // invalid placement: the reason follows the ghost (never hidden)
        if (a.*.ghost_ok > 0) {
            let gp: P3 = vp_proj(a.*.cam, vp, v3(gcx, mx.y + 0.6, gcz));
            if (gp.ok) {
                let msg: []u8 = place_err_text(a.*.ghost_ok);
                let mw: i32 = text_w(msg) + 10;
                let mx0: i32 = (gp.x as i32) - mw / 2;
                blend_rect(f, mx0, (gp.y as i32) - 8, mw, 15, rgb(30, 10, 10), 210);
                draw_text(f, mx0 + 5, (gp.y as i32) - 4, msg, th_danger());
            }
        }
    }

    // route tool: live preview from the armed output port to the cursor
    if (a.*.tool == tool_route() && a.*.route_c >= 0) {
        let rci: i32 = scene_comp_index(s, a.*.route_c);
        if (rci >= 0) {
            let ratt: Vox = comp_port_attach(s.*.comps.data[rci], a.*.route_p);
            let rfrom: Vec3 = vox_center(ratt);
            let rto: Vec3 = rfrom;
            let rcol: i64 = th_accent_hot();
            if (a.*.hover_pc >= 0) {
                let hci: i32 = scene_comp_index(s, a.*.hover_pc);
                if (hci >= 0) {
                    rto = vox_center(comp_port_attach(s.*.comps.data[hci], a.*.hover_pp));
                    rcol = th_ok();
                }
            } else {
                let rch: CellHit = vp_cell_at(a.*.cam, vp, a.*.inp.mx, a.*.inp.my, 1);
                if (rch.ok) { rto = vox_center(rch.cell); }
            }
            line3z(f, a.*.cam, vp, rfrom, rto, rcol, false, true);
        }
    }

    // measure tool overlay (Section 3.4)
    if (a.*.tool == tool_measure()) { draw_measure(a, vp); }

    // move ghost: outline every selected comp at its target offset
    if (a.*.moving) {
        let gcol2: i64 = th_ok();
        if (a.*.move_ok != 0) { gcol2 = th_danger(); }
        let mi: i32 = 0;
        while (mi < a.*.sel.len) {
            let ci: i32 = scene_comp_index(s, list.get[i32](a.*.sel, mi));
            if (ci >= 0) {
                let c3: Comp = s.*.comps.data[ci];
                let lo: Vec3 = comp_bounds_min(c3);
                let hi: Vec3 = comp_bounds_max(c3);
                let dx: f64 = a.*.move_delta.x as f64;
                let dz: f64 = a.*.move_delta.z as f64;
                let mn2: Vec3 = v3(lo.x + dx, lo.y, lo.z + dz);
                let mx2: Vec3 = v3(hi.x + dx, hi.y, hi.z + dz);
                vp_box(f, a.*.cam, vp, mn2, mx2, gcol2, 70, false);
                vp_box_wire(f, a.*.cam, vp, mn2, mx2, gcol2);
            }
            mi = mi + 1;
        }
    }

    // route tool port markers
    if (a.*.tool == tool_route()) {
        let pi: i32 = 0;
        while (pi < s.*.comps.len) {
            let c4: Comp = s.*.comps.data[pi];
            let np: i32 = kind_port_count(c4.kind);
            let pj: i32 = 0;
            while (pj < np) {
                let att: Vox = comp_port_attach(c4, pj);
                let ctr: Vec3 = vox_center(att);
                let p: Port = kind_port(c4.kind, pj);
                let used: bool = scene_port_in_use(s, c4.id, pj);
                let mcol: i64 = rgb(110, 170, 235);
                if (p.is_output) { mcol = rgb(235, 170, 80); }
                if (used) { mcol = rgb(80, 84, 92); }
                if (a.*.route_c == c4.id && a.*.route_p == pj) { mcol = th_ok(); }
                let hovp: bool = a.*.hover_pc == c4.id && a.*.hover_pp == pj;
                let ms: f64 = 0.16;
                if (hovp) { ms = 0.24; }
                let mn3: Vec3 = v3(ctr.x - ms, ctr.y - ms, ctr.z - ms);
                let mx3: Vec3 = v3(ctr.x + ms, ctr.y + ms, ctr.z + ms);
                vp_box(f, a.*.cam, vp, mn3, mx3, mcol, 256, false);
                pj = pj + 1;
            }
            pi = pi + 1;
        }
    }

    // hover outline (subtle): only in select mode, only for an unselected part
    if (a.*.tool == tool_select() && a.*.hover_comp >= 0 && !sel_has(a, a.*.hover_comp)) {
        let hci: i32 = scene_comp_index(s, a.*.hover_comp);
        if (hci >= 0) {
            let hc: Comp = s.*.comps.data[hci];
            let hmn: Vec3 = comp_bounds_min(hc);
            let hmx: Vec3 = comp_bounds_max(hc);
            let he: f64 = 0.04;
            vp_box_wire(f, a.*.cam, vp,
                v3(hmn.x - he, hmn.y - he, hmn.z - he),
                v3(hmx.x + he, hmx.y + he, hmx.z + he), rgb(150, 156, 172));
        }
    }

    // selection outlines: a dim ghost through occluding geometry, then a bright
    // outline where the part is actually visible. The bright pass fades in over
    // ~6 frames after a selection change (Section 3.11) — color only, never
    // position, and reduced motion renders at full strength immediately.
    let sel_col: i64 = th_select();
    if (!a.*.inp.reduced_motion) {
        let sage: i64 = a.*.frame - a.*.sel_frame;
        if (sage < 6 && sage >= 0) {
            sel_col = lerp_color(rgb(120, 82, 26), th_select(), (sage as f64) / 6.0);
        }
    }
    let si: i32 = 0;
    while (si < a.*.sel.len) {
        let ci2: i32 = scene_comp_index(s, list.get[i32](a.*.sel, si));
        if (ci2 >= 0) {
            let c5: Comp = s.*.comps.data[ci2];
            let smn0: Vec3 = comp_bounds_min(c5);
            let smx0: Vec3 = comp_bounds_max(c5);
            let se: f64 = 0.05;
            let smn: Vec3 = v3(smn0.x - se, smn0.y - se, smn0.z - se);
            let smx: Vec3 = v3(smx0.x + se, smx0.y + se, smx0.z + se);
            vp_box_wire_ghost(f, a.*.cam, vp, smn, smx, rgb(150, 96, 30));
            vp_box_wire(f, a.*.cam, vp, smn, smx, sel_col);
            // a locked part shows a small padlock glyph at its top corner
            if (app_is_locked(a, c5.id)) {
                let lp: P3 = vp_proj(a.*.cam, vp, v3(smx.x, smx.y, smn.z));
                if (lp.ok) {
                    draw_text(f, lp.x as i32, (lp.y as i32) - 10, "#", th_warning());
                }
            }
        }
        si = si + 1;
    }

    // (detector live badges are painted by vp_draw_live above)

    // navigation hint (bottom left, single dim line)
    draw_text(f, vp.x + 8, vp.y + vp.h - 15, "MMB orbit   Shift+MMB pan   wheel zoom", th_text_dim());

    draw_gizmo(a, vp);

    // rubber-band selection box
    if (a.*.box_sel) {
        let bx: i32 = imin(a.*.box_x0, a.*.inp.mx);
        let by: i32 = imin(a.*.box_y0, a.*.inp.my);
        let bw: i32 = imax(a.*.box_x0, a.*.inp.mx) - bx;
        let bh: i32 = imax(a.*.box_y0, a.*.inp.my) - by;
        blend_rect(f, bx, by, bw, bh, th_accent(), 48);
        rect_outline(f, bx, by, bw, bh, th_accent_hot());
    }

    draw_frame_timing_overlay(a, vp);

    // section view badge (Section 3.5)
    if (a.*.sect_on) {
        let sb: []u8 = _zag_str_concat("SECTION  y <= ", fmt_i(a.*.sect_y as i64));
        let sbw: i32 = text_w(sb) + pad_panel() * 2;
        let sbx: i32 = vp.x + (vp.w - sbw) / 2;
        blend_rect(f, sbx, vp.y + 8, sbw, 18, rgb(6, 8, 12), 190);
        rect_outline(f, sbx, vp.y + 8, sbw, 18, th_warning());
        draw_text(f, sbx + pad_panel(), vp.y + 13, sb, th_warning());
    }

    // invalid-action flash (Section 3.11): a brief red border pulse plus the
    // reason. Subtle, color-only; reduced motion shows it at a steady level.
    let iage: i64 = a.*.frame - a.*.invalid_frame;
    if (iage >= 0 && iage < 14) {
        let lvl: i32 = ((14 - iage) * 14) as i32;
        if (a.*.inp.reduced_motion) { lvl = 120; }
        blend_rect(f, vp.x, vp.y, vp.w, 3, th_danger(), lvl);
        blend_rect(f, vp.x, vp.y + vp.h - 3, vp.w, 3, th_danger(), lvl);
        blend_rect(f, vp.x, vp.y + 3, 3, vp.h - 6, th_danger(), lvl);
        blend_rect(f, vp.x + vp.w - 3, vp.y + 3, 3, vp.h - 6, th_danger(), lvl);
        if (a.*.invalid_text.len > 0) {
            let iw2: i32 = text_w(a.*.invalid_text) + pad_panel() * 2;
            let ix: i32 = vp.x + (vp.w - iw2) / 2;
            let iy: i32 = vp.y + vp.h - 24;
            blend_rect(f, ix, iy, iw2, 17, rgb(30, 10, 10), 210);
            draw_text(f, ix + pad_panel(), iy + 5, a.*.invalid_text, th_danger());
        }
    }

    fb_clip_reset(f);
    rect_outline(f, vp.x, vp.y, vp.w, vp.h, th_outline());
}

fn fill_disc(f: *FB, cx: i32, cy: i32, r: i32, col: i64) void {
    let dy: i32 = 0 - r;
    while (dy <= r) {
        let dx: i32 = 0 - r;
        while (dx <= r) {
            if (dx * dx + dy * dy <= r * r) { fill_rect(f, cx + dx, cy + dy, 1, 1, col); }
            dx = dx + 1;
        }
        dy = dy + 1;
    }
}

fn gizmo_axis_color(axis: i32) i64 {
    if (axis == 0) { return rgb(224, 86, 92); }    // X red
    if (axis == 1) { return rgb(126, 205, 126); }  // Y green
    return rgb(104, 158, 240);                      // Z blue
}

fn gizmo_letter(axis: i32) []u8 {
    if (axis == 0) { return "X"; }
    if (axis == 1) { return "Y"; }
    return "Z";
}

// Our clickable orientation gizmo: axis balls placed by the live camera basis,
// front-most drawn last, hover-highlighted; click snaps the view (input side is
// handled in app_viewport_input via gizmo_hit/gizmo_apply).
fn draw_gizmo(a: *App, vp: Rect) void {
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let gcx: i32 = gizmo_cx(a);
    let gcy: i32 = gizmo_cy(a);
    let gr: i32 = gizmo_r();
    let hov: i32 = gizmo_hit(a, inp.*.mx, inp.*.my);

    fill_disc(f, gcx, gcy, gr + 8, rgb(24, 24, 29));

    // stems to the three positive axis balls
    let ax: i32 = 0;
    while (ax < 3) {
        let b: P3 = gizmo_ball(a, ax * 2);
        line2d(f, gcx, gcy, b.x as i32, b.y as i32, gizmo_axis_color(ax));
        ax = ax + 1;
    }

    // balls back-to-front (front faces the viewer: z <= 0)
    let pass: i32 = 0;
    while (pass < 2) {
        let i: i32 = 0;
        while (i < 6) {
            let b: P3 = gizmo_ball(a, i);
            let front: bool = b.z <= 0.0;
            if ((pass == 1) == front) {
                let axis: i32 = i / 2;
                let positive: bool = (i % 2) == 0;
                let bx: i32 = b.x as i32;
                let by: i32 = b.y as i32;
                if (positive) {
                    if (hov == i) { fill_disc(f, bx, by, 8, rgb(245, 245, 250)); }
                    fill_disc(f, bx, by, 6, gizmo_axis_color(axis));
                    draw_text(f, bx - 3, by - 3, gizmo_letter(axis), rgb(20, 20, 24));
                } else {
                    let dim: i64 = rgb(70, 72, 82);
                    if (hov == i) { dim = rgb(214, 214, 220); }
                    fill_disc(f, bx, by, 5, dim);
                    fill_disc(f, bx, by, 3, rgb(24, 24, 29));
                }
            }
            i = i + 1;
        }
        pass = pass + 1;
    }
}

fn draw_frame_timing_overlay(a: *App, vp: Rect) void {
    let f: *FB = &a.*.f;
    let x: i32 = vp.x + 8;
    let y: i32 = vp.y + 8;
    let w: i32 = 176;
    let h: i32 = 34;
    blend_round_rect(f, x, y, w, h, radius_control(), rgb(6, 8, 12), 176);
    round_rect_outline(f, x, y, w, h, radius_control(), th_outline_soft());
    draw_text(f, x + 6, y + 7, "frame ", th_text_dim());
    let tx: i32 = x + 6 + text_w("frame ");
    let tx2: i32 = tx + draw_int(f, tx, y + 7, a.*.frame, th_text());
    draw_text(f, tx2, y + 7, "  ", th_text_dim());
    let tx3: i32 = tx2 + text_w("  ");
    let tx4: i32 = tx3 + draw_int(f, tx3, y + 7, a.*.frame_ms, th_text());
    draw_text(f, tx4, y + 7, " ms", th_text_dim());
    draw_text(f, x + 6, y + 20, "symbol ", th_text_dim());
    let sx: i32 = x + 6 + text_w("symbol ");
    let sx2: i32 = sx + draw_int(f, sx, y + 20, a.*.sim.*.symbol, th_text());
    let run: []u8 = " paused";
    if (a.*.sim.*.playing) { run = " running"; }
    draw_text(f, sx2, y + 20, run, th_text_dim());
}

// ── modals ────────────────────────────────────────────────────────────────────

fn modal_frame(a: *App, w: i32, h: i32, title: []u8) Rect {
    let f: *FB = &a.*.f;
    // dim everything behind
    blend_rect(f, 0, 0, a.*.inp.w, a.*.inp.h, rgb(8, 8, 10), 150);
    let r: Rect = rect((a.*.inp.w - w) / 2, (a.*.inp.h - h) / 2, w, h);
    draw_shadow(f, r.x, r.y, r.w, r.h, radius_panel());
    fill_round_rect(f, r.x, r.y, r.w, r.h, radius_panel(), th_panel());
    round_rect_outline(f, r.x, r.y, r.w, r.h, radius_panel(), th_outline());
    fill_round_rect(f, r.x + 1, r.y + 1, r.w - 2, 23, radius_panel() - 1, th_header());
    fill_rect(f, r.x + 1, r.y + 12, r.w - 2, 12, th_header());
    hline(f, r.x + 1, r.y + 24, r.w - 2, th_outline_soft());
    draw_text(f, r.x + pad_panel(), r.y + 8, title, th_text());
    return r;
}

// Flash FIR workspace: a visible, bounded path from source selection through
// import to run/step and per-operation inspection. It never executes Flash or
// host code; it only parses FIR through flash_ir.zag.
fn draw_flash_panel(a: *App) void {
    if (!a.*.flash_open) { return; }
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let cap: i32 = inp.*.capture; inp.*.capture = 0;
    let pr: Rect = modal_frame(a, 660, 420, "Flash FIR Workspace");
    let field: Rect = rect(pr.x + 12, pr.y + 34, pr.w - 134, 20);
    let _changed: bool = ui_textfield(f, inp, field, &a.*.flash_path, "path/to/program.fir");
    if (ui_button(f, inp, rect(pr.x + pr.w - 112, pr.y + 34, 100, 20), "Import FIR", false) ||
        a.*.flash_path.committed) {
        let _ok: bool = app_flash_import(a, textedit_text(&a.*.flash_path));
    }

    let by: i32 = pr.y + 62;
    let run_label: []u8 = "Run"; if (a.*.sim.*.playing) { run_label = "Pause"; }
    if (ui_button(f, inp, rect(pr.x + 12, by, 62, 20), run_label, a.*.sim.*.playing)) {
        a.*.sim.*.playing = !a.*.sim.*.playing;
    }
    if (ui_button(f, inp, rect(pr.x + 80, by, 54, 20), "Step", false)) {
        sim_step(a.*.sim, a.*.scene);
    }
    if (ui_button(f, inp, rect(pr.x + 140, by, 58, 20), "Reset", false)) {
        sim_reset(a.*.sim, a.*.scene);
    }
    let stat: []u8 = "not imported"; let scol: i64 = th_text_dim();
    if (a.*.flash_verify_errors == 0) { stat = "verified: all detector traces match"; scol = th_ok(); }
    else if (a.*.flash_verify_errors > 0) { stat = "verification mismatch"; scol = th_danger(); }
    draw_text(f, pr.x + 212, by + 6, stat, scol);

    let sy: i32 = pr.y + 94;
    draw_text(f, pr.x + 12, sy, "FIR SOURCE", th_text_dim());
    draw_text(f, pr.x + 340, sy, "PER-OPERATION TRACE", th_text_dim());
    let sr: Rect = rect(pr.x + 12, sy + 14, 310, 272);
    let tr: Rect = rect(pr.x + 336, sy + 14, 312, 272);
    fill_round_rect(f, sr.x, sr.y, sr.w, sr.h, radius_control(), rgb(13, 14, 18));
    fill_round_rect(f, tr.x, tr.y, tr.w, tr.h, radius_control(), rgb(13, 14, 18));
    round_rect_outline(f, sr.x, sr.y, sr.w, sr.h, radius_control(), th_outline());
    round_rect_outline(f, tr.x, tr.y, tr.w, tr.h, radius_control(), th_outline());
    if (a.*.flash_raw.len == 0) {
        ui_empty_state(f, sr, "no FIR loaded", "choose a bounded Flash FIR above");
        ui_empty_state(f, tr, "no operation trace", "import then Run or Step");
    } else {
        let pos: i32 = 0; let row: i32 = 0;
        while (pos < a.*.flash_raw.len && row < 16) {
            let en: i32 = pos;
            while (en < a.*.flash_raw.len && (a.*.flash_raw[en] as i32) != 10) { en = en + 1; }
            draw_text_max(f, sr.x + 7, sr.y + 7 + row * 15, a.*.flash_raw[pos..en], th_text_dim(), sr.w - 14);
            pos = en + 1; row = row + 1;
        }
        let i: i32 = 0;
        while (i < a.*.flash_tags.len && i < 16) {
            let yy: i32 = tr.y + 7 + i * 16;
            draw_text_max(f, tr.x + 7, yy, a.*.flash_tags.data[i], th_text(), 112);
            let os: []u8 = _zag_str_concat("op ", _zag_i64_to_str(a.*.flash_ops.data[i] as i64));
            draw_text(f, tr.x + 126, yy, os, th_text_dim());
            let es: []u8 = _zag_str_concat("expected ", trit_glyph(a.*.flash_expected.data[i]));
            let ecol: i64 = th_warning();
            if (a.*.flash_verify_errors == 0) { ecol = th_ok(); }
            draw_text(f, tr.x + 184, yy, es, ecol);
            i = i + 1;
        }
    }
    draw_text(f, pr.x + 12, pr.y + pr.h - 24,
              "FIR import is simulated software evidence; no fabricated-hardware claim.", th_warning());
    if (ui_button(f, inp, rect(pr.x + pr.w - 88, pr.y + pr.h - 28, 76, 20), "Close", false)) {
        a.*.flash_open = false;
    }
    inp.*.capture = cap;
}

fn draw_modal(a: *App) void {
    if (a.*.modal == modal_none()) { return; }
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    // The modal owns the pointer. Underlying panels were already rendered inert
    // with capture=4; release capture here so modal buttons themselves work.
    inp.*.capture = 0;

    if (a.*.modal == modal_open()) {
        let r: Rect = modal_frame(a, 380, 300, "Open Design");
        let y: i32 = r.y + 30;
        if (a.*.modal_files.len == 0) {
            draw_text(f, r.x + 12, y + 6, "no .zpa designs in this folder", th_text_dim());
        }
        let i: i32 = 0;
        while (i < a.*.modal_files.len && y < r.y + r.h - 56) {
            let nm: []u8 = list.get[[]u8](a.*.modal_files, i);
            let row: Rect = rect(r.x + 8, y, r.w - 16, 18);
            let hov: bool = rect_has(row, inp.*.mx, inp.*.my);
            let _eid: i64 = ui_register(inp, "option", nm, nm, row, true, false, false);
            if (hov) { fill_rect(f, row.x, row.y, row.w, row.h, th_accent()); }
            draw_text(f, row.x + 6, y + 5, nm, th_text());
            if (hov && btn_released(inp, 0)) {
                app_open_file(a, nm);
                a.*.modal = modal_none();
            }
            y = y + 19;
            i = i + 1;
        }
        if (ui_button(f, inp, rect(r.x + r.w - 88, r.y + r.h - 26, 80, 18), "Cancel", false)) {
            a.*.modal = modal_none();
        }
        return;
    }

    if (a.*.modal == modal_recovery()) {
        let r: Rect = modal_frame(a, 460, 250, "Recover Autosave");
        draw_text(f, r.x + 12, r.y + 34,
                  "Choose one of the three retained pre-save snapshots.", th_text_dim());
        let y: i32 = r.y + 56;
        if (a.*.modal_files.len == 0) {
            ui_empty_state(f, rect(r.x + 8, y, r.w - 16, 110),
                           "no recovery snapshots", "autosave history appears after edits");
        }
        let i: i32 = 0;
        while (i < a.*.modal_files.len) {
            let p: []u8 = a.*.modal_files.data[i];
            let row: Rect = rect(r.x + 8, y, r.w - 16, 26);
            let label: []u8 = _zag_str_concat("Restore snapshot ", _zag_i64_to_str((i + 1) as i64));
            if (ui_button(f, inp, row, label, false)) { let _ok: bool = app_recover_file(a, p); }
            y = y + 31; i = i + 1;
        }
        if (ui_button(f, inp, rect(r.x + r.w - 88, r.y + r.h - 26, 80, 18), "Cancel", false)) {
            a.*.modal = modal_none();
        }
        return;
    }

    if (a.*.modal == modal_permission()) {
        let r: Rect = modal_frame(a, 440, 156, "Write Permission");
        draw_text(f, r.x + 14, r.y + 38, "This workspace is read-only under the current host policy.", th_text());
        draw_text(f, r.x + 14, r.y + 56, "Allow edits once, or keep inspecting without mutation.", th_text_dim());
        draw_text(f, r.x + 14, r.y + 78, "Enter allows once; Esc keeps read-only.", th_accent_hot());
        if (ui_button(f, inp, rect(r.x + 14, r.y + 108, 118, 24), "Allow once", true)) {
            app_permission_allow_once(a);
        }
        if (ui_button(f, inp, rect(r.x + 140, r.y + 108, 138, 24), "Keep read-only", false)) {
            app_permission_keep_read_only(a);
        }
        return;
    }

    if (a.*.modal == modal_saveas()) {
        let r: Rect = modal_frame(a, 380, 118, "Save Design As");
        draw_text(f, r.x + 12, r.y + 34, "file name:", th_text_dim());
        let field: Rect = rect(r.x + 12, r.y + 48, r.w - 24, 20);
        fill_rect(f, field.x, field.y, field.w, field.h, rgb(18, 18, 22));
        rect_outline(f, field.x, field.y, field.w, field.h, th_accent());
        let txt: []u8 = a.*.modal_text.data[0..a.*.modal_text.len];
        draw_text(f, field.x + 6, field.y + 6, txt, th_text());
        // caret
        fill_rect(f, field.x + 6 + text_w(txt) + 1, field.y + 4, 1, 12, th_accent_hot());
        if (ui_button(f, inp, rect(r.x + r.w - 176, r.y + r.h - 26, 80, 18), "Save", false)) {
            app_saveas_commit(a);
        }
        if (ui_button(f, inp, rect(r.x + r.w - 88, r.y + r.h - 26, 80, 18), "Cancel", false)) {
            a.*.modal = modal_none();
        }
        return;
    }

    if (a.*.modal == modal_keys()) {
        let r: Rect = modal_frame(a, 420, 312, "Shortcuts");
        let x: i32 = r.x + 14;
        let y: i32 = r.y + 32;
        draw_text(f, x, y, "1..5", th_accent_hot());
        draw_text(f, x + 90, y, "arm a component for placement", th_text());
        y = y + 16;
        draw_text(f, x, y, "Q / E", th_accent_hot());
        draw_text(f, x + 90, y, "select tool / route tool", th_text());
        y = y + 16;
        draw_text(f, x, y, "R", th_accent_hot());
        draw_text(f, x + 90, y, "rotate placement ghost", th_text());
        y = y + 16;
        draw_text(f, x, y, "G", th_accent_hot());
        draw_text(f, x + 90, y, "move selection (click to drop)", th_text());
        y = y + 16;
        draw_text(f, x, y, "Shift+D", th_accent_hot());
        draw_text(f, x + 90, y, "duplicate selection", th_text());
        y = y + 16;
        draw_text(f, x, y, "X / Del", th_accent_hot());
        draw_text(f, x + 90, y, "delete selection", th_text());
        y = y + 16;
        draw_text(f, x, y, "Shift+click", th_accent_hot());
        draw_text(f, x + 90, y, "add or remove from selection", th_text());
        y = y + 16;
        draw_text(f, x, y, "F / Home", th_accent_hot());
        draw_text(f, x + 90, y, "frame selected / frame all", th_text());
        y = y + 16;
        draw_text(f, x, y, "T", th_accent_hot());
        draw_text(f, x + 90, y, "cycle emitter pattern", th_text());
        y = y + 16;
        draw_text(f, x, y, "Space", th_accent_hot());
        draw_text(f, x + 90, y, "run / pause the simulation", th_text());
        y = y + 16;
        draw_text(f, x, y, "Ctrl+Z / Y", th_accent_hot());
        draw_text(f, x + 90, y, "undo / redo", th_text());
        y = y + 16;
        draw_text(f, x, y, "Ctrl+N/O/S", th_accent_hot());
        draw_text(f, x + 90, y, "new / open / save design", th_text());
        y = y + 16;
        draw_text(f, x, y, "MMB drag", th_accent_hot());
        draw_text(f, x + 90, y, "orbit (Shift+MMB pans)", th_text());
        y = y + 22;
        if (ui_button(f, inp, rect(r.x + r.w - 88, r.y + r.h - 26, 80, 18), "Close", false)) {
            a.*.modal = modal_none();
        }
    }
}

fn draw_access_state(a: *App) void {
    if (a.*.access_state == access_ready()) { return; }
    let f: *FB = &a.*.f; let inp: *Input = &a.*.inp;
    let vp: Rect = zone_center(a);
    let r: Rect = rect(vp.x + 12, vp.y + 12, imin(430, vp.w - 24), 46);
    blend_round_rect(f, r.x, r.y, r.w, r.h, radius_panel(), rgb(8, 10, 15), 232);
    let col: i64 = th_warning(); let title: []u8 = "Loading workspace...";
    if (a.*.access_state == access_disconnected()) { title = "Disconnected"; col = th_danger(); }
    if (a.*.access_state == access_read_only()) { title = "Read-only workspace"; col = th_warning(); }
    round_rect_outline(f, r.x, r.y, r.w, r.h, radius_panel(), col);
    draw_text(f, r.x + 10, r.y + 9, title, col);
    draw_text_max(f, r.x + 10, r.y + 25, a.*.access_message, th_text_dim(), r.w - 126);
    if (a.*.access_state == access_disconnected()) {
        if (ui_button(f, inp, rect(r.x + r.w - 96, r.y + 12, 84, 22), "Retry", false)) {
            app_set_access_state(a, access_loading(), "reconnecting to the live session");
        }
    }
    if (a.*.access_state == access_read_only()) {
        if (ui_button(f, inp, rect(r.x + r.w - 118, r.y + 12, 106, 22), "Request write", false)) {
            app_request_write_access(a);
        }
    }
}

fn draw_model_panel(a: *App) void {
    if (!a.*.model_open) { return; }
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let cap: i32 = inp.*.capture;
    inp.*.capture = 0;
    let pw: i32 = imin(780, inp.*.w - 24);
    let ph: i32 = imin(570, inp.*.h - 48);
    let pr: Rect = rect((inp.*.w - pw) / 2, (inp.*.h - ph) / 2, pw, ph);
    draw_shadow(f, pr.x, pr.y, pr.w, pr.h, radius_panel());
    fill_round_rect(f, pr.x, pr.y, pr.w, pr.h, radius_panel(), th_panel());
    round_rect_outline(f, pr.x, pr.y, pr.w, pr.h, radius_panel(), th_outline());
    draw_text(f, pr.x + 14, pr.y + 14, "PHYSICAL MODEL & PROVENANCE", th_text());
    let schema_line: []u8 = _zag_str_concat("Pinned schema ", fmt_i(a.*.scene.*.model.schema_version as i64));
    draw_text(f, pr.x + 14, pr.y + 31, schema_line, th_accent_hot());
    draw_text(f, pr.x + 120, pr.y + 31, a.*.scene.*.model.id, th_text_dim());
    if (model_can_migrate(a.*.scene.*.model, model_schema_current())) {
        if (ui_button(f, inp, rect(pr.x + pr.w - 206, pr.y + 10, 112, 22), "Migrate to v2", true)) {
            if (model_migrate(&a.*.scene.*.model, 2)) {
                scene_mark_render(a.*.scene); app_mark_dirty(a); app_log(a, "physical model migrated to schema 2");
            }
        }
    }
    if (ui_button(f, inp, rect(pr.x + pr.w - 86, pr.y + 10, 72, 22), "Close", false)) {
        a.*.model_open = false; inp.*.capture = cap; return;
    }

    draw_text(f, pr.x + 14, pr.y + 54, "VERSIONED DEVICE TYPES", th_text_dim());
    let tw: i32 = (pr.w - 28) / 4;
    let ti: i32 = 0;
    while (ti < model_type_schema_count()) {
        let d: DeviceTypeSchema = model_type_schema(ti);
        let tx: i32 = pr.x + 14 + (ti % 4) * tw;
        let ty: i32 = pr.y + 68 + (ti / 4) * 20;
        let ts: []u8 = _zag_str_concat(_zag_str_concat(d.id, "  v"), fmt_i(d.version as i64));
        draw_text(f, tx, ty + 4, ts, th_text());
        ti = ti + 1;
    }

    let grid_y: i32 = pr.y + 116;
    draw_text(f, pr.x + 14, grid_y, "PHYSICAL PARAMETERS", th_text_dim());
    let cols: i32 = 3;
    let cw: i32 = (pr.w - 28) / cols;
    let pi: i32 = 0;
    while (pi < model_param_count()) {
        let col: i32 = pi % cols;
        let row_i: i32 = pi / cols;
        let rr: Rect = rect(pr.x + 14 + col * cw, grid_y + 14 + row_i * 25, cw - 6, 22);
        let p: PhysicalParam = model_param_at(a.*.scene.*.model, pi);
        let selected: bool = a.*.model_param_sel == pi;
        let hov: bool = rect_has(rr, inp.*.mx, inp.*.my);
        if (selected) { fill_round_rect(f, rr.x, rr.y, rr.w, rr.h, radius_control(), th_accent()); }
        else if (hov) { fill_round_rect(f, rr.x, rr.y, rr.w, rr.h, radius_control(), th_header()); }
        let _eid: i64 = ui_register(inp, "gridcell", model_param_name(pi), model_param_name(pi), rr,
                                    true, selected, false);
        draw_text_max(f, rr.x + 5, rr.y + 4, model_param_name(pi), th_text(), rr.w / 2);
        let pv: []u8 = "Unknown";
        if (p.known) { pv = _zag_str_concat(_zag_str_concat(fmt_f1(p.value), " "), p.units); }
        let pvc: i64 = th_warning();
        if (p.known) { pvc = th_text_dim(); }
        draw_text_max(f, rr.x + rr.w / 2, rr.y + 4, pv, pvc, rr.w / 2 - 5);
        if (hov && btn_released(inp, 0)) { a.*.model_param_sel = pi; }
        pi = pi + 1;
    }

    let detail_y: i32 = grid_y + 14 + 9 * 25 + 8;
    let dp: PhysicalParam = model_param_at(a.*.scene.*.model, a.*.model_param_sel);
    hline(f, pr.x + 14, detail_y - 6, pr.w - 28, th_outline_soft());
    draw_text(f, pr.x + 14, detail_y, model_param_name(a.*.model_param_sel), th_text());
    let dpc: i64 = th_warning();
    if (dp.known) { dpc = th_accent_hot(); }
    draw_text(f, pr.x + 14, detail_y + 16,
              _zag_str_concat(_zag_str_concat(evidence_class_name(dp.confidence), "  uncertainty ±"), fmt_f1(dp.uncertainty)), dpc);
    draw_text(f, pr.x + 14, detail_y + 32, _zag_str_concat("Source: ", dp.source), th_text_dim());
    draw_text(f, pr.x + 14, detail_y + 48, _zag_str_concat("Method: ", dp.method), th_text_dim());
    draw_text(f, pr.x + pr.w - 270, detail_y + 32, _zag_str_concat("Version: ", dp.source_version), th_text_dim());
    draw_text(f, pr.x + pr.w - 270, detail_y + 48, _zag_str_concat("Date: ", dp.date_), th_text_dim());

    if (btn_pressed(inp, 0) && !rect_has(pr, inp.*.mx, inp.*.my)) { a.*.model_open = false; }
    inp.*.capture = cap;
}

// ── frame orchestration ───────────────────────────────────────────────────────

// ── Settings panel (Section 20.5) ────────────────────────────────────────────
fn draw_settings_panel(a: *App) void {
    if (!a.*.settings_open) { return; }
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    // This panel is topmost and owns the pointer: its own controls must be live
    // even though the frame set capture to keep everything underneath inert.
    let cap: i32 = inp.*.capture;
    inp.*.capture = 0;
    let gr: Rect = zone_settings_gear(a);
    let pw: i32 = 236;
    let px: i32 = gr.x + gr.w - pw;
    if (px < 4) { px = 4; }
    let pr: Rect = rect(px, menu_h(), pw, 410);
    draw_shadow(f, pr.x, pr.y, pr.w, pr.h, radius_panel());
    fill_round_rect(f, pr.x, pr.y, pr.w, pr.h, radius_panel(), th_panel());
    round_rect_outline(f, pr.x, pr.y, pr.w, pr.h, radius_panel(), th_outline());
    draw_text(f, pr.x + pad_panel(), pr.y + 8, "Settings", th_text());

    let y: i32 = pr.y + 26;
    draw_text(f, pr.x + 10, y + 5, "Optimizer", th_text_dim());
    let e_lbl: []u8 = "Off";
    if (a.*.opt.*.enabled) { e_lbl = "On"; }
    if (ui_button(f, inp, rect(pr.x + pw - 62, y, 52, 18), e_lbl, a.*.opt.*.enabled)) {
        a.*.opt.*.enabled = !a.*.opt.*.enabled;
    }
    y = y + 24;
    draw_text(f, pr.x + 10, y + 5, "CPU budget", th_text_dim());
    if (ui_mini(f, inp, rect(pr.x + pw - 88, y + 2, 16, 16), "-", th_text())) { a.*.opt.*.cpu_budget_pct = imax(1, a.*.opt.*.cpu_budget_pct - 1); }
    if (ui_mini(f, inp, rect(pr.x + pw - 18, y + 2, 16, 16), "+", th_text())) { a.*.opt.*.cpu_budget_pct = imin(20, a.*.opt.*.cpu_budget_pct + 1); }
    let cbx: i32 = pr.x + pw - 62; cbx = cbx + draw_int(f, cbx, y + 5, a.*.opt.*.cpu_budget_pct as i64, th_text_dim());
    draw_text(f, cbx, y + 5, "%", th_text_dim());
    y = y + 24;
    draw_text(f, pr.x + 10, y + 5, "Quiet hours UTC", th_text_dim());
    let qtext: []u8 = _zag_str_concat(_zag_str_concat(_zag_i64_to_str(a.*.opt.*.quiet_start_hour as i64), "-"), _zag_i64_to_str(a.*.opt.*.quiet_end_hour as i64));
    if (ui_button(f, inp, rect(pr.x + pw - 74, y, 64, 18), qtext, opt_quiet_now(a.*.opt))) {
        a.*.opt.*.quiet_start_hour = (a.*.opt.*.quiet_start_hour + 1) % 24;
        a.*.opt.*.quiet_end_hour = (a.*.opt.*.quiet_end_hour + 1) % 24;
    }
    y = y + 24;
    draw_text(f, pr.x + 10, y + 5, "Watchdog", th_text_dim());
    let wd: []u8 = "Armed"; if (a.*.opt.*.suspended) { wd = "Resume"; }
    if (ui_button(f, inp, rect(pr.x + pw - 74, y, 64, 18), wd, !a.*.opt.*.suspended)) { opt_engine_resume(a.*.opt); }
    y = y + 24;
    let policy: []u8 = "Host policy: inspect only"; let pcol: i64 = th_warning();
    if (cap_allowed(cap_edit())) { policy = "Host policy: edits allowed"; pcol = th_ok(); }
    draw_text(f, pr.x + 10, y + 5, policy, pcol);
    y = y + 24;
    if (ui_button(f, inp, rect(pr.x + 10, y, pw - 20, 18), "Reset optimizer defaults", false)) {
        a.*.opt.*.enabled = true; a.*.opt.*.auto_apply = false; a.*.opt.*.min_gain_pct = 1;
        a.*.opt.*.family_dead_path = true; a.*.opt.*.family_const_collapse = true;
        a.*.opt.*.cpu_budget_pct = 5; a.*.opt.*.quiet_start_hour = 22; a.*.opt.*.quiet_end_hour = 7;
        opt_engine_resume(a.*.opt);
    }
    y = y + 24;
    draw_text(f, pr.x + 10, y + 5, "Auto-apply", th_text_dim());
    let a_lbl: []u8 = "Off";
    if (a.*.opt.*.auto_apply) { a_lbl = "On"; }
    if (ui_button(f, inp, rect(pr.x + pw - 62, y, 52, 18), a_lbl, a.*.opt.*.auto_apply)) {
        a.*.opt.*.auto_apply = !a.*.opt.*.auto_apply;
    }
    y = y + 24;
    draw_text(f, pr.x + 10, y + 5, "Min gain", th_text_dim());
    if (ui_mini(f, inp, rect(pr.x + pw - 88, y + 2, 16, 16), "-", th_text())) {
        a.*.opt.*.min_gain_pct = imax(1, a.*.opt.*.min_gain_pct - 1);
    }
    if (ui_mini(f, inp, rect(pr.x + pw - 18, y + 2, 16, 16), "+", th_text())) {
        a.*.opt.*.min_gain_pct = imin(100, a.*.opt.*.min_gain_pct + 1);
    }
    let gx: i32 = pr.x + pw - 62;
    gx = gx + draw_int(f, gx, y + 5, a.*.opt.*.min_gain_pct as i64, th_text_dim());
    draw_text(f, gx, y + 5, "%", th_text_dim());
    y = y + 24;
    draw_text(f, pr.x + 10, y + 5, "Dead-path family", th_text_dim());
    let fd_lbl: []u8 = "Off"; if (a.*.opt.*.family_dead_path) { fd_lbl = "On"; }
    if (ui_button(f, inp, rect(pr.x + pw - 62, y, 52, 18), fd_lbl, a.*.opt.*.family_dead_path)) {
        a.*.opt.*.family_dead_path = !a.*.opt.*.family_dead_path;
    }
    y = y + 24;
    draw_text(f, pr.x + 10, y + 5, "Const-fold family", th_text_dim());
    let fc_lbl: []u8 = "Off"; if (a.*.opt.*.family_const_collapse) { fc_lbl = "On"; }
    if (ui_button(f, inp, rect(pr.x + pw - 62, y, 52, 18), fc_lbl, a.*.opt.*.family_const_collapse)) {
        a.*.opt.*.family_const_collapse = !a.*.opt.*.family_const_collapse;
    }
    y = y + 24;
    draw_text(f, pr.x + 10, y + 5, "HiDPI scale", th_text_dim());
    let s_lbl: []u8 = "1x";
    if (a.*.ui_scale == 2) { s_lbl = "2x"; }
    if (a.*.ui_scale == 3) { s_lbl = "3x"; }
    if (ui_button(f, inp, rect(pr.x + pw - 62, y, 52, 18), s_lbl, a.*.ui_scale > 1)) {
        a.*.ui_scale = (a.*.ui_scale % 3) + 1;
    }
    y = y + 24;
    // reduced motion (Section 3.11): every ease/pulse becomes instant
    draw_text(f, pr.x + 10, y + 5, "Reduced motion", th_text_dim());
    let rm_lbl: []u8 = "Off";
    if (a.*.inp.reduced_motion) { rm_lbl = "On"; }
    if (ui_button(f, inp, rect(pr.x + pw - 62, y, 52, 18), rm_lbl, a.*.inp.reduced_motion)) {
        a.*.inp.reduced_motion = !a.*.inp.reduced_motion;
    }
    y = y + 24;
    // object-alignment snapping (Section 3.4)
    draw_text(f, pr.x + 10, y + 5, "Object snapping", th_text_dim());
    let sn_lbl: []u8 = "Off";
    if (a.*.snap_obj) { sn_lbl = "On"; }
    if (ui_button(f, inp, rect(pr.x + pw - 62, y, 52, 18), sn_lbl, a.*.snap_obj)) {
        a.*.snap_obj = !a.*.snap_obj;
    }

    if (btn_pressed(inp, 0) && !rect_has(pr, inp.*.mx, inp.*.my) &&
        !rect_has(gr, inp.*.mx, inp.*.my)) {
        a.*.settings_open = false;
    }
    inp.*.capture = cap;
}

// Append an append-only audit record for an applied optimization (Section 20.4).
fn opt_audit(family: i32, gain_pct: i32, removed_n: i32) void {
    let a1: []u8 = _zag_str_concat("optimizer family=", opt_family_name(family));
    let a2: []u8 = _zag_str_concat(a1, " gain_pct=");
    let a3: []u8 = _zag_str_concat(a2, _zag_i64_to_str(gain_pct as i64));
    let a4: []u8 = _zag_str_concat(a3, " removed=");
    let a5: []u8 = _zag_str_concat(a4, _zag_i64_to_str(removed_n as i64));
    audit_append("optimize", a5, 0);
}

// Commit the pending optimizer proposal through the journaled + audited edit path
// (Section 20.4): re-verify output-equivalence, record ONE undoable op covering
// every removal and relabel, write an audit record, and mark the document dirty.
// Both the panel's Apply button and (when enabled) auto-apply route through here.
fn opt_apply_gui(a: *App) void {
    if (!a.*.opt.*.has_pending) { return; }
    let p: *OptProposal = &a.*.opt.*.pending;
    if (opt_verify(a.*.scene, p)) {
        let rid: list.ArrayList[i32] = list.make[i32](4);
        let rnew: list.ArrayList[i32] = list.make[i32](4);
        let ri: i32 = 0;
        while (ri < p.*.relabels.len) {
            list.push[i32](&rid, p.*.relabels.data[ri].comp_id);
            list.push[i32](&rnew, p.*.relabels.data[ri].new_op);
            ri = ri + 1;
        }
        let fam: i32 = p.*.family;
        let gain: i32 = opt_gain_percent(p.*);
        let removed_n: i32 = p.*.removed.len;
        op_optimize(&a.*.jrn, a.*.scene, p.*.removed, rid, rnew);
        list.free[i32](&rid);
        list.free[i32](&rnew);
        opt_audit(fam, gain, removed_n);
        a.*.opt.*.applied_count = a.*.opt.*.applied_count + 1;
        a.*.dirty = true;
    }
    opt_engine_clear_pending(a.*.opt);
}

// ── Optimizer proposal panel (Section 20.4) ──────────────────────────────────
fn draw_opt_panel(a: *App) void {
    if (!a.*.opt_open) { return; }
    let f: *FB = &a.*.f;
    let inp: *Input = &a.*.inp;
    let cap: i32 = inp.*.capture;
    inp.*.capture = 0;   // topmost panel owns the pointer (see draw_settings_panel)
    let ob: Rect = zone_opt_btn(a);
    let pw: i32 = 300;
    let px: i32 = ob.x + ob.w - pw;
    if (px < 4) { px = 4; }
    let ph: i32 = 96;
    if (a.*.opt.*.has_pending && a.*.opt_details) { ph = 156; }
    if (!a.*.opt.*.has_pending) { ph = 56; }
    let pr: Rect = rect(px, menu_h(), pw, ph);
    draw_shadow(f, pr.x, pr.y, pr.w, pr.h, radius_panel());
    fill_round_rect(f, pr.x, pr.y, pr.w, pr.h, radius_panel(), th_panel());
    round_rect_outline(f, pr.x, pr.y, pr.w, pr.h, radius_panel(), th_outline());
    draw_text(f, pr.x + pad_panel(), pr.y + 8, "Optimizer", th_text());

    if (!a.*.opt.*.has_pending) {
        draw_text(f, pr.x + 10, pr.y + 32, "No optimizations found.", th_text_dim());
    } else {
        draw_text(f, pr.x + 10, pr.y + 28, opt_family_name(opt_engine_pending_family(a.*.opt)), th_text());
        let gy: i32 = pr.y + 44;
        draw_text(f, pr.x + 10, gy, "gain ", th_accent_hot());
        let gx: i32 = pr.x + 10 + text_w("gain ");
        gx = gx + draw_int(f, gx, gy, opt_engine_pending_gain(a.*.opt) as i64, th_accent_hot());
        draw_text(f, gx, gy, "%  ", th_accent_hot());
        gx = gx + text_w("%  ");
        gx = gx + draw_int(f, gx, gy, 0 - a.*.opt.*.pending.removed.len as i64, th_text_dim());
        draw_text(f, gx, gy, " parts", th_text_dim());

        let by: i32 = pr.y + 62;
        if (ui_button(f, inp, rect(pr.x + 10, by, 82, 20), "Apply", a.*.opt_previewed)) {
            if (a.*.opt_previewed) {
                opt_apply_gui(a);
                a.*.opt_open = false;
                a.*.opt_details = false;
                a.*.opt_previewed = false;
            } else {
                app_invalid(a, "review Details before Apply");
            }
        }
        if (ui_button(f, inp, rect(pr.x + 98, by, 82, 20), "Ignore", false)) {
            opt_engine_ignore_pending(a.*.opt);
            a.*.opt_open = false;
            a.*.opt_details = false;
        }
        if (ui_button(f, inp, rect(pr.x + 186, by, 82, 20), "Details", a.*.opt_details)) {
            a.*.opt_details = !a.*.opt_details;
            if (a.*.opt_details) { a.*.opt_previewed = true; }
        }
        if (a.*.opt_details) {
            let dy: i32 = pr.y + 90;
            draw_text(f, pr.x + 10, dy, "removes ", th_text_dim());
            let dx: i32 = pr.x + 10 + text_w("removes ");
            dx = dx + draw_int(f, dx, dy, a.*.opt.*.pending.removed.len as i64, th_text_dim());
            draw_text(f, dx, dy, " part(s), relabels ", th_text_dim());
            dx = dx + text_w(" part(s), relabels ");
            dx = dx + draw_int(f, dx, dy, a.*.opt.*.pending.relabels.len as i64, th_text_dim());
            let sy: i32 = pr.y + 108;
            draw_text(f, pr.x + 10, sy, "cost ", th_text_dim());
            let sx: i32 = pr.x + 10 + text_w("cost ");
            sx = sx + draw_int(f, sx, sy, opt_cost_score(a.*.opt.*.pending.before), th_text_dim());
            draw_text(f, sx, sy, " -> ", th_text_dim());
            sx = sx + text_w(" -> ");
            sx = sx + draw_int(f, sx, sy, opt_cost_score(a.*.opt.*.pending.after), th_text_dim());
            draw_text(f, pr.x + 10, pr.y + 128, "equivalent over all inputs", th_ok());
        }
    }

    if (btn_pressed(inp, 0) && !rect_has(pr, inp.*.mx, inp.*.my) &&
        !rect_has(ob, inp.*.mx, inp.*.my)) {
        a.*.opt_open = false;
    }
    inp.*.capture = cap;
}

// ── panel state hashes (Section 3.12) ─────────────────────────────────────────
// Everything a panel renders from is folded into an i64; an unchanged hash
// plus an idle pointer means the cached surface stands in for the frame.

fn hash_textedit(h0: i64, te: *TextEdit) i64 {
    let h: i64 = ps_hash(h0, te.*.buf.len as i64);
    if (te.*.focus) { h = ps_hash(h, 77); }
    let i: i32 = 0;
    while (i < te.*.buf.len) {
        h = ps_hash(h, te.*.buf.data[i] as i64);
        i = i + 1;
    }
    return h;
}

fn hash_sel(a: *App, h0: i64) i64 {
    let h: i64 = ps_hash(h0, a.*.sel.len as i64);
    let i: i32 = 0;
    while (i < a.*.sel.len) {
        h = ps_hash(h, list.get[i32](a.*.sel, i) as i64);
        i = i + 1;
    }
    return ps_hash(h, a.*.sel_guide as i64);
}

// Live output trits of every active part: the data behind outliner badges and
// timeline rows. A sim step that changes nothing visible changes no hash.
fn hash_signals(a: *App, h0: i64) i64 {
    let h: i64 = h0;
    let i: i32 = 0;
    while (i < a.*.scene.*.comps.len) {
        let c: Comp = a.*.scene.*.comps.data[i];
        if (c.kind == Kind.Emitter || c.kind == Kind.Chamber || c.kind == Kind.Detector) {
            h = ps_hash(h, sim_history(a.*.sim, c.id, 0) as i64);
        }
        i = i + 1;
    }
    return h;
}

fn hash_left(a: *App) i64 {
    let h: i64 = 1469598103934665603;
    h = ps_hash(h, a.*.scene.*.render_rev);
    h = ps_hash(h, a.*.scene.*.comps.len as i64);
    h = ps_hash(h, a.*.scene.*.guides.len as i64);
    h = ps_hash(h, a.*.tool as i64);
    h = ps_hash(h, a.*.lib_tab as i64);
    h = ps_hash(h, a.*.lib_drag as i64);
    h = hash_textedit(h, &a.*.lib_search);
    h = hash_sel(a, h);
    h = ps_hash(h, sel_output_trit(a) as i64);
    h = ps_hash(h, a.*.insp_open_t as i64 + a.*.insp_open_e as i64 * 2 +
                   a.*.insp_open_m as i64 * 4 + a.*.insp_open_p as i64 * 8);
    h = ps_hash(h, a.*.insp_edit_field as i64);
    h = hash_textedit(h, &a.*.insp_edit);
    let err_live: i64 = 0;
    if (a.*.insp_err.len > 0 && a.*.frame - a.*.insp_err_frame < 180) { err_live = 1; }
    h = ps_hash(h, err_live);
    h = ps_hash(h, a.*.warn_rev);
    if (a.*.moving) { h = ps_hash(h, 3); }
    h = ps_hash(h, a.*.locked.len as i64);
    h = ps_hash(h, a.*.sim.*.playing as i64);
    // live trits render in the inspector only while something is selected, so
    // an unselected panel ignores signal steps entirely (Section 3.12)
    if (sel_primary(a) >= 0 || a.*.sel_guide >= 0) {
        h = hash_signals(a, h);
        let sgi: i32 = scene_guide_index(a.*.scene, a.*.sel_guide);
        if (sgi >= 0) { h = ps_hash(h, a.*.scene.*.guides.data[sgi].live as i64); }
    }
    return h;
}

fn hash_right(a: *App) i64 {
    let h: i64 = 1099511628211;
    h = ps_hash(h, a.*.scene.*.render_rev);
    h = ps_hash(h, a.*.scene.*.comps.len as i64);
    h = ps_hash(h, a.*.scene.*.guides.len as i64);
    h = ps_hash(h, a.*.out_scroll as i64);
    h = hash_textedit(h, &a.*.out_search);
    h = ps_hash(h, a.*.rename_id as i64);
    h = hash_textedit(h, &a.*.rename_edit);
    h = hash_sel(a, h);
    h = ps_hash(h, a.*.locked.len as i64);
    h = ps_hash(h, a.*.groups.len as i64);
    h = ps_hash(h, a.*.warn_rev);
    let i: i32 = 0;
    while (i < a.*.expand.len) {
        h = ps_hash(h, list.get[i32](a.*.expand, i) as i64);
        i = i + 1;
    }
    h = hash_signals(a, h);
    // waveguide rows carry their live trit color
    let gi: i32 = 0;
    while (gi < a.*.scene.*.guides.len) {
        h = ps_hash(h, a.*.scene.*.guides.data[gi].live as i64);
        gi = gi + 1;
    }
    return h;
}

fn hash_bottom(a: *App) i64 {
    let h: i64 = 14695981039346656;
    h = ps_hash(h, a.*.sim.*.symbol);
    h = ps_hash(h, a.*.sim.*.playing as i64);
    h = ps_hash(h, (a.*.sim.*.speed * 1000.0) as i64);
    h = ps_hash(h, a.*.scene.*.render_rev);
    h = ps_hash(h, a.*.scene.*.comps.len as i64);
    h = ps_hash(h, a.*.tl_zoom as i64);
    h = ps_hash(h, a.*.tl_scrub as i64);
    h = ps_hash(h, a.*.tl_scroll as i64);
    h = ps_hash(h, a.*.tl_pin.len as i64);
    h = ps_hash(h, a.*.tl_hide.len as i64);
    if (a.*.tl_show_hidden) { h = ps_hash(h, 5); }
    h = ps_hash(h, a.*.log_rev);
    h = hash_sel(a, h);
    h = hash_signals(a, h);
    // the interference scope animates its carrier phase per frame
    if (scope_visible(a) && zone_bottom(a).w >= 700 && !a.*.inp.reduced_motion) {
        h = ps_hash(h, a.*.frame);
    }
    return h;
}

fn mouse_in(a: *App, r: Rect) bool {
    return rect_has(r, a.*.inp.mx, a.*.inp.my) || rect_has(r, a.*.pmx, a.*.pmy);
}

// ── dirty-region presentation (perf) ─────────────────────────────────────────
// Union `r` into this frame's present rectangle.
fn present_add(a: *App, x0: i32, y0: i32, x1: i32, y1: i32) void {
    if (x1 <= x0 || y1 <= y0) { return; }
    if (a.*.present_none) {
        a.*.present_x0 = x0;
        a.*.present_y0 = y0;
        a.*.present_x1 = x1;
        a.*.present_y1 = y1;
        a.*.present_none = false;
    } else {
        if (x0 < a.*.present_x0) { a.*.present_x0 = x0; }
        if (y0 < a.*.present_y0) { a.*.present_y0 = y0; }
        if (x1 > a.*.present_x1) { a.*.present_x1 = x1; }
        if (y1 > a.*.present_y1) { a.*.present_y1 = y1; }
    }
}

fn present_add_rect(a: *App, r: Rect) void {
    present_add(a, r.x, r.y, r.x + r.w, r.y + r.h);
}

// Decide which screen region actually changed this frame so the X11 loop can
// upload only that instead of the whole framebuffer. Overlays force a full
// upload; a fully static frame uploads nothing.
fn app_compute_present(a: *App) void {
    a.*.present_none = true;
    a.*.present_full = false;

    // Overlays cover/dim large areas: upload the whole frame.
    if (a.*.menu >= 0 || a.*.modal != modal_none() || a.*.palette_open || a.*.flash_open ||
        a.*.opt_open || a.*.settings_open || a.*.ctx_open || a.*.warn_open ||
        a.*.title_dirty || a.*.frame < 3) {
        a.*.present_full = true;
        a.*.present_none = false;
        return;
    }

    // Panels that re-ran their widget code this frame changed on screen.
    if (a.*.ps_left.draws != a.*.pl_draws_prev) { present_add_rect(a, zone_left(a)); }
    if (a.*.ps_right.draws != a.*.pr_draws_prev) { present_add_rect(a, zone_right(a)); }
    if (a.*.ps_bottom.draws != a.*.pb_draws_prev) { present_add_rect(a, zone_bottom(a)); }

    // The viewport redraws its dynamic overlay every frame; include it whenever
    // anything there could have moved. A dead-still pointer over a paused scene
    // with no animation leaves it untouched (and we skip the upload).
    let mouse_moved: bool = a.*.inp.mx != a.*.pmx || a.*.inp.my != a.*.pmy;
    // sim symbol and scene revision change the viewport without a pointer move
    // (Step button, paste, undo/redo, agent edits, optimizer auto-apply).
    let sim_changed: bool = a.*.sim.*.symbol != a.*.present_sym_prev;
    let rev_changed: bool = a.*.scene.*.render_rev != a.*.present_rev_prev;
    let vp_dirty: bool = a.*.tile_cache.cam_moved || a.*.cam_drag || a.*.moving ||
        a.*.box_sel || a.*.sim.*.playing || a.*.pulse_frame == a.*.frame ||
        a.*.tool != tool_select() || a.*.ghost_ok >= 0 || mouse_moved ||
        a.*.inp.anim_live || sim_changed || rev_changed ||
        (a.*.frame - a.*.sel_frame) < 8 ||
        (a.*.frame - a.*.invalid_frame) < 15;
    if (vp_dirty) { present_add_rect(a, zone_center(a)); }

    // Menu and status strips are thin; refresh them alongside any other change
    // (the status bar tracks the cursor cell, counts, and sim state).
    if (!a.*.present_none) {
        present_add_rect(a, zone_menu(a));
        present_add_rect(a, zone_status(a));
    }

    // A live tooltip is small but can sit anywhere; union its box.
    if (a.*.inp.tip_dwell >= 30 && a.*.inp.tip_text.len > 0) {
        present_add(a, a.*.inp.tip_x - 2, a.*.inp.tip_y - 28,
                    a.*.inp.tip_x + text_w(a.*.inp.tip_text) + 16, a.*.inp.tip_y + 20);
    }

    a.*.pl_draws_prev = a.*.ps_left.draws;
    a.*.pr_draws_prev = a.*.ps_right.draws;
    a.*.pb_draws_prev = a.*.ps_bottom.draws;
    a.*.present_sym_prev = a.*.sim.*.symbol;
    a.*.present_rev_prev = a.*.scene.*.render_rev;
}

fn app_frame(a: *App, dt: f64) void {
    let t0: i64 = _zag_clock_monotonic_ms();

    a.*.inp.frame = a.*.frame;
    a.*.inp.anim_live = false;
    a.*.inp.text_focus = false;
    a.*.inp.tip_text = "";
    a.*.inp.capture = 0;
    ui_catalog_begin(&a.*.inp);
    input_focus_begin(&a.*.inp);
    // an open modal, menu, command palette, context menu, or optimizer/settings
    // panel owns the pointer: panels underneath go inert
    if (a.*.modal != modal_none() || a.*.menu >= 0 || a.*.palette_open || a.*.flash_open || a.*.model_open ||
        a.*.opt_open || a.*.settings_open || a.*.ctx_open) { a.*.inp.capture = 4; }
    if (a.*.inp.capture == 0) { app_splitters(a); }
    // a focused text field owns the keyboard (fields consume keys as they draw)
    let typing: bool = a.*.lib_search.focus || a.*.out_search.focus || a.*.flash_path.focus ||
        a.*.rename_edit.focus || a.*.insp_edit.focus;
    if (a.*.palette_open) { app_palette_keys(a); }
    else if (!typing) { app_keys(a); }
    if (a.*.inp.capture != 4 && !typing) { app_viewport_input(a); }
    app_warnings_rebuild(a);

    // Incremental sim patch: small edits keep symbol time and in-flight state;
    // clear/load or large dirty sets fall back to a full recompile inside.
    if (a.*.scene.*.topo_dirty) { sim_recompile_region(a.*.sim, a.*.scene); }
    let stepped: i32 = sim_update(a.*.sim, a.*.scene, dt);
    if (stepped > 0) { a.*.pulse_frame = a.*.frame; }   // beam pulse (Section 3.11)

    // Optimizer background pass (Section 20.5). Kept off the interaction path: it
    // runs at most once per ~second and only while the user is idle (no drag,
    // move, split, menu, modal, or active simulation). With auto-apply off — the
    // default — a tick only updates the Optimizer badge and never mutates the
    // project, so it is a pure runtime observer.
    if (a.*.frame % opt_cadence_frames(a.*.opt) == 0 && !opt_quiet_now(a.*.opt) &&
        opt_should_run(a.*.opt.*.enabled, a.*.opt.*.suspended, a.*.moving, a.*.cam_drag,
                       a.*.grab != 0, a.*.menu >= 0, a.*.modal != modal_none(),
                       a.*.sim.*.playing, a.*.opt_open || a.*.settings_open || a.*.palette_open || a.*.flash_open || a.*.model_open)) {
        let _oc: bool = opt_engine_refresh_keyed(a.*.opt, a.*.scene);
        if (a.*.opt.*.auto_apply && cap_allowed(cap_edit()) && a.*.opt.*.has_pending) {
            opt_apply_gui(a);   // journaled + audited, single-undo
        }
    }
    fb_resize(&a.*.f, a.*.inp.w, a.*.inp.h);

    draw_viewport(a);

    // ── retained panel surfaces (Section 3.12) ───────────────────────────────
    // A panel re-runs its widget code only when its state hash changed, the
    // pointer is over it (or just left), an ease is mid-flight, or a pointer
    // grab is active; otherwise its cached pixels blit back in one command.
    let force: bool = a.*.anim_live_prev || a.*.inp.capture == 3 || a.*.inp.capture == 1 || a.*.inp.focus_nav;
    // During an active camera drag the panels neither change nor get re-uploaded
    // (dirty-region present sends only the viewport, which never overwrites the
    // panel regions), so their framebuffer pixels persist and the cached blit is
    // pure waste — skip it for real orbit headroom.
    let keep_cached: bool = a.*.cam_drag && a.*.frame > 3;
    let lr: Rect = zone_left(a);
    let lh: i64 = hash_left(a);
    if (force || mouse_in(a, lr) || ps_stale(&a.*.ps_left, lr, lh)) {
        draw_toolbar(a);
        ps_capture(&a.*.f, lr, &a.*.ps_left, lh);
    } else if (!keep_cached) {
        ps_blit(&a.*.f, &a.*.ps_left);
    }
    let rr: Rect = zone_right(a);
    let rh: i64 = hash_right(a);
    if (force || mouse_in(a, rr) || ps_stale(&a.*.ps_right, rr, rh)) {
        draw_outliner(a);
        ps_capture(&a.*.f, rr, &a.*.ps_right, rh);
    } else if (!keep_cached) {
        ps_blit(&a.*.f, &a.*.ps_right);
    }
    let br: Rect = zone_bottom(a);
    let bh: i64 = hash_bottom(a);
    if (force || mouse_in(a, br) || ps_stale(&a.*.ps_bottom, br, bh)) {
        draw_debugger(a);
        ps_capture(&a.*.f, br, &a.*.ps_bottom, bh);
    } else if (!keep_cached) {
        ps_blit(&a.*.f, &a.*.ps_bottom);
    }
    a.*.anim_live_prev = a.*.inp.anim_live;

    draw_statusbar(a);
    draw_menubar(a);
    draw_menu_dropdown(a);
    draw_settings_panel(a);
    draw_opt_panel(a);
    draw_flash_panel(a);
    draw_model_panel(a);
    draw_modal(a);
    draw_palette(a);
    draw_ctx_menu(a);
    draw_warnings_popup(a);
    draw_access_state(a);
    ui_tip_flush(&a.*.f, &a.*.inp);
    input_focus_end(&a.*.inp);

    app_compute_present(a);

    a.*.pmx = a.*.inp.mx;
    a.*.pmy = a.*.inp.my;
    a.*.frame = a.*.frame + 1;
    a.*.frame_ms = _zag_clock_monotonic_ms() - t0;
}
