// agent.zag — headless agent RPC for CLI and MCP wrappers.
//
// Protocol (stdin/stdout, one command per line):
//   Request:  <verb> [args...]
//   Response: OK [message]          — success, optional one-line payload
//             OK                    — start of multi-line block
//             <data lines>
//             .                     — end of block
//             ERR <message>         — failure
//
// Examples:
//   place plate 6 0 10 0     -> OK id=3 name=GeSn_Plate.1
//   list                     -> OK + component/guide lines + .
//   sim step 24              -> OK symbol=24
//   test engine              -> OK passed (runs ./probe/engine_test)

@import("../std/list.zag") as list
@import("app.zag")
@import("workspace.zag")
@import("routing.zag")
@import("sim.zag")
@import("editops.zag")
@import("demo.zag")
@import("ternary.zag")

struct Tok {
    off: i32,
    len: i32,
}

fn tok_slice(line: []u8, t: Tok) []u8 {
    return line[t.off..t.off + t.len];
}

fn tokenize(line: []u8, out: *list.ArrayList[Tok]) void {
    out.*.len = 0;
    let i: i32 = 0;
    while (i < line.len) {
        while (i < line.len && (line[i] as i32) == 32) { i = i + 1; }
        if (i >= line.len) { return; }
        let st: i32 = i;
        while (i < line.len && (line[i] as i32) != 32) { i = i + 1; }
        list.push[Tok](out, Tok{ .off = st, .len = i - st });
    }
}

fn tok_eq(line: []u8, t: Tok, lit: []u8) bool {
    if (t.len != lit.len) { return false; }
    let i: i32 = 0;
    while (i < t.len) {
        if ((line[t.off + i] as i32) != (lit[i] as i32)) { return false; }
        i = i + 1;
    }
    return true;
}

fn parse_kind_name(s: []u8) i32 {
    if (_zag_strcmp(s, "plate") == 1) { return 0; }
    if (_zag_strcmp(s, "gesn") == 1) { return 0; }
    if (_zag_strcmp(s, "chamber") == 1) { return 1; }
    if (_zag_strcmp(s, "exec") == 1) { return 1; }
    if (_zag_strcmp(s, "soh") == 1) { return 2; }
    if (_zag_strcmp(s, "emitter") == 1) { return 3; }
    if (_zag_strcmp(s, "laser") == 1) { return 3; }
    if (_zag_strcmp(s, "wdm") == 1) { return 3; }
    if (_zag_strcmp(s, "detector") == 1) { return 4; }
    if (_zag_strcmp(s, "sensor") == 1) { return 4; }
    if (_zag_strcmp(s, "mos2") == 1) { return 4; }
    return 0 - 1;
}

fn kind_slug(k: Kind) []u8 {
    if (k == Kind.Plate) { return "plate"; }
    if (k == Kind.Chamber) { return "chamber"; }
    if (k == Kind.Soh) { return "soh"; }
    if (k == Kind.Emitter) { return "emitter"; }
    return "detector";
}

fn agent_flush() void { _zag_flush(); }

fn agent_ok1(msg: []u8) void {
    _zag_print("OK ");
    _zag_println(msg);
    agent_flush();
}

fn agent_ok0() void {
    _zag_println("OK");
    agent_flush();
}

fn agent_err(msg: []u8) void {
    _zag_print("ERR ");
    _zag_println(msg);
    agent_flush();
}

fn agent_dot() void {
    _zag_println(".");
    agent_flush();
}

fn agent_print_i(name_: []u8, v: i64) void {
    _zag_print(name_);
    _zag_print(_zag_i64_to_str(v));
}

fn tok_i64(line: []u8, t: Tok) i64 {
    return _zag_str_to_i64(tok_slice(line, t));
}

fn agent_help() void {
    agent_ok0();
    _zag_println("# triton agent commands");
    _zag_println("ping | help | quit");
    _zag_println("new | demo | open <file.zpa> | save <file.zpa> | list_files");
    _zag_println("place <kind> <x> <y> <z> [rot] | delete <id> | route <fc> <fp> <tc> <tp>");
    _zag_println("can_place <kind> <x> <y> <z> [rot] | list | get <id> | select <id>");
    _zag_println("sim step [n] | sim reset | sim state | render <out.bmp>");
    _zag_println("status | coords | power | perf | kinds");
    _zag_println("test engine | test smoke | build");
    _zag_println("kinds: plate chamber soh emitter detector");
    agent_dot();
}

fn agent_status(a: *App) void {
    let play: i64 = 0;
    if (a.*.sim.*.playing) { play = 1; }
    let spd: i64 = a.*.sim.*.speed as i64;
    let msg: []u8 = _zag_str_concat("frame=", _zag_i64_to_str(a.*.frame));
    let m2: []u8 = _zag_str_concat(msg, " comps=");
    let m3: []u8 = _zag_str_concat(m2, _zag_i64_to_str(a.*.scene.*.comps.len as i64));
    let m4: []u8 = _zag_str_concat(m3, " guides=");
    let m5: []u8 = _zag_str_concat(m4, _zag_i64_to_str(a.*.scene.*.guides.len as i64));
    let m6: []u8 = _zag_str_concat(m5, " symbol=");
    let m7: []u8 = _zag_str_concat(m6, _zag_i64_to_str(a.*.sim.*.symbol));
    let m8: []u8 = _zag_str_concat(m7, " playing=");
    let m9: []u8 = _zag_str_concat(m8, _zag_i64_to_str(play));
    let m10: []u8 = _zag_str_concat(m9, " speed=");
    let m11: []u8 = _zag_str_concat(m10, _zag_i64_to_str(spd));
    let m12: []u8 = _zag_str_concat(m11, " frame_ms=");
    let m13: []u8 = _zag_str_concat(m12, _zag_i64_to_str(a.*.frame_ms));
    let m14: []u8 = _zag_str_concat(m13, " file=");
    agent_ok1(_zag_str_concat(m14, a.*.file_));
}

