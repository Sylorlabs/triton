// reference_pcu_ui_test.zag — visible reference-PCU workflow (Masterplan 9.3).
// Uses the same command dispatch as the Debug library card and command palette,
// then exercises the live simulation, save, and reopen path on the canonical
// Flash PCU. It is intentionally an App test rather than a direct Scene load.

@import("../src/workspace.zag")

fn check(name_: []u8, ok: bool, failures: *i32) void {
    if (ok) { _zag_print("  ok  "); } else { _zag_print("  XX  "); failures.* = failures.* + 1; }
    _zag_println(name_);
}

fn main() i32 {
    let failures: i32 = 0;
    let a: *App = app_new(1440, 900);

    // Code 32 is exposed by both the Debug library card and command palette.
    app_action(a, 32);
    check("visible reference-PCU command loads the canonical Flash design",
        a.*.scene.*.comps.len == 384 && a.*.scene.*.guides.len == 192,
        &failures);
    check("reference-PCU command frames the loaded design", a.*.cam.dist > 1.0, &failures);

    // The existing Run control maps to this state, and app_frame drives the
    // exact production simulation update path used by the signal timeline.
    let before: i64 = a.*.sim.*.symbol;
    app_action(a, 42);
    app_frame(a, 1.0);
    app_action(a, 42);
    check("visible Run control advances the reference-PCU simulation",
        a.*.sim.*.symbol > before, &failures);

    a.*.file_ = "/tmp/triton_reference_pcu_ui.zpa";
    app_save(a);
    let saved_n: i32 = a.*.scene.*.comps.len;
    app_new_design(a);
    app_open_file(a, "/tmp/triton_reference_pcu_ui.zpa");
    check("visible save then open preserves the reference PCU", a.*.scene.*.comps.len == saved_n,
        &failures);

    // Flash FIR workspace: visible command, bounded import, source/operation
    // inspector state, and the same Run/Step simulation controls.
    app_action(a, 49);
    check("visible Flash FIR Workspace command opens the panel", a.*.flash_open, &failures);
    let imported: bool = app_flash_import(a, "examples/flash_reference.fir");
    check("Flash FIR import builds every operation into the design",
        imported && a.*.flash_ops.len == 4 && a.*.scene.*.comps.len == 24, &failures);
    check("Flash source and per-operation trace are retained for inspection",
        a.*.flash_raw.len > 0 && a.*.flash_tags.len == 4 && a.*.flash_verify_errors == 0,
        &failures);
    let fsym: i64 = a.*.sim.*.symbol;
    sim_step(a.*.sim, a.*.scene);
    check("Flash Step control advances the imported program", a.*.sim.*.symbol == fsym + 1, &failures);
    app_frame(a, 0.016); // renders the full source/operation panel path

    let bad: bool = app_flash_import(a, "corpus/flash/bad_operation.fir");
    check("invalid Flash FIR produces an explicit error state without pretending success",
        !bad && a.*.flash_verify_errors < 0 && a.*.invalid_text.len > 0, &failures);

    if (failures == 0) { _zag_println("REFERENCE PCU UI: ALL PASS"); return 0; }
    _zag_println("REFERENCE PCU UI: FAILURES"); return 1;
}
