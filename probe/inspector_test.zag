// inspector_test.zag — inspector live beam-state readout (Masterplan Sections
// 3.4/3.8 / Phase F). Verifies the source the inspector reads for the selected
// component's live output trit.

@import("../std/list.zag") as list
@import("../src/flash_ir.zag")
@import("../src/workspace.zag")

fn check(name_: []u8, ok: bool, failures: *i32) void {
    if (ok) { _zag_print("  ok  "); } else { _zag_print("  XX  "); failures.* = failures.* + 1; }
    _zag_println(name_);
}

fn main() i32 {
    let failures: i32 = 0;
    let a: *App = app_new(1024, 640);
    let plate: i32 = scene_place(a.*.scene, Kind.Plate, vox(0, 0, 0), 0);
    let e: i32 = scene_place(a.*.scene, Kind.Emitter, vox(1, 1, 2), 0);
    let c: i32 = scene_place(a.*.scene, Kind.Chamber, vox(4, 1, 3), 0);
    let d: i32 = scene_place(a.*.scene, Kind.Detector, vox(7, 1, 4), 0);
    let ei: i32 = scene_comp_index(a.*.scene, e);
    a.*.scene.*.comps.data[ei].preset = 6;    // constant +1
    let cii: i32 = scene_comp_index(a.*.scene, c);
    a.*.scene.*.comps.data[cii].logic_op = 2;  // negate
    let _r: bool = flash_route(a.*.scene, e, 0, c, 0) && flash_route(a.*.scene, c, 3, d, 0);

    sim_recompile(a.*.sim, a.*.scene);
    let step: i32 = 0;
    while (step < 16) { sim_step(a.*.sim, a.*.scene); step = step + 1; }

    sel_set(a, d);
    let sd: i32 = sel_output_trit(a);
    check("selected detector reports a valid live trit", signal_is_trit(sd), &failures);
    check("inspector output matches the simulation history", sd == sim_history(a.*.sim, d, 0), &failures);

    sel_set(a, e);
    check("selected emitter reports its live output",
        sel_output_trit(a) == sim_history(a.*.sim, e, 0), &failures);

    sel_set(a, plate);
    check("passive plate has no beam output", sel_output_trit(a) == signal_unknown(), &failures);

    sel_clear(a);
    check("empty selection has no beam output", sel_output_trit(a) == signal_unknown(), &failures);

    if (failures == 0) { _zag_println("INSPECTOR: ALL PASS"); return 0; }
    _zag_println("INSPECTOR: FAILURES"); return 1;
}
