// ui_agent_access_test.zag — the automation catalog is generated by the live
// widgets and supplies stable IDs, exact bounds, state, activation, and capture.

@import("../src/agent.zag")

fn check(name_: []u8, ok: bool, failures: *i32) void {
    if (ok) { _zag_print("  ok  "); } else { _zag_print("  XX  "); failures.* = failures.* + 1; }
    _zag_println(name_);
}

fn find_label(a: *App, label: []u8) i32 {
    let i: i32 = 0;
    while (i < a.*.inp.ui_elements.len) {
        if (_zag_strcmp(a.*.inp.ui_elements.data[i].label, label) == 1) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

fn role_seen(a: *App, role: []u8) bool {
    let i: i32 = 0;
    while (i < a.*.inp.ui_elements.len) {
        if (_zag_strcmp(a.*.inp.ui_elements.data[i].role, role) == 1) { return true; }
        i = i + 1;
    }
    return false;
}

fn bounds_valid(a: *App) bool {
    let i: i32 = 0;
    while (i < a.*.inp.ui_elements.len) {
        let r: Rect = a.*.inp.ui_elements.data[i].bounds;
        if (r.w <= 0 || r.h <= 0 || r.x < 0 || r.y < 0 ||
            r.x + r.w > a.*.inp.w || r.y + r.h > a.*.inp.h) { return false; }
        i = i + 1;
    }
    return true;
}

fn main() i32 {
    let failures: i32 = 0;
    let a: *App = app_new(1024, 720);
    app_action_demo(a);
    agent_ui_refresh(a);
    check("live catalog enumerates a broad visible control surface", a.*.inp.ui_elements.len >= 35, &failures);
    check("catalog includes buttons textboxes tabs options tree items disclosures and menubar items",
        role_seen(a, "button") && role_seen(a, "textbox") && role_seen(a, "tab") &&
        role_seen(a, "option") && role_seen(a, "treeitem") && role_seen(a, "disclosure") &&
        role_seen(a, "menubaritem"), &failures);
    check("every advertised click target is inside the real framebuffer", bounds_valid(a), &failures);

    let si: i32 = find_label(a, "Settings");
    check("custom chrome controls have stable semantic entries", si >= 0, &failures);
    let sid: i64 = 0;
    if (si >= 0) { sid = a.*.inp.ui_elements.data[si].id; }
    a.*.inp.w = 1280; a.*.inp.h = 800;
    agent_ui_refresh(a);
    let si2: i32 = find_label(a, "Settings");
    check("element ID is stable when layout coordinates change",
        si2 >= 0 && a.*.inp.ui_elements.data[si2].id == sid, &failures);

    if (si2 >= 0) { agent_ui_activate(a, sid); }
    check("authorized activation uses the live click target", a.*.settings_open, &failures);
    agent_ui_refresh(a);
    check("opened surfaces expose their controls and states", find_label(a, "Reset optimizer defaults") >= 0, &failures);

    a.*.settings_open = false;
    a.*.model_open = true;
    agent_ui_refresh(a);
    let cells: i32 = 0;
    let j: i32 = 0;
    while (j < a.*.inp.ui_elements.len) {
        if (_zag_strcmp(a.*.inp.ui_elements.data[j].role, "gridcell") == 1) { cells = cells + 1; }
        j = j + 1;
    }
    check("physical-model UI exposes every parameter as an addressable control", cells == model_param_count(), &failures);
    agent_render(a, "/tmp/prism_ui_agent_access.bmp");
    let bmp: []u8 = _zag_read_file("/tmp/prism_ui_agent_access.bmp");
    check("agent screenshot captures the same UI state", bmp.len > 54 && bmp[0] == 66 && bmp[1] == 77, &failures);

    if (failures == 0) { _zag_println("UI AGENT ACCESS: ALL PASS"); return 0; }
    _zag_println("UI AGENT ACCESS: FAILURES"); return 1;
}
