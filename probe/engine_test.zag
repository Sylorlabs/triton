// engine_test.zag — headless engine validation:
// placement DRC, removal cascades, A* routing, ternary interference sim.

@import("../std/list.zag") as list
@import("../std/hashmap.zag") as hm
@import("../src/scene.zag")
@import("../src/routing.zag")
@import("../src/sim.zag")
@import("../src/sim_region.zag")
@import("../src/editops.zag")

fn check(name_: []u8, ok: bool, fails: *i32) void {
    if (ok) {
        _zag_print("  ok  ");
        _zag_println(name_);
    } else {
        _zag_print("  XX  ");
        _zag_println(name_);
        fails.* = fails.* + 1;
    }
}

fn main() i32 {
    let fails: i32 = 0;
    let s: *Scene = scene_new();

    // ── placement rules ──
    check("chamber floating in space rejected (needs plate)",
        scene_can_place(s, Kind.Chamber, vox(1, 1, 1), 0) == 3, &fails);
    check("plate off-ground rejected",
        scene_can_place(s, Kind.Plate, vox(20, 1, 0), 0) == 2, &fails);

    let plate: i32 = scene_place(s, Kind.Plate, vox(0, 0, 0), 0);
    check("plate placed on ground", plate > 0, &fails);
    check("chamber on plate accepted",
        scene_can_place(s, Kind.Chamber, vox(3, 1, 3), 0) == 0, &fails);

    let ch: i32 = scene_place(s, Kind.Chamber, vox(3, 1, 3), 0);
    check("chamber placed", ch > 0, &fails);
    check("overlapping chamber rejected",
        scene_can_place(s, Kind.Chamber, vox(4, 1, 4), 0) == 1, &fails);

    // ── emitters, detector, SOH ──
    let e1: i32 = scene_place(s, Kind.Emitter, vox(0, 1, 1), 0);
    let e2: i32 = scene_place(s, Kind.Emitter, vox(0, 1, 5), 0);
    let det: i32 = scene_place(s, Kind.Detector, vox(7, 1, 4), 0);
    check("emitters + detector placed", e1 > 0 && e2 > 0 && det > 0, &fails);

    let e1i: i32 = scene_comp_index(s, e1);
    let e2i: i32 = scene_comp_index(s, e2);
    check("emitter WDM channels distinct",
        s.*.comps.data[e1i].wl_nm < s.*.comps.data[e2i].wl_nm, &fails);

    // ── routing ──
    let e1c: Comp = s.*.comps.data[e1i];
    let chc: Comp = s.*.comps.data[scene_comp_index(s, ch)];
    let dtc: Comp = s.*.comps.data[scene_comp_index(s, det)];

    let p1: list.ArrayList[Vox] = list.make[Vox](32);
    let a1: Vox = comp_port_attach(e1c, 0);
    let b1: Vox = comp_port_attach(chc, 0);   // IN.A
    check("route emitter1 -> chamber IN.A", route_guide(s, a1, b1, &p1), &fails);
    check("route endpoints correct",
        vox_eq(p1.data[0], a1) && vox_eq(p1.data[p1.len - 1], b1), &fails);
    // 6-connectivity of every hop
    let conn: bool = true;
    let hi: i32 = 1;
    while (hi < p1.len) {
        if (vox_manhattan(p1.data[hi], p1.data[hi - 1]) != 1) { conn = false; }
        hi = hi + 1;
    }
    check("route is 6-connected", conn, &fails);
    let g1: i32 = scene_add_guide(s, e1, 0, ch, 0, p1);

    let p2: list.ArrayList[Vox] = list.make[Vox](32);
    let e2c: Comp = s.*.comps.data[scene_comp_index(s, e2)];
    let a2: Vox = comp_port_attach(e2c, 0);
    let b2: Vox = comp_port_attach(chc, 1);   // IN.B
    check("route emitter2 -> chamber IN.B", route_guide(s, a2, b2, &p2), &fails);
    let _g2: i32 = scene_add_guide(s, e2, 0, ch, 1, p2);

    let p3: list.ArrayList[Vox] = list.make[Vox](32);
    let a3: Vox = comp_port_attach(chc, 3);   // OUT
    let b3: Vox = comp_port_attach(dtc, 0);   // SENSE
    check("route chamber OUT -> detector", route_guide(s, a3, b3, &p3), &fails);
    let _g3: i32 = scene_add_guide(s, ch, 3, det, 0, p3);
    check("port in use tracked", scene_port_in_use(s, ch, 0), &fails);

    // ── interference sim ──
    // Force constant opposite-phase sources: presets replaced by direct check
    // of the balanced sum. preset 0 pattern starts "+0-.."; instead verify
    // interference algebra directly, then run the compiled pipeline.
    check("trit algebra: +1 & -1 cancel", trit_sat_add(1, 0 - 1) == 0, &fails);
    check("trit algebra: +1 & +1 saturate", trit_from_sum(2) == 1, &fails);

    let sim: *Sim = sim_new();
    sim_recompile(sim, s);
    check("sim compiled nodes", sim.*.nodes.len == s.*.comps.len, &fails);
    check("sim compiled guides", sim.*.sguides.len == 3, &fails);

    // Both emitters share preset stepping; drive 40 symbols and confirm the
    // detector reproduces the interference of the two source patterns with
    // the correct per-hop latency.
    let steps: i32 = 0;
    while (steps < 40) {
        sim_step(sim, s);
        steps = steps + 1;
    }
    // pipeline latency: emitter->chamber guide delay + chamber->detector delay
    // (delays are quantized from real propagation time against the derived
    // clock; read them back from the compiled fabric)
    check("clock derived from placed parts", sim.*.clock_ghz > 0.0, &fails);
    let original_clock: f64 = sim.*.clock_ghz;
    s.*.model.emitter_rate_ghz.value = original_clock / 2.0;
    sim_recompile(sim, s);
    check("changing device model changes derived timing without source edit",
        sim.*.clock_ghz == original_clock / 2.0, &fails);
    s.*.model.emitter_rate_ghz.value = original_clock;
    sim_recompile(sim, s);
    check("complete illustrative model permits simulation", sim.*.model_ok, &fails);
    s.*.model.group_index.known = false;
    sim_recompile(sim, s);
    let blocked_symbol: i64 = sim.*.symbol;
    sim_step(sim, s);
    check("incomplete model cannot silently advance verified simulation",
        !sim.*.model_ok && sim.*.symbol == blocked_symbol, &fails);
    s.*.model.group_index.known = true;
    sim_recompile(sim, s);
    let d_in: i32 = sim.*.sguides.data[0].delay;
    let d_out: i32 = sim.*.sguides.data[2].delay;
    let lat: i32 = d_in + d_out;
    // The chamber interferes the two WDM carriers as complex fields: each
    // arrives with phase 2*pi*n_g*L/lambda from its routed length, and the
    // cavity discriminates the in-phase component. The detector then reads
    // the regenerated trit coherently.
    let e1p: i32 = s.*.comps.data[e1i].preset;
    let e2p: i32 = s.*.comps.data[e2i].preset;
    let g0re: f64 = sim.*.sguides.data[0].ph_re;
    let g1re: f64 = sim.*.sguides.data[1].ph_re;
    let all_match: bool = true;
    let back: i32 = 0;
    while (back < 20) {
        let t_det: i64 = sim.*.symbol - 1 - (back as i64);
        let t_src: i64 = t_det - (lat as i64);
        if (t_src >= 0) {
            let fld: f64 = (preset_trit(e1p, t_src) as f64) * g0re
                         + (preset_trit(e2p, t_src) as f64) * g1re;
            let want: i32 = trit_from_field(fld);
            let got: i32 = sim_history(sim, det, back);
            if (want != got) { all_match = false; }
        }
        back = back + 1;
    }
    check("detector reads interference of both WDM sources", all_match, &fails);

    // ── SOH memory ──
    let soh: i32 = scene_place(s, Kind.Soh, vox(5, 1, 3), 0);
    check("SOH tile placed beside chamber", soh > 0, &fails);
    check("chamber sees SOH tile", scene_soh_adjacent(s, ch) == 1, &fails);

    // ── removal cascade ──
    check("guides present before removal", s.*.guides.len == 3, &fails);
    scene_remove(s, e1);
    check("removing emitter drops its guide", s.*.guides.len == 2, &fails);
    check("emitter cells freed", scene_cell_owner(s, vox(0, 1, 1)) < 0, &fails);
    let refill: i32 = scene_place(s, Kind.Emitter, vox(0, 1, 1), 0);
    check("freed cells reusable", refill > 0, &fails);

    // chamber quota: fill a fresh plate with 64 chambers (8x8 of 2x2 at y=1
    // exceeds an 8x8 plate; use 4 plates -> 16x16 area = 64 chambers exactly)
    let q0: i32 = scene_place(s, Kind.Plate, vox(100, 0, 0), 0);
    let _q1: i32 = scene_place(s, Kind.Plate, vox(108, 0, 0), 0);
    let _q2: i32 = scene_place(s, Kind.Plate, vox(100, 0, 8), 0);
    let _q3: i32 = scene_place(s, Kind.Plate, vox(108, 0, 8), 0);
    check("quota plates placed", q0 > 0, &fails);
    let placed: i32 = 0;
    let qx: i32 = 0;
    while (qx < 8) {
        let qz: i32 = 0;
        while (qz < 8) {
            let r: i32 = scene_place(s, Kind.Chamber, vox(100 + qx * 2, 1, qz * 2), 0);
            if (r > 0) { placed = placed + 1; }
            qz = qz + 1;
        }
        qx = qx + 1;
    }
    // each 8x8 plate holds 16 chambers (4x4 of 2x2); the quota is per-plate,
    // so all 64 place fine — but a 65th on any of those plates must fail...
    check("64 chambers across the board", placed == 64, &fails);

    // ── undo / redo journal ──
    let j: Journal = journal_new();
    let _jplate: i32 = scene_place(s, Kind.Plate, vox(130, 0, 0), 0);
    let before_comps: i32 = s.*.comps.len;
    let nch: i32 = scene_place(s, Kind.Chamber, vox(130, 1, 0), 0);
    check("journal: chamber placed", nch > 0, &fails);
    op_add_comp(&j, s, nch);
    check("journal: undo removes it", journal_undo(&j, s) && s.*.comps.len == before_comps, &fails);
    check("journal: redo restores it (same id)",
        journal_redo(&j, s) && scene_comp_index(s, nch) >= 0, &fails);
    op_del_comp(&j, s, nch);
    scene_remove(s, nch);
    check("journal: undo of delete restores", journal_undo(&j, s) && scene_comp_index(s, nch) >= 0, &fails);

    // ── group move with waveguide re-route (fresh plate clear of quota grid) ──
    let _mvplate: i32 = scene_place(s, Kind.Plate, vox(120, 0, 0), 0);
    let mv_e: i32 = scene_place(s, Kind.Emitter, vox(121, 1, 1), 0);
    let mv_d: i32 = scene_place(s, Kind.Detector, vox(125, 1, 1), 0);
    check("move: parts placed", mv_e > 0 && mv_d > 0, &fails);
    let mvec: Comp = s.*.comps.data[scene_comp_index(s, mv_e)];
    let mvdc: Comp = s.*.comps.data[scene_comp_index(s, mv_d)];
    let mp: list.ArrayList[Vox] = list.make[Vox](32);
    check("move: routed", route_guide(s, comp_port_attach(mvec, 0), comp_port_attach(mvdc, 0), &mp), &fails);
    let mgid: i32 = scene_add_guide(s, mv_e, 0, mv_d, 0, mp);
    let ids: list.ArrayList[i32] = list.make[i32](2);
    list.push[i32](&ids, mv_d);
    check("move: DRC accepts shift", group_can_move(s, &ids, vox(1, 0, 1)) == 0, &fails);
    group_move(s, &ids, vox(1, 0, 1));
    let moved: Comp = s.*.comps.data[scene_comp_index(s, mv_d)];
    check("move: origin updated", vox_eq(moved.origin, vox(126, 1, 2)), &fails);
    let mgi: i32 = scene_guide_index(s, mgid);
    check("move: guide survived re-route", mgi >= 0, &fails);
    if (mgi >= 0) {
        let g2: Guide = s.*.guides.data[mgi];
        let want_end: Vox = comp_port_attach(moved, 0);
        check("move: guide re-routed to new port",
            vox_eq(list.get[Vox](g2.path, g2.path.len - 1), want_end), &fails);
    }

    // ── save / load roundtrip ──
    check("save design", design_save(s, "/tmp/triton_engine_test.zpa"), &fails);
    let s2: *Scene = scene_new();
    check("load design", design_load(s2, "/tmp/triton_engine_test.zpa"), &fails);
    check("roundtrip: component count", s2.*.comps.len == s.*.comps.len, &fails);
    check("roundtrip: guide count", s2.*.guides.len == s.*.guides.len, &fails);
    let rt_ok: bool = true;
    let ri: i32 = 0;
    while (ri < s.*.comps.len) {
        let ca: Comp = s.*.comps.data[ri];
        let ci2: i32 = scene_comp_index(s2, ca.id);
        if (ci2 < 0) { rt_ok = false; }
        else {
            let cb: Comp = s2.*.comps.data[ci2];
            if (!vox_eq(ca.origin, cb.origin) || ca.rot != cb.rot || kind_index(ca.kind) != kind_index(cb.kind)) { rt_ok = false; }
            if (!_zag_str_eq_wrap(ca.name_, cb.name_)) { rt_ok = false; }
        }
        ri = ri + 1;
    }
    check("roundtrip: every part identical", rt_ok, &fails);
    check("roundtrip: occupancy rebuilt",
        scene_cell_owner(s2, s.*.comps.data[0].origin) == s.*.comps.data[0].id, &fails);
    check("roundtrip: placement still enforced",
        scene_can_place(s2, Kind.Chamber, vox(3, 1, 3), 0) == 1, &fails);
    check("roundtrip: device model version pinned", s2.*.model.schema_version == 1, &fails);
    check("roundtrip: physical model values preserved",
        s2.*.model.pitch_nm.value == s.*.model.pitch_nm.value &&
        s2.*.model.emitter_rate_ghz.value == s.*.model.emitter_rate_ghz.value, &fails);

    // ── journal persistence ──
    let jj: Journal = journal_new();
    let _jp: i32 = scene_place(s, Kind.Plate, vox(140, 0, 0), 0);
    let jch: i32 = scene_place(s, Kind.Chamber, vox(140, 1, 0), 0);
    op_add_comp(&jj, s, jch);
    check("journal: save", journal_save(&jj, "/tmp/triton_engine_test.jrn"), &fails);
    let jj2: Journal = journal_new();
    check("journal: load", journal_load(&jj2, "/tmp/triton_engine_test.jrn"), &fails);
    check("journal: roundtrip undo depth", jj2.undo.len == jj.undo.len, &fails);
    let comps_before: i32 = s.*.comps.len;
    check("journal: loaded undo works", journal_undo(&jj2, s) && s.*.comps.len == comps_before - 1, &fails);
    journal_clear(&jj);
    journal_clear(&jj2);

    // ── incremental sim patching ──
    let psim: *Sim = sim_new();
    sim_recompile_region(psim, s);          // initial full build
    let pn: i32 = 0;
    while (pn < 20) { sim_step(psim, s); pn = pn + 1; }
    check("patch: sim advanced", psim.*.symbol == 20, &fails);
    let pplate: i32 = scene_place(s, Kind.Plate, vox(220, 0, 0), 0);
    let pch: i32 = scene_place(s, Kind.Chamber, vox(221, 1, 1), 0);
    check("patch: parts placed", pplate > 0 && pch > 0, &fails);
    sim_recompile_region(psim, s);
    check("patch: symbol time preserved across small edit", psim.*.symbol == 20, &fails);
    check("patch: new node present", sim_node_index(psim, pch) >= 0, &fails);
    check("patch: topo flags cleared", !s.*.topo_dirty, &fails);
    scene_remove(s, pch);
    sim_recompile_region(psim, s);
    check("patch: removed node dropped", sim_node_index(psim, pch) < 0, &fails);
    check("patch: time still preserved", psim.*.symbol == 20, &fails);
    scene_remove(s, pplate);
    sim_recompile_region(psim, s);

    // ── hashmap tombstone churn ──
    // put/del/get cycles: probe chains must survive tombstones.
    let tm: hm.Int64Map[i32] = hm.int64_make[i32](8);
    let ti: i64 = 0;
    while (ti < 500) {
        hm.int64_put[i32](&tm, ti, (ti as i32) * 3);
        ti = ti + 1;
    }
    let td: i64 = 0;
    while (td < 500) {                       // delete every even key
        let _g: bool = hm.del[i64, i32](&tm.inner, td);
        td = td + 2;
    }
    let tomb_ok: bool = true;
    let tq: i64 = 1;
    while (tq < 500) {                       // every odd key must survive
        let got: i32 = hm.int64_get[i32](tm, tq) orelse (0 - 1);
        if (got != (tq as i32) * 3) { tomb_ok = false; }
        tq = tq + 2;
    }
    let tq2: i64 = 0;
    while (tq2 < 500) {                      // every even key must be gone
        if (hm.int64_has[i32](tm, tq2)) { tomb_ok = false; }
        tq2 = tq2 + 2;
    }
    check("hashmap: lookups survive tombstones", tomb_ok, &fails);
    let tr: i64 = 0;
    while (tr < 500) {                       // reinsert into tombstoned slots
        hm.int64_put[i32](&tm, tr, (tr as i32) * 7);
        tr = tr + 2;
    }
    let re_ok: bool = true;
    let rq: i64 = 0;
    while (rq < 500) {
        let want: i32 = (rq as i32) * 3;
        if (rq % 2 == 0) { want = (rq as i32) * 7; }
        let got2: i32 = hm.int64_get[i32](tm, rq) orelse (0 - 1);
        if (got2 != want) { re_ok = false; }
        rq = rq + 1;
    }
    check("hashmap: reinsert after delete, no duplicates", re_ok, &fails);
    hm.int64_free[i32](&tm);

    // ── occupancy churn: place/remove cycles must not corrupt the lattice ──
    let cp: i32 = scene_place(s, Kind.Plate, vox(200, 0, 0), 0);
    check("churn: plate placed", cp > 0, &fails);
    let round: i32 = 0;
    let churn_ok: bool = true;
    while (round < 30) {
        let ids2: list.ArrayList[i32] = list.make[i32](16);
        let px: i32 = 0;
        while (px < 3) {   // chamber fp is 2x2x2: stride 2, stay on the 8x8 plate
            let cid: i32 = scene_place(s, Kind.Chamber, vox(200 + px * 2, 1, (round % 3) * 2), 0);
            if (cid < 0) { churn_ok = false; }
            list.push[i32](&ids2, cid);
            px = px + 1;
        }
        // every placed comp must own its origin cell
        let vi: i32 = 0;
        while (vi < ids2.len) {
            let cid2: i32 = list.get[i32](ids2, vi);
            let ci3: i32 = scene_comp_index(s, cid2);
            if (ci3 < 0) { churn_ok = false; }
            else if (scene_cell_owner(s, s.*.comps.data[ci3].origin) != cid2) { churn_ok = false; }
            vi = vi + 1;
        }
        let di2: i32 = 0;
        while (di2 < ids2.len) {
            scene_remove(s, list.get[i32](ids2, di2));
            di2 = di2 + 1;
        }
        // all churn cells free again
        let fx: i32 = 0;
        while (fx < 6) {
            if (scene_cell_owner(s, vox(200 + fx, 1, (round % 3) * 2)) >= 0) { churn_ok = false; }
            fx = fx + 1;
        }
        list.free[i32](&ids2);
        round = round + 1;
    }
    check("churn: occupancy exact through 30 place/remove rounds", churn_ok, &fails);
    check("churn: DRC accepts freed cells",
        scene_can_place(s, Kind.Chamber, vox(200, 1, 0), 0) == 0, &fails);

    if (fails == 0) { _zag_println("ENGINE: ALL PASS"); return 0; }
    _zag_println("ENGINE: FAILURES");
    return 1;
}

fn _zag_str_eq_wrap(a: []u8, b: []u8) bool {
    return _zag_strcmp(a, b) == 1;
}
