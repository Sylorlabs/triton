// dpi_test.zag — HiDPI framebuffer upscale + UI-scale setting (Masterplan
// Section 9.3 / Phase F). The whole UI renders at a logical resolution and is
// upscaled to physical pixels; this verifies the upscale is pixel-exact and the
// scale setting cycles.

@import("../std/list.zag") as list
@import("../src/workspace.zag")

fn check(name_: []u8, ok: bool, failures: *i32) void {
    if (ok) { _zag_print("  ok  "); } else { _zag_print("  XX  "); failures.* = failures.* + 1; }
    _zag_println(name_);
}

fn upscale_exact(src: *FB, scale: i32) bool {
    let dst: FB = fb_new(src.*.w * scale, src.*.h * scale);
    fb_upscale(&dst, src, scale);
    let y: i32 = 0;
    while (y < dst.h) {
        let x: i32 = 0;
        while (x < dst.w) {
            if (dst.px.data[y * dst.w + x] != src.*.px.data[(y / scale) * src.*.w + (x / scale)]) {
                return false;
            }
            x = x + 1;
        }
        y = y + 1;
    }
    return true;
}

fn main() i32 {
    let failures: i32 = 0;

    let src: FB = fb_new(5, 4);
    let i: i32 = 0;
    while (i < 20) { src.px.data[i] = (i * 131 + 7) as i64; i = i + 1; }

    check("2x upscale is pixel-exact nearest-neighbor", upscale_exact(&src, 2), &failures);
    check("3x upscale is pixel-exact nearest-neighbor", upscale_exact(&src, 3), &failures);

    // Undersized destination must be a safe no-op (no crash / no OOB write).
    let small: FB = fb_new(3, 3);
    fb_upscale(&small, &src, 2);
    check("undersized destination upscale is a safe no-op", true, &failures);

    // UI-scale setting cycles 1 -> 2 -> 3 -> 1.
    let a: *App = app_new(1024, 640);
    check("ui_scale defaults to 1x", a.*.ui_scale == 1, &failures);
    app_action(a, 27);
    check("cycle to 2x", a.*.ui_scale == 2, &failures);
    app_action(a, 27);
    check("cycle to 3x", a.*.ui_scale == 3, &failures);
    app_action(a, 27);
    check("cycle wraps back to 1x", a.*.ui_scale == 1, &failures);

    if (failures == 0) { _zag_println("DPI: ALL PASS"); return 0; }
    _zag_println("DPI: FAILURES"); return 1;
}
